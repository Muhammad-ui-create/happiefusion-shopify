      "label": "Input placeholder",
      "default": "Enter discount code"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Apply"
    },
    {
      "type": "text",
      "id": "remove_text",
      "label": "Remove button text",
      "default": "Remove"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
