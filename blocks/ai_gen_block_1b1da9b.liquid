      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "input_background_color",
      "label": "Input background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "input_text_color",
      "label": "Input text",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "input_border_color",
      "label": "Input border",
      "default": "#d1d1d1"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button background",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button hover background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Border radius"
    },
    {
      "type": "range",
      "id": "input_border_radius",
      "label": "Input and messages",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Button",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "header",
      "content": "Success message"
    },
    {
      "type": "color",
      "id": "success_background",
      "label": "Background",
      "default": "#d4edda"
    },
    {
      "type": "color",
      "id": "success_text_color",
      "label": "Text",
      "default": "#155724"
    },
    {
      "type": "color",
      "id": "success_border_color",
      "label": "Border",
      "default": "#c3e6cb"
    },
    {
      "type": "header",
      "content": "Error message"
    },
    {
      "type": "color",
      "id": "error_background",
