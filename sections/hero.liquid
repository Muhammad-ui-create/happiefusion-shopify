<!-- Google's model-viewer web component for 3D GLB rendering -->
<script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.5.0/model-viewer.min.js"></script>

<section class="hero" itemscope itemtype="https://schema.org/Product">
  <meta itemprop="name" content="Happie Fungi Fusion Functional Mushroom Seltzer">
  <meta itemprop="brand" content="Happie Fusion">
  <div class="hero-inner">
    <div class="hero-text">
      <div class="hero-eyebrow">Functional Mushroom Seltzer · Alcohol-Free · Caffeine-Free</div>
      <h1 class="hero-headline">Focus. Energy.<br>Calm. In a Can.</h1>
      <p class="hero-sub">900mg Lion's Mane + 700mg Cordyceps + 400mg Reishi — <strong>2,000mg total</strong> per can. Zero alcohol. Zero caffeine. Real adaptogenic results.</p>
      <div class="hero-badges">
        <span class="no-alc-badge">No Alcohol</span>
        <span class="no-alc-badge">No Caffeine</span>
        <span class="no-alc-badge">No Jitters</span>
        <span class="no-alc-badge">Vegan &amp; Non-GMO</span>
      </div>
      <div class="hero-ctas">
        <a href="/collections/all" class="btn-primary">Shop Mushroom Seltzers →</a>
        <a href="/pages/the-science" class="btn-ghost">The Science ↗</a>
      </div>
      <div class="hero-trust">
        <span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3h6l1 4H8L9 3z"/><path d="M8 7v10a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V7"/><path d="M12 11v3M11 13h2"/></svg> Third-party lab tested</span>
        <span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22V12"/><path d="M12 12C12 12 7 10 6 6c3 0 6 2 6 6z"/><path d="M12 12c0 0 5-2 6-6-3 0-6 2-6 6z"/></svg> 100% Fruiting body extract</span>
        <span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="6" width="15" height="11" rx="2"/><path d="M16 10h4l3 3v4h-7"/><circle cx="5.5" cy="19.5" r="1.5"/><circle cx="20.5" cy="19.5" r="1.5"/></svg> Free shipping on $75+</span>
      </div>
    </div>
    <div class="hero-visual">
      <div class="hero-ring-wrap">
        <div class="hero-glow"></div>
        <div class="hero-ring-outer"></div>
        <div class="hero-ring-mid"></div>
        <div class="hero-ring-inner"></div>

        <!-- Interactive 3D can — rotates automatically, drag to spin, AR-enabled -->
        <model-viewer
          src="{{ 'happie-can-3d.glb' | asset_url }}"
          alt="Happie Fungi Fusion Blue Raspberry — interactive 3D can. Drag to rotate, or tap to view in AR."
          class="hero-can-3d"
          auto-rotate
          auto-rotate-delay="0"
          rotation-per-second="20deg"
          camera-controls
          camera-orbit="0deg 85deg 105%"
          min-camera-orbit="auto 75deg 90%"
          max-camera-orbit="auto 95deg 130%"
          orientation="0deg 0deg 90deg"
          disable-pan
          touch-action="pan-y"
          interaction-prompt="none"
          shadow-intensity="0.5"
          shadow-softness="1.0"
          exposure="1.85"
          tone-mapping="commerce"
          environment-image="neutral"
          loading="eager"
          reveal="auto"
          poster="{{ 'can-hero.png' | asset_url }}"
          ar
          ar-modes="webxr scene-viewer quick-look"
          ar-scale="auto"
          ar-placement="floor"
          ios-src="{{ 'happie-can-3d.usdz' | asset_url }}"
        >
          <!-- Loading state -->
          <div slot="progress-bar" class="hero-3d-loader">
            <div class="hero-3d-loader-fill"></div>
          </div>

          <!-- Custom AR button (overrides default) -->
          <button slot="ar-button" class="hero-ar-btn" type="button">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
              <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
              <line x1="12" y1="22.08" x2="12" y2="12"/>
            </svg>
            View in your space
          </button>
        </model-viewer>

        <!-- Drag hint -->
        <div class="hero-3d-hint">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-9-9c2.5 0 4.7 1 6.3 2.7M21 4v5h-5"/></svg>
          Drag to spin
        </div>
      </div>
      <div class="hero-pills">
        <div class="hero-pill">
          <span class="pill-label">FOCUS</span>
          <span class="pill-val">900mg Lion's Mane</span>
        </div>
        <div class="hero-pill">
          <span class="pill-label">ENERGY</span>
          <span class="pill-val">700mg Cordyceps</span>
        </div>
        <div class="hero-pill">
          <span class="pill-label">CALM</span>
          <span class="pill-val">400mg Reishi</span>
        </div>
      </div>
    </div>
  </div>

  <style>
    /* 3D can styling — sizes to match the previous <img> footprint */
    .hero-can-3d {
      width: 320px;
      height: 480px;
      max-width: 100%;
      background: transparent;
      --poster-color: transparent;
      position: relative; z-index: 5;
      cursor: grab;
      /* prevent overflow on tight containers */
      display: block;
    }
    .hero-can-3d:active { cursor: grabbing; }

    /* Custom progress loader */
    .hero-3d-loader {
      position: absolute; left: 50%; bottom: 24px;
      transform: translateX(-50%);
      width: 80px; height: 3px;
      background: rgba(0,0,0,0.08);
      border-radius: 3px; overflow: hidden;
    }
    .hero-3d-loader-fill {
      width: 0%; height: 100%;
      background: var(--green, #52B788);
      transition: width 0.2s ease;
    }

    /* Drag hint pill */
    .hero-3d-hint {
      position: absolute; bottom: -8px; left: 50%;
      transform: translateX(-50%);
      display: inline-flex; align-items: center; gap: 6px;
      background: rgba(45,106,79,0.92); color: #fff;
      padding: 7px 14px; border-radius: 50px;
      font-size: 11px; font-weight: 700; letter-spacing: 0.06em;
      text-transform: uppercase;
      z-index: 10; pointer-events: none;
      animation: hintPulse 3s ease-in-out infinite;
      backdrop-filter: blur(8px);
      box-shadow: 0 8px 24px rgba(0,0,0,0.15);
    }
    @keyframes hintPulse {
      0%, 100% { opacity: 0.55; transform: translateX(-50%) translateY(0); }
      50% { opacity: 1; transform: translateX(-50%) translateY(-3px); }
    }

    /* Hide hint after first interaction */
    .hero-can-3d:active ~ .hero-3d-hint,
    .hero-can-3d.user-interacted ~ .hero-3d-hint {
      opacity: 0; transition: opacity 0.4s; pointer-events: none;
    }

    /* AR button — appears at top of 3D viewer on AR-capable devices */
    .hero-ar-btn {
      position: absolute; top: 16px; right: 16px;
      display: inline-flex; align-items: center; gap: 7px;
      background: rgba(255,255,255,0.96);
      color: var(--green-dark, #2D6A4F);
      border: 1.5px solid rgba(45,106,79,0.2);
      border-radius: 50px;
      padding: 9px 16px;
      font-family: 'Poppins', sans-serif;
      font-size: 12px; font-weight: 700;
      letter-spacing: 0.04em;
      cursor: pointer;
      box-shadow: 0 8px 24px rgba(0,0,0,0.12);
      transition: all 0.2s;
      backdrop-filter: blur(8px);
      z-index: 20;
    }
    .hero-ar-btn:hover {
      background: var(--green-dark, #2D6A4F);
      color: #fff;
      transform: translateY(-1px);
      box-shadow: 0 12px 28px rgba(45,106,79,0.3);
    }
    .hero-ar-btn svg { flex-shrink: 0; }

    /* AR button hidden by default; JS shows it on Android only */
    .hero-ar-btn { display: none; }

    @media (max-width: 768px) {
      .hero-can-3d { width: 200px; height: 300px; }
      .hero-ar-btn { font-size: 10px; padding: 7px 12px; top: 8px; right: 8px; gap: 5px; }
      .hero-ar-btn svg { width: 13px; height: 13px; }
      .hero-3d-hint { font-size: 9px; padding: 5px 10px; gap: 4px; }
    }
    @media (max-width: 420px) {
      .hero-can-3d { width: 170px; height: 260px; }
    }
  </style>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      var mv = document.querySelector('.hero-can-3d');
      if (!mv) return;

      // Loader progress
      var fill = mv.querySelector('.hero-3d-loader-fill');
      mv.addEventListener('progress', function(e) {
        if (fill) fill.style.width = (e.detail.totalProgress * 100) + '%';
      });

      // Hide hint on user interaction
      var hideHint = function() { mv.classList.add('user-interacted'); };
      mv.addEventListener('pointerdown', hideHint);

      // ── AR button — show/hide based on real AR capability ──
      var arBtn = mv.querySelector('.hero-ar-btn');
      var ua = navigator.userAgent;
      var isAndroid = /Android/i.test(ua);
      var isIOS = /iPad|iPhone|iPod/i.test(ua);
      var isMobile = isAndroid || isIOS;

      // Wait for model-viewer to load + check AR capability
      mv.addEventListener('load', function() {
        // AR is mobile-only — both Android (Scene Viewer w/ GLB) and iOS (Quick Look w/ USDZ) work
        if (!isMobile) {
          if (arBtn) arBtn.style.display = 'none';
          return;
        }
        if (arBtn) arBtn.style.display = 'inline-flex';
      });

      // Wire the button manually so it always triggers AR on supported devices
      if (arBtn) {
        arBtn.addEventListener('click', function(e) {
          e.preventDefault();
          if (mv.activateAR) {
            mv.activateAR();
          }
        });
      }
    });
  </script>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": []
}
{% endschema %}
