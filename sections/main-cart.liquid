<div class="cart-page">
  <div class="section-inner">
    <h1>Your Cart</h1>
    {% if cart.item_count == 0 %}
      <div class="cart-empty">
        <p>Your cart is empty.</p>
        <a href="/collections/all" class="btn-primary">Shop Now →</a>
      </div>
    {% else %}
      <div class="cart-layout">
        <div class="cart-items">
          {% for item in cart.items %}
            <div class="cart-item">
              <a href="{{ item.url }}">
                <img src="{{ item.image | image_url: width: 120 }}" alt="{{ item.title }}" class="cart-item-img" />
              </a>
              <div class="cart-item-info">
                <div class="cart-item-title">{{ item.product.title }}</div>
                <div class="cart-item-variant">{{ item.variant.title }}</div>
                {% if item.selling_plan_allocation %}
                  <div class="cart-item-plan">{{ item.selling_plan_allocation.selling_plan.name }}</div>
                {% endif %}
                <div class="cart-item-qty-row">
                  <a href="{{ routes.cart_change_url }}?id={{ item.key }}&quantity={{ item.quantity | minus: 1 }}" class="qty-btn-sm">−</a>
                  <span class="cart-item-qty">{{ item.quantity }}</span>
                  <a href="{{ routes.cart_change_url }}?id={{ item.key }}&quantity={{ item.quantity | plus: 1 }}" class="qty-btn-sm">+</a>
                  <a href="{{ routes.cart_change_url }}?id={{ item.key }}&quantity=0" class="remove-link">Remove</a>
                </div>
              </div>
              <div class="cart-item-price">{{ item.line_price | money }}</div>
            </div>
          {% endfor %}
        </div>
        <div class="cart-summary">
          <div class="cart-summary-row">
            <span>Subtotal</span>
            <span>{{ cart.total_price | money }}</span>
          </div>
          {% if cart.total_price < 7500 %}
            <p class="free-ship-msg">Add {{ 7500 | minus: cart.total_price | money }} more for free shipping!</p>
          {% else %}
            <p class="free-ship-msg free-ship-unlocked">🚚 You've unlocked free shipping!</p>
          {% endif %}
          <a href="/checkout" class="btn-atc">Checkout →</a>
          <a href="/collections/all" class="btn-keep-shopping">← Continue Shopping</a>
        </div>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Main Cart",
  "settings": []
}
{% endschema %}
