<div class="cart-page">
  <div class="section-inner">
    <h1>Your Cart</h1>
    {% if cart.item_count == 0 %}
      <div class="cart-empty">
        <p>Your cart is empty.</p>
        <a href="/collections/all" class="btn-primary">Shop Now →</a>
      </div>
    {% else %}
      <div class="cart-layout">
        <div class="cart-items">
          {% for item in cart.items %}
            <div class="cart-item">
              <a href="{{ item.url }}">
                <img src="{{ item.image | image_url: width: 120 }}" alt="{{ item.title }}" class="cart-item-img" />
              </a>
              <div class="cart-item-info">
                <div class="cart-item-title">{{ item.product.title }}</div>
                <div class="cart-item-variant">{{ item.variant.title }}</div>
                {% if item.selling_plan_allocation %}
                  <div class="cart-item-plan">{{ item.selling_plan_allocation.selling_plan.name }}</div>
                {% endif %}
                <div class="cart-item-qty-row">
                  <a href="{{ routes.cart_change_url }}?id={{ item.key }}&quantity={{ item.quantity | minus: 1 }}" class="qty-btn-sm">−</a>
                  <span class="cart-item-qty">{{ item.quantity }}</span>
                  <a href="{{ routes.cart_change_url }}?id={{ item.key }}&quantity={{ item.quantity | plus: 1 }}" class="qty-btn-sm">+</a>
                  <a href="{{ routes.cart_change_url }}?id={{ item.key }}&quantity=0" class="remove-link">Remove</a>
                </div>
              </div>
              <div class="cart-item-price">{{ item.line_price | money }}</div>
            </div>
          {% endfor %}
        </div>
        <div class="cart-summary">
          <div class="cart-summary-row">
            <span>Subtotal</span>
            <span>{{ cart.total_price | money }}</span>
          </div>
          {% comment %} Free shipping threshold: $41.99 — show progress nudge below it {% endcomment %}
          {%- if cart.total_price >= 4199 -%}
            <p class="free-ship-msg free-ship-unlocked">🚚 Free shipping unlocked!</p>
          {%- else -%}
            <p class="free-ship-msg">🚚 Add <strong>{{ 4199 | minus: cart.total_price | money }}</strong> more for free shipping</p>
          {%- endif -%}
          <a href="/checkout" class="btn-atc">Checkout →</a>
          <a href="/collections/all" class="btn-keep-shopping">← Continue Shopping</a>

          <!-- Social proof + trust trio — last reassurance before checkout -->
          <div class="cart-review-card">
            <div class="cart-review-stars" aria-hidden="true">★★★★★</div>
            <blockquote>"Best adaptogen drink I've tried! Love the mild relaxed feeling. Tastes great without being too sweet."</blockquote>
            <cite>— Shannon B. · Verified Amazon Purchase</cite>
          </div>
          <div class="cart-trust-trio">
            <div class="cart-trust-item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-12V5l-8-3-8 3v5c0 8 8 12 8 12z"/><path d="M9 12l2 2 4-4"/></svg>
              <strong>Lab Tested</strong>
              <span>Every batch, third-party verified</span>
            </div>
            <div class="cart-trust-item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="6" width="15" height="11" rx="2"/><path d="M16 10h4l3 3v4h-7"/><circle cx="5.5" cy="19.5" r="1.5"/><circle cx="20.5" cy="19.5" r="1.5"/></svg>
              <strong>Fast Shipping</strong>
              <span>Ships in 1 business day · free over $41.99</span>
            </div>
            <div class="cart-trust-item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              <strong>Secure Payments</strong>
              <span>30-day full refund guarantee</span>
            </div>
          </div>
        </div>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Main Cart",
  "settings": []
}
{% endschema %}
