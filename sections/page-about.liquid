        <div><div style="font-size:48px;font-weight:900;color:#fff;">40+</div><div style="font-size:14px;color:rgba(255,255,255,0.65);margin-top:6px;">States shipping to</div></div>
        <div><div style="font-size:48px;font-weight:900;color:#fff;">100%</div><div style="font-size:14px;color:rgba(255,255,255,0.65);margin-top:6px;">Lab verified batches</div></div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="padding:80px 24px;text-align:center;background:var(--cream);">
    <h2 style="font-size:clamp(28px,4vw,40px);font-weight:900;margin-bottom:16px;">Taste the difference.</h2>
    <p style="font-size:17px;color:var(--gray);margin-bottom:32px;">Start with any flavor. You'll understand in one can.</p>
    <a href="/collections/all" class="btn-primary btn-lg">Shop Now →</a>
