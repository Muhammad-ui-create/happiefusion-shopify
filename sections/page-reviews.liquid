<style>
/* ── REVIEWS PAGE ── */
.rev-hero {
  background: linear-gradient(135deg, #0B3D2E 0%, #1B5E42 50%, #2D6A4F 100%);
  padding: 100px 24px 70px; text-align: center;
  position: relative; overflow: hidden;
}
.rev-hero::before {
  content: ''; position: absolute; inset: 0;
  background: radial-gradient(ellipse at 70% 20%, rgba(82,183,136,0.18) 0%, transparent 55%);
  pointer-events: none;
}
.rev-eyebrow {
  display: inline-flex; align-items: center; gap: 6px;
  background: rgba(245,166,35,0.15); border: 1px solid rgba(245,166,35,0.3);
  color: #F5A623; font-size: 11px; font-weight: 800; letter-spacing: 0.14em;
  text-transform: uppercase; padding: 6px 16px; border-radius: 50px;
  margin-bottom: 20px;
}
.rev-hero-title {
  font-size: clamp(34px,5vw,58px); font-weight: 900; line-height: 1.05;
  color: #fff; margin: 0 0 24px;
}
.rev-hero-rating {
  display: inline-flex; align-items: center; gap: 16px;
  background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.12);
  border-radius: 20px; padding: 16px 28px; margin-bottom: 32px;
}
.rev-stars-large { color: #F5A623; font-size: 28px; letter-spacing: 2px; }
.rev-score-num { font-size: 26px; font-weight: 900; color: #fff; line-height: 1; }
.rev-score-num span { font-size: 16px; font-weight: 500; color: rgba(255,255,255,0.6); }
.rev-score-sub { font-size: 12px; color: rgba(255,255,255,0.55); margin-top: 4px; }

/* Filters */
.rev-filters { display: flex; justify-content: center; flex-wrap: wrap; gap: 10px; }
.rev-filter {
  display: flex; align-items: center; gap: 7px;
  padding: 9px 20px; border-radius: 50px;
  background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15);
  color: rgba(255,255,255,0.7); font-size: 13px; font-weight: 600;
  cursor: pointer; transition: all 0.2s;
}
.rev-filter:hover, .rev-filter.active {
  background: rgba(255,255,255,0.18); border-color: rgba(255,255,255,0.3); color: #fff;
}
.rev-filter-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }

/* Breakdown */
.rev-breakdown { background: #fff; padding: 40px 24px; border-bottom: 1px solid rgba(0,0,0,0.07); }
.rev-breakdown-inner { max-width: 500px; margin: 0 auto; display: flex; flex-direction: column; gap: 10px; }
.rev-bar-row { display: flex; align-items: center; gap: 12px; font-size: 14px; }
.rev-bar-label { width: 36px; text-align: right; font-weight: 700; color: #333; }
.rev-bar-track { flex: 1; height: 10px; background: #F0F0F0; border-radius: 10px; overflow: hidden; }
.rev-bar-fill { height: 100%; border-radius: 10px; transition: width 0.8s ease; }
.rev-bar-pct { width: 32px; font-size: 12px; color: #888; font-weight: 600; }

/* Reviews grid */
.rev-section { padding: 64px 24px 80px; background: var(--cream, #F5F0E8); }
.rev-grid-wrap { max-width: 1200px; margin: 0 auto; }
.rev-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 18px;
}

/* Review card */
.rev-card {
  background: #fff; border-radius: 20px;
  padding: 24px; border: 1.5px solid rgba(0,0,0,0.06);
  display: flex; flex-direction: column; gap: 12px;
  transition: transform 0.2s, box-shadow 0.2s;
}
.rev-card:hover { transform: translateY(-4px); box-shadow: 0 12px 40px rgba(0,0,0,0.09); }
.rev-card.hidden { display: none; }

.rev-card-top { display: flex; justify-content: space-between; align-items: center; }
.rev-card-stars { color: #F5A623; font-size: 15px; letter-spacing: 1px; }

.rev-flavor-tag {
  font-size: 10px; font-weight: 800; letter-spacing: 0.08em;
  text-transform: uppercase; padding: 4px 10px; border-radius: 50px;
}
.rev-flavor-blue { background: rgba(59,111,240,0.1); color: #2855D4; }
.rev-flavor-watermelon { background: rgba(232,76,107,0.1); color: #C03060; }
.rev-flavor-mango { background: rgba(245,166,35,0.12); color: #B8730A; }

.rev-card-title { font-size: 14px; font-weight: 800; color: #111; line-height: 1.3; }
.rev-card-body {
  font-size: 13.5px; color: #555; line-height: 1.75;
  margin: 0; font-style: italic; flex: 1;
}

.rev-card-footer { display: flex; align-items: center; gap: 10px; margin-top: auto; padding-top: 12px; border-top: 1px solid rgba(0,0,0,0.05); }
.rev-avatar {
  width: 36px; height: 36px; border-radius: 50%;
  color: #fff; font-size: 12px; font-weight: 800;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.rev-author-info strong { display: block; font-size: 13px; color: #111; }
.rev-verified {
  display: flex; align-items: center; gap: 4px;
  font-size: 11px; color: #888; margin-top: 2px;
}

/* CTA */
.rev-cta {
  background: var(--green-dark, #2D6A4F);
  padding: 80px 24px; text-align: center;
}
.rev-cta h2 { color: #fff; font-size: clamp(26px,4vw,40px); font-weight: 900; margin-bottom: 12px; }
.rev-cta p { color: rgba(255,255,255,0.75); font-size: 16px; margin-bottom: 28px; }
.rev-cta-btn { background: #fff !important; color: var(--green-dark, #2D6A4F) !important; }

/* Responsive */
@media (max-width: 1100px) { .rev-grid { grid-template-columns: repeat(3, 1fr); } }
@media (max-width: 768px)  { .rev-grid { grid-template-columns: repeat(2, 1fr); } .rev-hero { padding: 80px 20px 60px; } }
@media (max-width: 480px)  { .rev-grid { grid-template-columns: 1fr; } }
</style>

<script>
document.querySelectorAll('.rev-filter').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.rev-filter').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const filter = btn.dataset.filter;
    document.querySelectorAll('.rev-card').forEach(card => {
      if (filter === 'all' || card.dataset.flavor === filter) {
        card.classList.remove('hidden');
      } else {
        card.classList.add('hidden');
      }
    });
  });
});
</script>

