<style>
/* ── TERMS PAGE ── */
.terms-page { background: #fff; }

/* Hero */
.terms-hero {
  background: linear-gradient(135deg, #0B3D2E 0%, #1B5E42 60%, #2D6A4F 100%);
  padding: 100px 48px 80px; text-align: center;
  position: relative; overflow: hidden;
}
.terms-hero::before {
  content: ''; position: absolute; inset: 0;
  background: radial-gradient(ellipse at 30% 0%, rgba(82,183,136,0.15) 0%, transparent 60%);
  pointer-events: none;
}
.terms-eyebrow {
  display: inline-flex; align-items: center; gap: 7px;
  background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.18);
  color: rgba(255,255,255,0.75); font-size: 11px; font-weight: 700;
  letter-spacing: 0.14em; text-transform: uppercase;
  padding: 7px 16px; border-radius: 50px; margin-bottom: 20px;
}
.terms-hero-title {
  font-size: clamp(36px, 6vw, 64px); font-weight: 900;
  color: #fff; margin: 0 0 16px; line-height: 1.05;
}
.terms-hero-sub {
  font-size: 16px; color: rgba(255,255,255,0.6);
  max-width: 480px; margin: 0 auto 16px; line-height: 1.65;
}
.terms-hero-date {
  display: inline-block;
  font-size: 12px; color: rgba(255,255,255,0.45);
  background: rgba(255,255,255,0.07); border-radius: 50px;
  padding: 5px 14px;
}

/* Layout */
.terms-layout {
  max-width: 1200px; margin: 0 auto;
  display: grid; grid-template-columns: 240px 1fr;
  gap: 64px; padding: 72px 48px 100px;
  align-items: start;
}

/* Sidebar */
.terms-sidebar { position: sticky; top: 100px; }
.terms-toc {
  background: var(--cream, #F5F0E8);
  border-radius: 20px; padding: 28px 24px;
  border: 1px solid rgba(0,0,0,0.06);
}
.terms-toc-label {
  font-size: 10px; font-weight: 800; letter-spacing: 0.14em;
  text-transform: uppercase; color: var(--green, #52B788);
  margin-bottom: 16px;
}
.terms-toc nav { display: flex; flex-direction: column; gap: 2px; }
.terms-toc-link {
  font-size: 13px; color: #666; font-weight: 500;
  text-decoration: none; padding: 7px 10px; border-radius: 8px;
  transition: all 0.15s; line-height: 1.4;
}
.terms-toc-link:hover {
  background: rgba(82,183,136,0.1); color: var(--green-dark, #2D6A4F);
  font-weight: 600;
}
.terms-toc-cta {
  margin-top: 20px; padding-top: 20px;
  border-top: 1px solid rgba(0,0,0,0.07);
}
.terms-toc-cta p { font-size: 12px; color: #888; margin-bottom: 8px; }
.terms-toc-cta a {
  font-size: 13px; font-weight: 700;
  color: var(--green, #52B788); text-decoration: none;
}

/* Content */
.terms-intro {
  font-size: 17px; color: #444; line-height: 1.85;
  padding-bottom: 32px; margin-bottom: 40px;
  border-bottom: 2px solid var(--green-light, #D8F3DC);
}

.terms-section {
  display: grid; grid-template-columns: 48px 1fr;
  gap: 24px; margin-bottom: 48px;
  padding-bottom: 48px;
  border-bottom: 1px solid rgba(0,0,0,0.07);
}
.terms-section:last-child { border-bottom: none; margin-bottom: 0; }

.terms-section-num {
  font-size: 13px; font-weight: 900; color: var(--green, #52B788);
  letter-spacing: 0.06em; margin-top: 4px;
  opacity: 0.6;
}
.terms-section-body h2 {
  font-size: 20px; font-weight: 900; color: #111;
  margin: 0 0 14px; line-height: 1.2;
}
.terms-section-body p {
  font-size: 15px; color: #555; line-height: 1.85;
  margin-bottom: 14px;
}
.terms-section-body p:last-child { margin-bottom: 0; }
.terms-section-body a { color: var(--green, #52B788); font-weight: 600; }
.terms-section-body strong { color: #222; }

/* Callouts */
.terms-callout {
  display: flex; align-items: flex-start; gap: 12px;
  padding: 16px 18px; border-radius: 14px;
  margin: 16px 0; font-size: 14px; line-height: 1.7;
}
.terms-callout p { margin: 0; font-size: 14px; }
.terms-callout svg { flex-shrink: 0; margin-top: 2px; }
.terms-callout-warning {
  background: #FFF8ED; border: 1px solid rgba(245,166,35,0.25);
  color: #7A4D00;
}
.terms-callout-warning svg { stroke: #D97706; }
.terms-callout-green {
  background: #F0FDF4; border: 1px solid rgba(82,183,136,0.25);
  color: #1A4D2E;
}
.terms-callout-green svg { stroke: var(--green, #52B788); }

/* Subscription highlights */
.terms-highlight-row {
  display: grid; grid-template-columns: repeat(3,1fr);
  gap: 12px; margin: 16px 0;
}
.terms-highlight-item {
  display: flex; flex-direction: column; align-items: flex-start; gap: 4px;
  background: var(--cream, #F5F0E8); border-radius: 14px;
  padding: 16px; border: 1px solid rgba(0,0,0,0.06);
}
.terms-highlight-item svg { stroke: var(--green, #52B788); margin-bottom: 4px; }
.terms-highlight-item strong { font-size: 13px; color: #111; }
.terms-highlight-item span { font-size: 12px; color: #888; }

/* Contact card */
.terms-contact-card {
  display: flex; align-items: center; gap: 18px;
  background: var(--cream, #F5F0E8);
  border: 1px solid rgba(0,0,0,0.07);
  border-radius: 18px; padding: 24px 28px; margin-top: 16px;
}
.terms-contact-icon {
  width: 52px; height: 52px; border-radius: 14px;
  background: linear-gradient(135deg, #D8F3DC, #B7E4C7);
  color: var(--green-dark, #2D6A4F);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.terms-contact-label { font-size: 11px; font-weight: 700; color: #888; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 4px; }
.terms-contact-email { font-size: 16px; font-weight: 800; color: var(--green-dark, #2D6A4F); text-decoration: none; display: block; }
.terms-contact-sub { font-size: 12px; color: #888; margin-top: 4px; }

/* Mobile */
@media (max-width: 900px) {
  .terms-layout { grid-template-columns: 1fr; gap: 40px; padding: 48px 20px 72px; }
  .terms-sidebar { position: static; }
  .terms-toc nav { display: grid; grid-template-columns: 1fr 1fr; }
  .terms-hero { padding: 80px 24px 60px; }
}
@media (max-width: 600px) {
  .terms-highlight-row { grid-template-columns: 1fr; }
  .terms-toc nav { grid-template-columns: 1fr; }
  .terms-section { grid-template-columns: 1fr; gap: 8px; }
  .terms-section-num { font-size: 11px; }
}
</style>

