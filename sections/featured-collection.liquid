<section class="featured-collection">
  <div class="section-inner">
    <div class="section-header">
      <div class="section-eyebrow">The Lineup</div>
      <h2 class="section-title">Pick Your Flavor</h2>
      <p class="section-sub">Same 2,000mg functional mushroom dose in every can. Pick by flavor, not by feel.</p>
    </div>
    <div class="products-grid">
      {% assign priority_handles = 'blue-razzberry-fungi-powered-seltzer,mango-mimosa-fungi-powered-seltzer,watermelon-fungi-powered-seltzer' | split: ',' %}
      {% assign shown = '' %}
      {% comment %} Sold-out products are skipped so the grid stays one clean row {% endcomment %}
      {% for handle in priority_handles %}
        {% assign product = all_products[handle] %}
        {% if product.id != blank and product.available %}
          {% render 'product-card', product: product %}
          {% assign shown = shown | append: handle | append: ',' %}
        {% endif %}
      {% endfor %}
      {% for product in collections['all'].products %}
        {% unless shown contains product.handle %}
          {% if product.available %}
            {% render 'product-card', product: product %}
          {% endif %}
        {% endunless %}
      {% endfor %}
    </div>
    <div class="section-cta-center">
      <a href="/collections/all" class="btn-primary">View All Products →</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "settings": []
}
{% endschema %}
