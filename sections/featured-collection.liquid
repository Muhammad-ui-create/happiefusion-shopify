<section class="featured-collection">
  <div class="section-inner">
    <div class="section-header">
      <div class="section-eyebrow">The Lineup</div>
      <h2 class="section-title">Pick Your Flavor</h2>
      <p class="section-sub">Same 2,000mg functional mushroom dose in every can. Pick by flavor, not by feel.</p>
    </div>
    <div class="products-grid">
      {% comment %} Show singles first in order, then variety pack last {% endcomment %}
      {% assign priority_handles = 'blue-razzberry,mango-mimosa,watermelon' | split: ',' %}
      {% for handle in priority_handles %}
        {% assign product = all_products[handle] %}
        {% if product.id %}
          {% render 'product-card', product: product %}
        {% endif %}
      {% endfor %}
      {% comment %} Show remaining products (variety pack etc) {% endcomment %}
      {% for product in collections['all'].products %}
        {% unless priority_handles contains product.handle %}
          {% render 'product-card', product: product %}
        {% endunless %}
      {% endfor %}
    </div>
    <div class="section-cta-center">
      <a href="/collections/all" class="btn-primary">View All Products →</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "settings": []
}
{% endschema %}
