    function findLocalAnswer(query) {
      for (var i = 0; i < KNOWLEDGE.length; i++) {
        if (KNOWLEDGE[i].match.test(query)) return KNOWLEDGE[i].reply;
      }
      return null;
    }

    var openBtn = document.getElementById('happie-chat-open');
    var closeBtn = document.getElementById('happie-chat-close');
    var panel = document.getElementById('happie-chat-panel');
    var messagesEl = document.getElementById('happie-chat-messages');
    var form = document.getElementById('happie-chat-form');
    var input = document.getElementById('happie-chat-input');
    var sendBtn = form.querySelector('.happie-chat__send');
    var suggestionsEl = document.getElementById('happie-chat-suggestions');
    var suggestionBtns = suggestionsEl.querySelectorAll('.happie-chat__suggestion');
    var handoffPanel = document.getElementById('happie-chat-handoff');
    var handoffBackBtn = document.getElementById('happie-chat-handoff-back');

    var conversation = [];
    var sessionStarted = false;

    function escapeHtml(str) {
      var div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    function renderMarkdown(text) {
      var html = escapeHtml(text);
      // Bold
      html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
      // Links [text](url)
      html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>');
      // Bullets
      var lines = html.split('\n');
      var inList = false;
      var out = [];
      lines.forEach(function(line) {
        if (/^[\-\*]\s+/.test(line)) {
          if (!inList) { out.push('<ul>'); inList = true; }
          out.push('<li>' + line.replace(/^[\-\*]\s+/, '') + '</li>');
        } else {
          if (inList) { out.push('</ul>'); inList = false; }
          out.push(line);
        }
      });
      if (inList) out.push('</ul>');
      return out.join('<br>').replace(/<br><(ul|\/ul|li)/g, '<$1');
    }

    function addMessage(text, role) {
      var msg = document.createElement('div');
      msg.className = 'happie-chat__msg happie-chat__msg--' + role;
      msg.innerHTML = role === 'bot' ? renderMarkdown(text) : escapeHtml(text);
      messagesEl.appendChild(msg);
      messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    function showTyping() {
      var typing = document.createElement('div');
      typing.className = 'happie-chat__typing';
      typing.id = 'happie-chat-typing';
      typing.innerHTML = '<span></span><span></span><span></span>';
      messagesEl.appendChild(typing);
      messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    function hideTyping() {
      var t = document.getElementById('happie-chat-typing');
      if (t) t.remove();
    }

    function openChat() {
      panel.classList.add('is-open');
      panel.setAttribute('aria-hidden', 'false');
      if (!sessionStarted) {
        addMessage(greeting, 'bot');
        sessionStarted = true;
      }
      setTimeout(function() { input.focus(); }, 300);
    }

    function closeChat() {
      panel.classList.remove('is-open');
      panel.setAttribute('aria-hidden', 'true');
      handoffPanel.hidden = true;
    }

    function showHandoff() {
      handoffPanel.hidden = false;
    }

    function hideHandoff() {
      handoffPanel.hidden = true;
    }

    async function sendMessage(text) {
      if (!text || !text.trim()) return;
      addMessage(text, 'user');
      conversation.push({ role: 'user', content: text });
      suggestionsEl.classList.add('is-hidden');
      input.value = '';
      sendBtn.disabled = true;
      showTyping();

      // Trigger human handoff if user explicitly asks
      var humanKeywords = /talk to (a |)human|speak to (a |)human|customer service|real person|live agent|escalate|email (you|us|support)/i;
      if (humanKeywords.test(text)) {
        hideTyping();
        addMessage("Got it! I'll connect you with our team. Please fill out this quick form below and we'll respond within 24 hours.", 'bot');
        conversation.push({ role: 'assistant', content: "Showing human handoff form." });
        sendBtn.disabled = false;
        setTimeout(showHandoff, 600);
        return;
      }

      // ── LOCAL KNOWLEDGE BASE — answer common questions instantly ──
      var localAnswer = findLocalAnswer(text);
      if (localAnswer) {
        // Brief typing delay for natural feel
        setTimeout(function() {
          hideTyping();
          addMessage(localAnswer, 'bot');
          conversation.push({ role: 'assistant', content: localAnswer });
          sendBtn.disabled = false;
        }, 600);
        return;
      }

      // Fall through to backend AI for anything we don't have a canned answer for
      if (!workerUrl) {
        hideTyping();
        addMessage("I'm not sure about that one yet. Email us at **" + supportEmail + "** or click 'Talk to a human' below and we'll help you out!", 'bot');
        sendBtn.disabled = false;
        return;
      }

      try {
        var resp = await fetch(workerUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ messages: conversation, page: window.location.pathname })
        });
        var data = await resp.json();
        hideTyping();
        if (data.reply) {
          addMessage(data.reply, 'bot');
          conversation.push({ role: 'assistant', content: data.reply });
          // If the bot suggests escalation, show handoff
          if (/contact (our team|support|us)|email (us|our team)|fill out (the |)form/i.test(data.reply)) {
            setTimeout(showHandoff, 800);
          }
        } else {
          addMessage("Sorry, I had trouble responding. Try again or email us at " + supportEmail, 'bot');
        }
      } catch (err) {
        hideTyping();
        addMessage("Connection hiccup. Try again, or email us at " + supportEmail, 'bot');
        console.error('Chatbot error:', err);
      }
      sendBtn.disabled = false;
    }

    openBtn.addEventListener('click', openChat);
    closeBtn.addEventListener('click', closeChat);
    handoffBackBtn.addEventListener('click', hideHandoff);

    form.addEventListener('submit', function(e) {
      e.preventDefault();
      sendMessage(input.value);
    });

    suggestionBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        sendMessage(btn.dataset.suggest);
      });
    });

    // Persist conversation in sessionStorage so it survives page navigation
    try {
      var saved = sessionStorage.getItem('happie-chat-convo');
      if (saved) {
        var parsed = JSON.parse(saved);
        if (Array.isArray(parsed) && parsed.length > 0) {
          conversation = parsed;
          parsed.forEach(function(m) {
            if (m.role === 'user' || m.role === 'assistant') {
              addMessage(m.content, m.role === 'user' ? 'user' : 'bot');
            }
          });
          sessionStarted = true;
          suggestionsEl.classList.add('is-hidden');
        }
      }
    } catch(e) {}

    // Save conversation on each update
    var origPush = conversation.push;
    conversation.push = function() {
      var r = origPush.apply(this, arguments);
      try { sessionStorage.setItem('happie-chat-convo', JSON.stringify(conversation)); } catch(e) {}
      return r;
    };
  })();
</script>
{%- endif -%}

