<section class="cta-banner-wrap">
  <div class="cta-banner">
    <div class="wave-field cta-waves" aria-hidden="true">
      <span class="wave wave--back"></span>
      <span class="wave wave--mid"></span>
      <span class="wave wave--front"></span>
    </div>
    <div class="cta-banner-inner">
      <div class="cta-text">
        <h2>Ready to make the swap?</h2>
        <p>Caffeine-free, all-natural, zero alcohol — something good to hold at work, at the gym, or instead of a beer.</p>
      </div>
      <div class="cta-actions">
        <a href="/collections/all" class="btn-primary btn-lg">Shop Now — Starting at $23.99 →</a>
        <p class="cta-sub">Subscribe &amp; save 15% · Free shipping, no minimum · Cancel anytime</p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CTA Banner",
  "settings": []
}
{% endschema %}
