<div class="inner-page">

  <div style="background:linear-gradient(135deg,#f5f0e8 0%,#d8f3dc 100%);padding:72px 48px;">
    <div style="max-width:1000px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;">
      <div>
        <div style="font-size:11px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#2D6A4F;margin-bottom:10px;">My Account</div>
        <h1 style="font-size:clamp(28px,4vw,42px);font-weight:900;line-height:1.1;margin:0;">
          Hey, {{ customer.first_name | default: customer.email }} 👋
        </h1>
      </div>
      <a href="/account/logout"
        style="background:#fff;color:#2D6A4F;border:2px solid #2D6A4F;border-radius:50px;padding:11px 24px;font-size:14px;font-weight:700;white-space:nowrap;">
        Sign Out
      </a>
    </div>
  </div>

  <section style="padding:56px 24px 96px;background:#fff;">
    <div style="max-width:1000px;margin:0 auto;display:grid;grid-template-columns:240px 1fr;gap:48px;align-items:start;">

      <!-- Sidebar -->
      <div style="background:var(--cream);border-radius:20px;padding:24px;position:sticky;top:100px;">
        <div style="font-size:12px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#999;margin-bottom:16px;">Menu</div>
        <nav style="display:flex;flex-direction:column;gap:4px;">
          <a href="/account" style="display:flex;align-items:center;gap:10px;padding:11px 14px;border-radius:10px;font-size:14px;font-weight:700;color:#1B4332;background:var(--green-light);">📦 Orders</a>
          <a href="/account/addresses" style="display:flex;align-items:center;gap:10px;padding:11px 14px;border-radius:10px;font-size:14px;font-weight:600;color:#444;">📍 Addresses</a>
          <a href="/collections/all" style="display:flex;align-items:center;gap:10px;padding:11px 14px;border-radius:10px;font-size:14px;font-weight:600;color:#444;">🛍️ Shop Again</a>
          <a href="/pages/contact" style="display:flex;align-items:center;gap:10px;padding:11px 14px;border-radius:10px;font-size:14px;font-weight:600;color:#444;">💬 Contact Support</a>
        </nav>
        <div style="margin-top:20px;padding-top:20px;border-top:1px solid rgba(0,0,0,0.08);">
          <div style="font-size:13px;color:#666;line-height:1.5;">
            <strong style="color:#333;">{{ customer.first_name }} {{ customer.last_name }}</strong><br>
            {{ customer.email }}
          </div>
        </div>
      </div>

      <!-- Main content: Orders -->
      <div>
        <h2 style="font-size:22px;font-weight:900;margin:0 0 24px;">Order History</h2>

        {% if customer.orders.size == 0 %}
          <div style="text-align:center;padding:64px 24px;background:var(--cream);border-radius:20px;">
            <div style="font-size:48px;margin-bottom:16px;">🛒</div>
            <h3 style="font-size:20px;font-weight:800;margin-bottom:10px;">No orders yet</h3>
            <p style="color:#666;font-size:15px;margin-bottom:28px;">Your order history will show up here once you place your first order.</p>
            <a href="/collections/all"
              style="background:#2D6A4F;color:#fff;border-radius:50px;padding:14px 32px;font-size:15px;font-weight:700;display:inline-block;">
              Shop Now →
            </a>
          </div>

        {% else %}
          <div style="display:flex;flex-direction:column;gap:16px;">
            {% for order in customer.orders %}
              <div style="border:2px solid rgba(0,0,0,0.08);border-radius:16px;padding:24px;transition:border-color 0.15s;"
                onmouseover="this.style.borderColor='#2D6A4F'" onmouseout="this.style.borderColor='rgba(0,0,0,0.08)'">
                <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:16px;">
                  <div>
                    <div style="font-size:16px;font-weight:800;color:#1B4332;margin-bottom:4px;">
                      Order {{ order.name }}
                    </div>
                    <div style="font-size:13px;color:#888;">{{ order.created_at | date: "%B %d, %Y" }}</div>
                  </div>
                  <div style="display:flex;align-items:center;gap:12px;">
                    <span style="font-size:13px;font-weight:700;padding:5px 12px;border-radius:50px;
                      {% if order.financial_status == 'paid' %}background:#d8f3dc;color:#1B4332;
                      {% elsif order.financial_status == 'pending' %}background:#fff3cd;color:#856404;
                      {% else %}background:#f8d7da;color:#721c24;{% endif %}">
                      {{ order.financial_status | capitalize }}
                    </span>
                    <span style="font-size:13px;font-weight:700;padding:5px 12px;border-radius:50px;background:var(--cream);color:#444;">
                      {{ order.fulfillment_status | default: 'Processing' | capitalize }}
                    </span>
                  </div>
                </div>

                <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:16px;">
                  {% for line_item in order.line_items %}
                    <div style="display:flex;align-items:center;gap:12px;font-size:14px;">
                      {% if line_item.image %}
                        <img src="{{ line_item.image | image_url: width: 56 }}" style="width:44px;height:44px;object-fit:cover;border-radius:8px;" />
                      {% else %}
                        <div style="width:44px;height:44px;background:var(--cream);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:18px;">🍄</div>
                      {% endif %}
                      <div style="flex:1;">
                        <div style="font-weight:600;color:#333;">{{ line_item.title }}</div>
                        {% if line_item.variant_title and line_item.variant_title != 'Default Title' %}
                          <div style="font-size:12px;color:#888;">{{ line_item.variant_title }}</div>
                        {% endif %}
                      </div>
                      <div style="font-weight:700;color:#333;">× {{ line_item.quantity }}</div>
                      <div style="font-weight:700;color:#2D6A4F;min-width:70px;text-align:right;">{{ line_item.final_line_price | money }}</div>
                    </div>
                  {% endfor %}
                </div>

                <div style="display:flex;align-items:center;justify-content:space-between;border-top:1px solid rgba(0,0,0,0.07);padding-top:14px;">
                  <div style="font-size:15px;font-weight:800;">Total: {{ order.total_price | money }}</div>
                  <a href="{{ order.customer_url }}"
                    style="font-size:13px;font-weight:700;color:#2D6A4F;border:2px solid #2D6A4F;border-radius:50px;padding:8px 18px;">
                    View Details →
                  </a>
                </div>
              </div>
            {% endfor %}
          </div>
        {% endif %}
      </div>

    </div>
  </section>

</div>

{% schema %}
{ "name": "Customer Account", "settings": [] }
{% endschema %}
