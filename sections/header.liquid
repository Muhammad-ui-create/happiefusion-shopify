<nav class="nav" id="site-nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo-link">
      <img src="{{ 'happie-logo.png' | asset_url }}" alt="{{ shop.name }}" class="nav-logo-img" />
    </a>
    <ul class="nav-links">
      <li><a href="/collections/all">Shop</a></li>
      <li><a href="/pages/mushrooms">Mushrooms</a></li>
      <li><a href="/pages/the-science">The Science</a></li>
      <li><a href="/pages/reviews">Reviews</a></li>
      <li><a href="/pages/about">About</a></li>
    </ul>
    <div class="nav-right">
      {% if customer %}
        <a href="/account" class="nav-signin">{{ customer.first_name | default: 'Account' }}</a>
      {% else %}
        <a href="/account/login" class="nav-signin">Sign in</a>
      {% endif %}
      <button class="cart-trigger" id="cart-trigger" aria-label="Open cart">
        Cart · <span class="cart-count-badge">{{ cart.item_count }}</span>
      </button>
    </div>
    <button class="hamburger" id="hamburger" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
  <div class="mobile-nav" id="mobile-nav">
    <ul>
      <li><a href="/collections/all">Shop</a></li>
      <li><a href="/pages/mushrooms">Mushrooms</a></li>
      <li><a href="/pages/the-science">The Science</a></li>
      <li><a href="/pages/reviews">Reviews</a></li>
      <li><a href="/pages/about">About</a></li>
      <li><a href="/cart">Cart ({{ cart.item_count }})</a></li>
      {% if customer %}
        <li><a href="/account">My Account ({{ customer.first_name }})</a></li>
        <li><a href="/account/logout">Sign Out</a></li>
      {% else %}
        <li><a href="/account/login">Sign In</a></li>
        <li><a href="/account/register">Create Account</a></li>
      {% endif %}
    </ul>
  </div>
</nav>

{% schema %}
{
  "name": "Header",
  "settings": []
}
{% endschema %}
