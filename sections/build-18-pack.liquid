{% comment %}
  Build Your Own pack — custom bundle builder with two sizes:
  18-Pack = 3 six-packs ($43.99, compare $71.97) · 24-Pack = 4 six-packs ($57.99, compare $95.96).
  Assign template "product.build-18" to the Build Your Own product.
  Flavors are picked as whole 6-packs; the hard cap tracks the selected size so the
  can count can never exceed the box. The mix is stored as line item properties on
  the selected size variant, so it rides cart -> checkout -> order for fulfillment.
{% endcomment %}

{%- assign v18 = blank -%}
{%- assign v24 = blank -%}
{%- for v in product.variants -%}
  {%- if v.title contains '24' -%}{%- assign v24 = v -%}{%- else -%}{%- assign v18 = v -%}{%- endif -%}
{%- endfor -%}
{%- assign p_blue  = all_products['blue-razzberry-fungi-powered-seltzer'] -%}
{%- assign p_mango = all_products['mango-mimosa-fungi-powered-seltzer'] -%}
{%- assign p_water = all_products['watermelon-fungi-powered-seltzer'] -%}

<div class="byo-page">
  <div class="byo-inner">

    <div class="byo-head">
      <div class="byo-eyebrow">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/></svg>
        Custom Pack Builder
      </div>
      <h1 class="byo-title">{{ product.title }}</h1>

      <div class="byo-rating-row">
        <a href="/pages/reviews" class="byo-rating" aria-label="Read customer reviews">
          <span class="byo-rating-stars" aria-hidden="true">★★★★★</span>
          <strong>4.9</strong>
          <span class="byo-rating-count">· Amazon-verified reviews</span>
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
        </a>
        <span class="byo-topseller">TOP SELLER</span>
      </div>

      <p class="byo-sub">Pick your box size, then fill it with any mix of our three flavors in 6-packs.</p>

      <!-- Size switcher -->
      <div class="byo-sizes" role="radiogroup" aria-label="Pack size">
        <button type="button" class="byo-size is-active" data-size="18" aria-pressed="true">
          <span class="byo-size-cans">18 Cans</span>
          <span class="byo-size-packs">3 six-packs</span>
          <span class="byo-size-price">{{ v18.price | money }} <s>{{ v18.compare_at_price | money }}</s></span>
        </button>
        <button type="button" class="byo-size" data-size="24" aria-pressed="false">
          <span class="byo-size-cans">24 Cans</span>
          <span class="byo-size-packs">4 six-packs</span>
          <span class="byo-size-price">{{ v24.price | money }} <s>{{ v24.compare_at_price | money }}</s></span>
          <span class="byo-size-flag">BEST RATE</span>
        </button>
      </div>

      <div class="byo-price-card">
        <div class="byo-price-row">
          <span class="byo-price" id="byo-price">{{ v18.price | money }}</span>
          <span class="byo-compare" id="byo-compare">{{ v18.compare_at_price | money }}</span>
          <span class="byo-save" id="byo-save">SAVE $27.98</span>
        </div>
        <div class="byo-price-meta">
          <span id="byo-percan">$2.72 per can</span>
          <span class="byo-price-dot">·</span>
          <span id="byo-pct">32% off vs three 6-packs</span>
          <span class="byo-price-dot">·</span>
          <span>Free shipping</span>
        </div>
      </div>
    </div>

    <!-- Progress: pack slots (4th slot only in 24-can mode) -->
    <div class="byo-progress-wrap" aria-live="polite">
      <div class="byo-progress-label">
        <span class="byo-progress-count"><strong id="byo-count">0</strong>&nbsp;/ <span id="byo-target">3</span> six-packs <em id="byo-cans">(18 cans)</em></span>
        <span id="byo-progress-hint">Pick your 6-packs below</span>
      </div>
      <div class="byo-progress-bar" id="byo-progress-bar">
        <div class="byo-seg" data-seg></div>
        <div class="byo-seg" data-seg></div>
        <div class="byo-seg" data-seg></div>
        <div class="byo-seg byo-seg-hidden" data-seg></div>
      </div>
    </div>

    <!-- Quick presets (rebuilt by JS per size) -->
    <div class="byo-presets" id="byo-presets"></div>

    <!-- Flavor cards -->
    <div class="byo-grid">

      <div class="byo-card byo-card-blue" data-flavor="Blue Razzberry">
        <div class="byo-card-accent" aria-hidden="true"></div>
        <div class="byo-card-img">
          {%- if p_blue.featured_image -%}
            <img src="{{ p_blue.featured_image | image_url: width: 400 }}" alt="Blue Razzberry 6-pack" width="200" height="200" loading="lazy" />
          {%- endif -%}
        </div>
        <div class="byo-card-name">Blue Razzberry</div>
        <div class="byo-card-note">Tart &amp; candy-bright</div>
        <div class="byo-card-unit">6-pack · 6 cans</div>
        <div class="byo-stepper">
          <button type="button" class="byo-btn byo-minus" aria-label="Remove one Blue Razzberry 6-pack">−</button>
          <span class="byo-qty" data-count>0</span>
          <button type="button" class="byo-btn byo-plus" aria-label="Add one Blue Razzberry 6-pack">+</button>
        </div>
      </div>

      <div class="byo-card byo-card-mango" data-flavor="Mango Mimosa">
        <div class="byo-card-accent" aria-hidden="true"></div>
        <div class="byo-card-img">
          {%- if p_mango.featured_image -%}
            <img src="{{ p_mango.featured_image | image_url: width: 400 }}" alt="Mango Mimosa 6-pack" width="200" height="200" loading="lazy" />
          {%- endif -%}
        </div>
        <div class="byo-card-name">Mango Mimosa</div>
        <div class="byo-card-note">Tropical &amp; lightly sweet</div>
        <div class="byo-card-unit">6-pack · 6 cans</div>
        <div class="byo-stepper">
          <button type="button" class="byo-btn byo-minus" aria-label="Remove one Mango Mimosa 6-pack">−</button>
          <span class="byo-qty" data-count>0</span>
          <button type="button" class="byo-btn byo-plus" aria-label="Add one Mango Mimosa 6-pack">+</button>
        </div>
      </div>

      <div class="byo-card byo-card-water" data-flavor="Watermelon">
        <div class="byo-card-accent" aria-hidden="true"></div>
        <div class="byo-card-img">
          {%- if p_water.featured_image -%}
            <img src="{{ p_water.featured_image | image_url: width: 400 }}" alt="Watermelon 6-pack" width="200" height="200" loading="lazy" />
          {%- endif -%}
        </div>
        <div class="byo-card-name">Watermelon</div>
        <div class="byo-card-note">Crisp, clean &amp; juicy</div>
        <div class="byo-card-unit">6-pack · 6 cans</div>
        <div class="byo-stepper">
          <button type="button" class="byo-btn byo-minus" aria-label="Remove one Watermelon 6-pack">−</button>
          <span class="byo-qty" data-count>0</span>
          <button type="button" class="byo-btn byo-plus" aria-label="Add one Watermelon 6-pack">+</button>
        </div>
      </div>

    </div>

    <!-- Low-stock urgency -->
    {%- assign _day = 'now' | date: '%j' | plus: 0 -%}
    {%- assign _shown = product.id | modulo: 97 | plus: _day | modulo: 9 | plus: 7 -%}
    <div class="low-stock-badge byo-low-stock">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
      </svg>
      <span>Low stock — only <strong>{{ _shown }}</strong> custom packs left today. Order soon</span>
    </div>

    <!-- Social proof strip — real numbers only -->
    <div class="pdp-proof-row byo-proof-row" aria-label="Customer proof">
      <span class="pdp-proof-item"><span class="pdp-proof-star">★</span> <strong>4.9</strong> from 1,200+ verified Amazon reviews</span>
      <span class="pdp-proof-dot" aria-hidden="true">·</span>
      <span class="pdp-proof-item">Thousands of cans shipped nationwide 🇺🇸</span>
    </div>

    <!-- ATC -->
    <button type="button" class="byo-atc" id="byo-atc" disabled>
      <span id="byo-atc-text">PICK 3 SIX-PACKS TO CONTINUE</span>
    </button>
    <p class="byo-atc-note">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="vertical-align:-2px;margin-right:4px;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
      Every can: 900mg Lion's Mane · 700mg Cordyceps · 400mg Reishi · Zero alcohol · Zero caffeine
    </p>

    <!-- Trust pills -->
    <div class="byo-pills">
      <span class="byo-pill">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="6" width="15" height="11" rx="2"/><path d="M16 10h4l3 3v4h-7"/><circle cx="5.5" cy="19.5" r="1.5"/><circle cx="20.5" cy="19.5" r="1.5"/></svg>
        Free Shipping — No Minimum
      </span>
      <span class="byo-pill">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-12V5l-8-3-8 3v5c0 8 8 12 8 12z"/><path d="M9 12l2 2 4-4"/></svg>
        30-Day Full Refund
      </span>
      <span class="byo-pill">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3h6l1 4H8L9 3z"/><path d="M8 7v10a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V7"/><path d="M12 11v3M11 13h2"/></svg>
        3rd-Party Lab Tested
      </span>
    </div>

    {% comment %} Product description rendered as a designed feature grid —
       the raw description stays on the product for SEO/channels. {% endcomment %}
    <div class="byo-features">
      <h2 class="byo-features-title">Your flavors. Your ratios. <em>One box.</em></h2>
      <div class="byo-features-grid">

        <div class="byo-feature">
          <span class="byo-feature-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22V12"/><path d="M12 12C12 12 7 10 6 6c3 0 6 2 6 6z"/><path d="M12 12c0 0 5-2 6-6-3 0-6 2-6 6z"/></svg>
          </span>
          <strong>Dual-Extracted Trio</strong>
          <p>Lion's Mane, Cordyceps &amp; Reishi in every can — fruiting body only, never mycelium on grain.</p>
        </div>

        <div class="byo-feature">
          <span class="byo-feature-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          </span>
          <strong>2,000mg Per Can</strong>
          <p>Real functional doses — zero caffeine, zero alcohol, 40 calories. No crash, no jitters.</p>
        </div>

        <div class="byo-feature">
          <span class="byo-feature-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
          </span>
          <strong>18 or 24 Cans, Your Way</strong>
          <p>Any mix of three flavors — and our best per-can prices, from $2.54 a can on the 24-pack.</p>
        </div>

        <div class="byo-feature">
          <span class="byo-feature-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3h6l1 4H8L9 3z"/><path d="M8 7v10a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V7"/><path d="M12 11v3M11 13h2"/></svg>
          </span>
          <strong>Lab Tested, Every Batch</strong>
          <p>Third-party verified for heavy metals, pesticides, and microbials. COA available for every batch.</p>
        </div>

      </div>
    </div>

    <!-- ── FAQ — builder-specific questions ── -->
    <section class="pdp-faq byo-faq" aria-labelledby="byo-faq-title">
      <div class="pdp-faq-inner">
        <div class="pdp-faq-head">
          <span class="pdp-faq-eyebrow">Custom Pack Questions</span>
          <h2 class="pdp-faq-title" id="byo-faq-title">Everything about building your box.</h2>
        </div>
        <div class="pdp-faq-grid">

          <details class="pdp-faq-item" open>
            <summary class="pdp-faq-q">
              <span class="pdp-faq-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg></span>
              <span>How does the custom pack work?</span>
              <span class="pdp-faq-chev"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg></span>
            </summary>
            <div class="pdp-faq-a">
              <p><strong>Pick your box size, then fill it with 6-packs.</strong> The 18-pack holds three 6-packs ($48.99); the 24-pack holds four ($60.99). All one flavor, one of each, or any combo — one price, one box, and your exact mix is printed on your order confirmation so you know exactly what's coming.</p>
            </div>
          </details>

          <details class="pdp-faq-item">
            <summary class="pdp-faq-q">
              <span class="pdp-faq-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></span>
              <span>Can I change my mix after ordering?</span>
              <span class="pdp-faq-chev"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg></span>
            </summary>
            <div class="pdp-faq-a">
              <p><strong>Yes — before it ships.</strong> We process orders within 1 business day, so email <a href="mailto:orders@drinkhappie.com">orders@drinkhappie.com</a> with your order number ASAP and we'll swap your flavors before the box leaves the warehouse.</p>
            </div>
          </details>

          <details class="pdp-faq-item">
            <summary class="pdp-faq-q">
              <span class="pdp-faq-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></span>
              <span>What if I don't like one of my flavors?</span>
              <span class="pdp-faq-chev"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg></span>
            </summary>
            <div class="pdp-faq-a">
              <p><strong>30-day full refund, no return needed.</strong> If any part of your pack isn't for you, email <a href="mailto:orders@drinkhappie.com">orders@drinkhappie.com</a> within 30 days of delivery and we'll refund your order in full. You keep the cans.</p>
            </div>
          </details>

          <details class="pdp-faq-item">
            <summary class="pdp-faq-q">
              <span class="pdp-faq-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="6" width="15" height="11" rx="2"/><path d="M16 10h4l3 3v4h-7"/><circle cx="5.5" cy="19.5" r="1.5"/><circle cx="20.5" cy="19.5" r="1.5"/></svg></span>
              <span>How fast does it ship?</span>
              <span class="pdp-faq-chev"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg></span>
            </summary>
            <div class="pdp-faq-a">
              <p><strong>Ships within 1 business day, free.</strong> Standard delivery is 3–5 business days from our Northern California warehouse to all 50 states. Need it faster? Express 2-day is $15 at checkout.</p>
            </div>
          </details>

          <details class="pdp-faq-item">
            <summary class="pdp-faq-q">
              <span class="pdp-faq-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></span>
              <span>Is this cheaper than buying 6-packs separately?</span>
              <span class="pdp-faq-chev"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg></span>
            </summary>
            <div class="pdp-faq-a">
              <p><strong>Yes — by a lot.</strong> Three 6-packs bought separately cost $71.97; the 18-pack is $48.99 (save $22.98, 32% off). Four 6-packs cost $95.96; the 24-pack is $60.99 (save $34.97, 36% off) — the best per-can price we offer at $2.54.</p>
            </div>
          </details>

          <details class="pdp-faq-item">
            <summary class="pdp-faq-q">
              <span class="pdp-faq-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 2.1l4 4-4 4"/><path d="M3 12.2v-2a4 4 0 0 1 4-4h12.8"/><path d="M7 21.9l-4-4 4-4"/><path d="M21 11.8v2a4 4 0 0 1-4 4H4.2"/></svg></span>
              <span>Can I subscribe to a custom pack?</span>
              <span class="pdp-faq-chev"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg></span>
            </summary>
            <div class="pdp-faq-a">
              <p><strong>Not yet — the custom packs are one-time purchase for now.</strong> If you want recurring delivery with 20% off, each of our individual 6-packs offers Subscribe &amp; Save. Custom pack subscriptions are on our roadmap.</p>
            </div>
          </details>

        </div>
      </div>
    </section>

  </div>
</div>

<style>
  .byo-page {
    padding: 48px 16px 80px;
    background:
      radial-gradient(ellipse 60% 40% at 15% 0%, rgba(82,183,136,0.10), transparent 65%),
      radial-gradient(ellipse 60% 40% at 85% 10%, rgba(245,166,35,0.10), transparent 65%);
  }
  .byo-inner { max-width: 880px; margin: 0 auto; }

  /* ── Header ── */
  .byo-head { text-align: center; margin-bottom: 30px; }
  .byo-eyebrow {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 11px; font-weight: 800; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--green, #2D6A4F);
    background: rgba(45,106,79,0.09); border: 1px solid rgba(45,106,79,0.15);
    border-radius: 50px; padding: 7px 16px; margin-bottom: 16px;
  }
  .byo-title { font-size: clamp(32px, 5vw, 52px); font-weight: 900; line-height: 1.04; letter-spacing: -0.02em; margin-bottom: 12px; }

  /* Rating strip + TOP SELLER badge row under the title */
  .byo-rating-row { display: inline-flex; align-items: center; gap: 10px; flex-wrap: wrap; justify-content: center; margin-bottom: 14px; }
  .byo-topseller {
    background: var(--teal, #50B2BD); color: #fff;
    border-radius: 50px; padding: 7px 15px;
    font-size: 11px; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase;
    line-height: 1;
  }
  .byo-rating {
    display: inline-flex; align-items: center; gap: 7px;
    background: rgba(245,166,35,0.10);
    border: 1px solid rgba(245,166,35,0.30);
    padding: 8px 16px; border-radius: 50px;
    font-size: 13px; line-height: 1; color: #1A1A1A;
    text-decoration: none; white-space: nowrap;
    transition: background .2s, transform .15s, border-color .2s;
  }
  .byo-rating:hover { background: rgba(245,166,35,0.18); border-color: rgba(245,166,35,0.55); transform: translateY(-1px); }
  .byo-rating > * { line-height: 1; }
  .byo-rating-stars { color: #F5A623; font-size: 12px; letter-spacing: 3px; }
  .byo-rating strong { font-weight: 900; font-size: 13.5px; }
  .byo-rating-count { color: var(--gray, #5A6B5E); font-weight: 600; }
  .byo-rating svg { color: var(--green, #2D6A4F); flex-shrink: 0; }

  .byo-sub { font-size: 16px; color: var(--gray, #5A6B5E); margin-bottom: 20px; max-width: 560px; margin-left: auto; margin-right: auto; }

  /* ── Size switcher — its own centered row, equal-height cards ── */
  .byo-sizes {
    display: flex; align-items: stretch; gap: 12px; margin: 0 auto 20px;
    flex-wrap: wrap; justify-content: center;
  }
  .byo-size {
    position: relative;
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 3px;
    min-width: 170px;
    background: #fff; border: 2px solid rgba(0,0,0,0.08); border-radius: 18px;
    padding: 14px 26px 12px; cursor: pointer;
    font-family: inherit;
    box-shadow: 0 3px 12px rgba(27,42,31,0.05);
    transition: border-color .2s, box-shadow .2s, transform .15s;
  }
  .byo-size:hover { transform: translateY(-1px); box-shadow: 0 8px 20px rgba(27,42,31,0.09); }
  .byo-size.is-active {
    border-color: var(--green, #2D6A4F);
    background: rgba(45,106,79,0.05);
    box-shadow: 0 8px 24px rgba(45,106,79,0.14);
  }
  .byo-size-cans { font-size: 17px; font-weight: 900; letter-spacing: -0.01em; }
  .byo-size-packs { font-size: 11px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--gray, #5A6B5E); }
  .byo-size-price { font-size: 13px; font-weight: 800; color: var(--green, #2D6A4F); }
  .byo-size-price s { color: #9aa39c; font-weight: 600; font-size: 11.5px; margin-left: 3px; }
  .byo-size-flag {
    position: absolute; top: -9px; right: -8px;
    background: linear-gradient(135deg, #E84C6B, #C03060); color: #fff;
    font-size: 9px; font-weight: 900; letter-spacing: 0.08em;
    padding: 4px 9px; border-radius: 50px;
    box-shadow: 0 3px 8px rgba(232,76,107,0.35);
  }

  .byo-price-card {
    display: inline-block;
    background: #fff;
    border: 1px solid rgba(45,106,79,0.14);
    border-radius: 20px;
    padding: 18px 30px 15px;
    box-shadow: 0 10px 32px rgba(27,42,31,0.08);
  }
  .byo-price-row { display: flex; align-items: baseline; justify-content: center; gap: 12px; flex-wrap: wrap; }
  .byo-price { font-size: 42px; font-weight: 900; color: var(--green, #2D6A4F); letter-spacing: -0.02em; line-height: 1; }
  .byo-compare { font-size: 20px; font-weight: 600; color: #9aa39c; text-decoration: line-through; text-decoration-thickness: 2px; }
  .byo-save {
    background: linear-gradient(135deg, #E84C6B, #C03060); color: #fff;
    font-size: 12px; font-weight: 900; letter-spacing: 0.06em;
    padding: 6px 13px; border-radius: 50px;
    box-shadow: 0 4px 12px rgba(232,76,107,0.30);
  }
  .byo-price-meta {
    display: flex; justify-content: center; gap: 8px; flex-wrap: wrap;
    margin-top: 9px; font-size: 12.5px; font-weight: 600; color: var(--gray, #5A6B5E);
  }
  .byo-price-dot { opacity: 0.4; }

  /* ── Progress: pack slots ── */
  .byo-progress-wrap { margin: 30px 0 18px; }
  .byo-progress-label {
    display: flex; justify-content: space-between; align-items: baseline;
    font-size: 13px; margin-bottom: 9px; color: var(--gray, #5A6B5E);
  }
  .byo-progress-count strong { color: #1A1A1A; font-size: 17px; }
  .byo-progress-count em { font-style: normal; opacity: 0.75; }
  #byo-progress-hint { font-weight: 600; }
  .byo-progress-bar { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
  .byo-progress-bar.is-24 { grid-template-columns: repeat(4, 1fr); }
  .byo-seg {
    height: 12px; border-radius: 50px;
    background: rgba(45,106,79,0.10);
    border: 1px solid rgba(45,106,79,0.10);
    transition: background 0.3s ease, box-shadow 0.3s ease;
  }
  .byo-seg-hidden { display: none; }
  .byo-progress-bar.is-24 .byo-seg-hidden { display: block; }
  .byo-seg.filled {
    background: linear-gradient(90deg, var(--green-mid, #52B788), var(--green, #2D6A4F));
    box-shadow: 0 3px 10px rgba(45,106,79,0.30);
    border-color: transparent;
  }

  /* ── Presets ── */
  .byo-presets { display: flex; gap: 9px; flex-wrap: wrap; justify-content: center; margin-bottom: 26px; }
  .byo-preset {
    display: inline-flex; align-items: center; gap: 8px;
    background: #fff; border: 1.5px solid rgba(45,106,79,0.20); color: #1A1A1A;
    border-radius: 50px; padding: 9px 17px; font-size: 12.5px; font-weight: 700; cursor: pointer;
    font-family: inherit;
    box-shadow: 0 2px 8px rgba(27,42,31,0.05);
    transition: all .18s;
  }
  .byo-preset:hover { border-color: var(--green, #2D6A4F); transform: translateY(-1px); box-shadow: 0 6px 16px rgba(27,42,31,0.10); }
  .byo-dots { display: inline-flex; gap: 3px; }
  .byo-dots i { width: 8px; height: 8px; border-radius: 50%; display: block; }

  /* ── Flavor cards ── */
  .byo-grid { display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: 18px; margin-bottom: 30px; }
  .byo-card {
    position: relative;
    background: #fff; border: 2px solid rgba(0,0,0,0.05); border-radius: 22px;
    padding: 0 16px 22px; text-align: center;
    overflow: hidden;
    box-shadow: 0 4px 18px rgba(27,42,31,0.05);
    transition: border-color .25s, box-shadow .25s, transform .25s;
  }
  .byo-card:hover { transform: translateY(-3px); box-shadow: 0 14px 34px rgba(27,42,31,0.11); }
  .byo-card-accent { height: 6px; margin: 0 -16px 18px; }
  .byo-card-blue  .byo-card-accent { background: linear-gradient(90deg, #3B6FF0, #7EA0F7); }
  .byo-card-mango .byo-card-accent { background: linear-gradient(90deg, #F5A623, #FBCB77); }
  .byo-card-water .byo-card-accent { background: linear-gradient(90deg, #E84C6B, #F58CA1); }
  .byo-card.has-cans { box-shadow: 0 14px 36px rgba(27,42,31,0.13); }
  .byo-card-blue.has-cans  { border-color: #3B6FF0; }
  .byo-card-mango.has-cans { border-color: #F5A623; }
  .byo-card-water.has-cans { border-color: #E84C6B; }

  .byo-card-img {
    width: 152px; height: 152px; margin: 0 auto 12px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
  }
  .byo-card-blue  .byo-card-img { background: radial-gradient(circle, rgba(59,111,240,0.12), transparent 72%); }
  .byo-card-mango .byo-card-img { background: radial-gradient(circle, rgba(245,166,35,0.14), transparent 72%); }
  .byo-card-water .byo-card-img { background: radial-gradient(circle, rgba(232,76,107,0.12), transparent 72%); }
  .byo-card-img img { width: 140px; height: 140px; object-fit: contain; transition: transform .3s; }
  .byo-card:hover .byo-card-img img { transform: scale(1.06) rotate(-1.5deg); }

  .byo-card-name { font-weight: 900; font-size: 16.5px; letter-spacing: -0.01em; margin-bottom: 3px; }
  .byo-card-note { font-size: 12.5px; color: var(--gray, #5A6B5E); margin-bottom: 6px; }
  .byo-card-unit {
    display: inline-block; font-size: 10.5px; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--green, #2D6A4F); background: rgba(45,106,79,0.08);
    padding: 4px 11px; border-radius: 50px; margin-bottom: 15px;
  }

  .byo-stepper { display: inline-flex; align-items: center; gap: 16px; }
  .byo-btn {
    width: 42px; height: 42px; border-radius: 14px;
    border: 1.5px solid rgba(45,106,79,0.25); background: #fff; color: var(--green, #2D6A4F);
    font-size: 22px; font-weight: 700; cursor: pointer; line-height: 1;
    box-shadow: 0 2px 8px rgba(27,42,31,0.06);
    transition: all .15s;
  }
  .byo-btn:hover:not(:disabled) { background: var(--green, #2D6A4F); color: #fff; transform: translateY(-1px); }
  .byo-btn:active:not(:disabled) { transform: translateY(0) scale(0.96); }
  .byo-btn:disabled { opacity: 0.30; cursor: not-allowed; box-shadow: none; }
  .byo-qty { font-size: 24px; font-weight: 900; min-width: 30px; transition: color .2s; }
  .byo-card-blue.has-cans  .byo-qty { color: #3B6FF0; }
  .byo-card-mango.has-cans .byo-qty { color: #D98A0F; }
  .byo-card-water.has-cans .byo-qty { color: #E84C6B; }

  /* ── Low-stock badge (base styles live in happie.css) ── */
  .byo-low-stock { display: flex; justify-content: center; width: fit-content; margin: 0 auto 12px; }

  /* ── Social proof strip ── */
  .byo-proof-row {
    display: flex; flex-wrap: wrap; align-items: center; justify-content: center;
    gap: 4px 8px;
    font-size: 13px; font-weight: 600;
    color: var(--gray, #5A6B5E);
    text-align: center;
    margin: 0 0 12px;
    line-height: 1.5;
  }
  .byo-proof-row strong { color: var(--ink, #1F2A22); font-weight: 800; }
  .byo-proof-row .pdp-proof-star { color: #F5A623; }
  .byo-proof-row .pdp-proof-dot { color: rgba(90,107,94,0.45); font-weight: 800; }
  @media (max-width: 640px) {
    .byo-proof-row { font-size: 12px; gap: 2px 7px; }
  }

  /* ── ATC ── */
  .byo-atc {
    display: block; width: 100%; max-width: 520px; margin: 0 auto 12px;
    background: linear-gradient(135deg, var(--green, #2D6A4F), var(--green-dark, #1B4332));
    color: #fff; border: 0; border-radius: 16px;
    padding: 20px; font-size: 16px; font-weight: 800; letter-spacing: 0.04em;
    cursor: pointer;
    box-shadow: 0 14px 32px rgba(45,106,79,0.30);
    transition: transform .2s, box-shadow .2s, opacity .2s;
  }
  .byo-atc:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 18px 40px rgba(45,106,79,0.42); }
  .byo-atc:disabled { opacity: 0.45; cursor: not-allowed; box-shadow: 0 6px 18px rgba(45,106,79,0.15); }
  .byo-atc-note { text-align: center; font-size: 12px; color: var(--gray, #5A6B5E); margin-bottom: 20px; }

  .byo-pills { display: flex; gap: 10px; flex-wrap: wrap; justify-content: center; }
  .byo-pill {
    display: inline-flex; align-items: center; gap: 6px;
    background: #fff; border: 1px solid rgba(0,0,0,0.06);
    border-radius: 50px; padding: 8px 15px;
    font-size: 12px; font-weight: 700; color: #1A1A1A;
    box-shadow: 0 2px 8px rgba(27,42,31,0.04);
  }
  .byo-pill svg { color: var(--green, #2D6A4F); }

  /* ── Feature grid ── */
  .byo-features { margin-top: 52px; }
  .byo-features-title {
    text-align: center; font-size: clamp(22px, 3.2vw, 30px); font-weight: 900;
    letter-spacing: -0.015em; margin-bottom: 26px;
  }
  .byo-features-title em { font-style: normal; color: var(--green, #2D6A4F); }
  .byo-features-grid { display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 14px; max-width: 720px; margin: 0 auto; }
  .byo-feature {
    background: #fff; border: 1px solid rgba(0,0,0,0.05); border-radius: 18px;
    padding: 20px 22px;
    box-shadow: 0 4px 16px rgba(27,42,31,0.05);
    transition: transform .2s, box-shadow .2s;
  }
  .byo-feature:hover { transform: translateY(-2px); box-shadow: 0 10px 26px rgba(27,42,31,0.09); }
  .byo-feature-icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 40px; height: 40px; border-radius: 12px;
    background: rgba(45,106,79,0.09); color: var(--green, #2D6A4F);
    margin-bottom: 11px;
  }
  .byo-feature strong { display: block; font-size: 14.5px; font-weight: 800; margin-bottom: 5px; letter-spacing: -0.005em; }
  .byo-feature p { font-size: 13px; color: var(--gray, #5A6B5E); line-height: 1.6; margin: 0; }
  @media (max-width: 560px) {
    .byo-features-grid { grid-template-columns: 1fr; }
    .byo-features { margin-top: 40px; }
  }

  /* FAQ spacing within the builder page (base .pdp-faq styles come from happie.css) */
  .byo-faq { margin-top: 56px; border-radius: 28px; }
  @media (max-width: 640px) {
    .byo-faq { margin-top: 44px; border-radius: 20px; }
  }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .byo-page { padding: 32px 14px 64px; }
    .byo-price { font-size: 34px; }
    .byo-compare { font-size: 17px; }
    .byo-price-card { padding: 15px 20px 13px; }
    .byo-size { padding: 12px 18px 10px; }
    .byo-size-cans { font-size: 15px; }
    .byo-grid { grid-template-columns: 1fr; gap: 12px; }
    .byo-card {
      display: grid; grid-template-columns: 96px 1fr auto; align-items: center;
      text-align: left; gap: 2px 14px; padding: 14px 14px 14px 10px;
    }
    .byo-card-accent { grid-column: 1 / -1; margin: -14px -14px 10px -10px; }
    .byo-card-img { width: 96px; height: 96px; margin: 0; grid-row: span 4; }
    .byo-card-img img { width: 88px; height: 88px; }
    .byo-card-note { margin-bottom: 2px; }
    .byo-card-unit { margin-bottom: 0; justify-self: start; }
    .byo-stepper { grid-column: 3; grid-row: 2 / span 3; flex-direction: column; gap: 7px; }
    .byo-btn { width: 38px; height: 38px; font-size: 20px; }
    .byo-qty { font-size: 20px; }
    #byo-progress-hint { font-size: 12px; }
  }
</style>

<script>
(function() {
  /* Two box sizes; per-size config drives every label and the hard cap.
     Money strings mirror the variant prices set in Shopify. */
  var SIZES = {
    "18": { target: 3, variantId: "{{ v18.id }}", cents: {{ v18.price }}, price: "{{ v18.price | money }}", compare: "{{ v18.compare_at_price | money }}", save: "SAVE {{ v18.compare_at_price | minus: v18.price | money }}", percan: "$2.72 per can", pct: "32% off vs three 6-packs",
      presets: [
        { mix: [1,1,1], label: "Even Mix · 1 of each", dots: ["#3B6FF0","#F5A623","#E84C6B"] },
        { mix: [3,0,0], label: "All Blue Razz", dots: ["#3B6FF0"] },
        { mix: [0,3,0], label: "All Mango", dots: ["#F5A623"] },
        { mix: [0,0,3], label: "All Watermelon", dots: ["#E84C6B"] }
      ] },
    "24": { target: 4, variantId: "{{ v24.id }}", cents: {{ v24.price }}, price: "{{ v24.price | money }}", compare: "{{ v24.compare_at_price | money }}", save: "SAVE {{ v24.compare_at_price | minus: v24.price | money }}", percan: "$2.54 per can", pct: "36% off vs four 6-packs",
      presets: [
        { mix: [2,1,1], label: "Blue-Heavy Mix", dots: ["#3B6FF0","#3B6FF0","#F5A623","#E84C6B"] },
        { mix: [1,1,2], label: "Melon-Heavy Mix", dots: ["#E84C6B","#E84C6B","#3B6FF0","#F5A623"] },
        { mix: [4,0,0], label: "All Blue Razz", dots: ["#3B6FF0"] },
        { mix: [0,4,0], label: "All Mango", dots: ["#F5A623"] },
        { mix: [0,0,4], label: "All Watermelon", dots: ["#E84C6B"] }
      ] }
  };

  var size     = "18";
  var cards    = Array.prototype.slice.call(document.querySelectorAll('.byo-card'));
  var atc      = document.getElementById('byo-atc');
  var atcText  = document.getElementById('byo-atc-text');
  var countEl  = document.getElementById('byo-count');
  var targetEl = document.getElementById('byo-target');
  var cansEl   = document.getElementById('byo-cans');
  var hintEl   = document.getElementById('byo-progress-hint');
  var segs     = Array.prototype.slice.call(document.querySelectorAll('[data-seg]'));
  var barEl    = document.getElementById('byo-progress-bar');
  var presetsEl= document.getElementById('byo-presets');
  var priceEl  = document.getElementById('byo-price');
  var compEl   = document.getElementById('byo-compare');
  var saveEl   = document.getElementById('byo-save');
  var percanEl = document.getElementById('byo-percan');
  var pctEl    = document.getElementById('byo-pct');
  if (!cards.length || !atc) return;

  var counts = cards.map(function() { return 0; });

  function cfg() { return SIZES[size]; }
  function total() { return counts.reduce(function(a, b) { return a + b; }, 0); }

  function renderPresets() {
    presetsEl.innerHTML = '';
    cfg().presets.forEach(function(p) {
      var btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'byo-preset';
      var dots = '<span class="byo-dots">' + p.dots.map(function(c) { return '<i style="background:' + c + ';"></i>'; }).join('') + '</span>';
      btn.innerHTML = dots + p.label;
      btn.addEventListener('click', function() { counts = p.mix.slice(); render(); });
      presetsEl.appendChild(btn);
    });
  }

  function render() {
    var TARGET = cfg().target;
    var t = total();
    cards.forEach(function(card, i) {
      card.querySelector('[data-count]').textContent = counts[i];
      card.classList.toggle('has-cans', counts[i] > 0);
      card.querySelector('.byo-minus').disabled = counts[i] === 0;
      card.querySelector('.byo-plus').disabled  = t >= TARGET;
    });
    countEl.textContent = t;
    targetEl.textContent = TARGET;
    cansEl.textContent = '(' + (TARGET * 6) + ' cans)';
    barEl.classList.toggle('is-24', size === '24');
    segs.forEach(function(seg, i) { seg.classList.toggle('filled', i < t); });
    if (t === 0)            hintEl.textContent = 'Pick your 6-packs below';
    else if (t < TARGET)    hintEl.textContent = 'Add ' + (TARGET - t) + ' more 6-pack' + (TARGET - t === 1 ? '' : 's');
    else                    hintEl.textContent = (TARGET * 6) + ' cans — pack complete! 🎉';
    atc.disabled = t !== TARGET;
    atcText.textContent = t === TARGET
      ? 'ADD MY ' + (TARGET * 6) + '-PACK — ' + cfg().price
      : 'PICK ' + (TARGET - t) + ' MORE 6-PACK' + (TARGET - t === 1 ? '' : 'S') + ' TO CONTINUE';
    priceEl.textContent  = cfg().price;
    compEl.textContent   = cfg().compare;
    saveEl.textContent   = cfg().save;
    percanEl.textContent = cfg().percan;
    pctEl.textContent    = cfg().pct;
  }

  /* Size switcher — trims overflow packs when stepping down 24 -> 18 */
  document.querySelectorAll('.byo-size').forEach(function(btn) {
    btn.addEventListener('click', function() {
      size = btn.dataset.size;
      document.querySelectorAll('.byo-size').forEach(function(b) {
        var on = b === btn;
        b.classList.toggle('is-active', on);
        b.setAttribute('aria-pressed', on ? 'true' : 'false');
      });
      var TARGET = cfg().target;
      while (total() > TARGET) {
        for (var i = counts.length - 1; i >= 0; i--) {
          if (counts[i] > 0 && total() > TARGET) { counts[i]--; }
        }
      }
      renderPresets();
      render();
    });
  });

  cards.forEach(function(card, i) {
    card.querySelector('.byo-plus').addEventListener('click', function() {
      if (total() < cfg().target) { counts[i]++; render(); }
    });
    card.querySelector('.byo-minus').addEventListener('click', function() {
      if (counts[i] > 0) { counts[i]--; render(); }
    });
  });

  atc.addEventListener('click', function() {
    var TARGET = cfg().target;
    if (total() !== TARGET) return;
    var properties = {};
    cards.forEach(function(card, i) {
      if (counts[i] > 0) properties[card.dataset.flavor] = counts[i] + ' × 6-pack (' + (counts[i] * 6) + ' cans)';
    });
    atc.disabled = true;
    atcText.textContent = 'Adding…';
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ id: cfg().variantId, quantity: 1, properties: properties })
    }).then(function(r) {
      if (!r.ok) throw new Error('add failed');
      return r.json();
    }).then(function() {
      atcText.textContent = '✓ Added to Cart!';
      try {
        if (window.fbq) {
          fbq('track', 'AddToCart', {
            content_ids: [String(cfg().variantId)],
            content_type: 'product',
            content_name: {{ product.title | json }},
            value: cfg().cents / 100,
            currency: 'USD',
            num_items: 1
          });
        }
      } catch(e) {}
      var trigger = document.getElementById('cart-trigger');
      if (trigger) trigger.click();
      setTimeout(render, 1800);
    }).catch(function() {
      render();
      alert("Couldn't add to cart. Please refresh and try again.");
    });
  });

  renderPresets();
  render();
})();
</script>

