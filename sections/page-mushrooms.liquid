      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="padding:80px 24px;text-align:center;background:var(--cream);">
    <h2 style="font-size:clamp(28px,4vw,40px);font-weight:900;margin-bottom:16px;">Ready to feel it yourself?</h2>
