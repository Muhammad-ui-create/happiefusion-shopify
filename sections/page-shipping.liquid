<div class="inner-page">

  <div style="background:linear-gradient(135deg,#f5f0e8 0%,#d8f3dc 100%);padding:90px 48px;text-align:center;">
    <div style="max-width:700px;margin:0 auto;">
      <div style="font-size:11px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#2D6A4F;margin-bottom:14px;">Delivery Info</div>
      <h1 style="font-size:clamp(34px,5vw,56px);font-weight:900;line-height:1.05;margin:0 0 18px;">Shipping Policy</h1>
      <p style="color:#6B6B6B;font-size:17px;line-height:1.65;max-width:520px;margin:0 auto;">Fast, reliable shipping to your door. Here's everything you need to know.</p>
    </div>
  </div>

  <!-- Quick stats -->
  <div style="background:#fff;padding:48px 24px;border-bottom:1px solid rgba(0,0,0,0.07);">
    <div style="max-width:900px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:32px;text-align:center;">
      <div style="padding:28px;background:var(--cream);border-radius:20px;">
        <div style="font-size:36px;margin-bottom:10px;">📦</div>
        <div style="font-size:20px;font-weight:900;color:var(--green);margin-bottom:4px;">1 Business Day</div>
        <div style="font-size:14px;color:var(--gray);">Order processing time</div>
      </div>
      <div style="padding:28px;background:var(--cream);border-radius:20px;">
        <div style="font-size:36px;margin-bottom:10px;">🚚</div>
        <div style="font-size:20px;font-weight:900;color:var(--green);margin-bottom:4px;">3–5 Business Days</div>
        <div style="font-size:14px;color:var(--gray);">Standard delivery</div>
      </div>
      <div style="padding:28px;background:var(--cream);border-radius:20px;">
        <div style="font-size:36px;margin-bottom:10px;">✅</div>
        <div style="font-size:20px;font-weight:900;color:var(--green);margin-bottom:4px;">Free on $75+</div>
        <div style="font-size:14px;color:var(--gray);">Free standard shipping</div>
      </div>
    </div>
  </div>

  <section style="padding:72px 48px;background:#fff;">
    <div style="max-width:800px;margin:0 auto;">

      <div style="margin-bottom:48px;">
        <h2 style="font-size:24px;font-weight:900;margin-bottom:16px;padding-bottom:12px;border-bottom:2px solid var(--green-light);">Processing Time</h2>
        <p style="font-size:16px;color:#444;line-height:1.8;margin-bottom:14px;">All orders are processed within <strong>1 business day</strong> (Monday–Friday, excluding holidays) from our Northern California warehouse. Orders placed after 2pm PST may be processed the following business day.</p>
        <p style="font-size:16px;color:#444;line-height:1.8;">You'll receive a shipping confirmation email with tracking information as soon as your order ships.</p>
      </div>

      <div style="margin-bottom:48px;">
        <h2 style="font-size:24px;font-weight:900;margin-bottom:16px;padding-bottom:12px;border-bottom:2px solid var(--green-light);">Shipping Rates</h2>
        <div style="overflow-x:auto;">
          <table style="width:100%;border-collapse:collapse;font-size:15px;margin-bottom:20px;">
            <thead>
              <tr style="background:var(--green-dark);color:#fff;">
                <th style="padding:14px 20px;text-align:left;border-radius:10px 0 0 0;">Order Total</th>
                <th style="padding:14px 20px;text-align:left;">Shipping Method</th>
                <th style="padding:14px 20px;text-align:left;border-radius:0 10px 0 0;">Cost</th>
              </tr>
            </thead>
            <tbody>
              <tr style="background:#fff;border-bottom:1px solid rgba(0,0,0,0.06);">
                <td style="padding:14px 20px;font-weight:600;">Under $75</td>
                <td style="padding:14px 20px;color:#444;">Standard (3–5 business days)</td>
                <td style="padding:14px 20px;font-weight:700;">$5.99</td>
              </tr>
              <tr style="background:#f9f9f9;border-bottom:1px solid rgba(0,0,0,0.06);">
                <td style="padding:14px 20px;font-weight:600;">$75 and over</td>
                <td style="padding:14px 20px;color:#444;">Standard (3–5 business days)</td>
                <td style="padding:14px 20px;font-weight:700;color:var(--green);">FREE</td>
              </tr>
              <tr style="background:#fff;">
                <td style="padding:14px 20px;font-weight:600;">Any amount</td>
                <td style="padding:14px 20px;color:#444;">Expedited (2 business days)</td>
                <td style="padding:14px 20px;font-weight:700;">$12.99</td>
              </tr>
            </tbody>
          </table>
        </div>
        <div style="background:var(--green-light);border-radius:14px;padding:18px 22px;font-size:14px;color:var(--green-dark);border-left:4px solid var(--green);">
          <strong>Tip:</strong> Two 6-packs ($47.98) get you close — add a third and you unlock free shipping. Subscribe & Save subscribers automatically qualify on recurring orders over $75.
        </div>
      </div>

      <div style="margin-bottom:48px;">
        <h2 style="font-size:24px;font-weight:900;margin-bottom:16px;padding-bottom:12px;border-bottom:2px solid var(--green-light);">Where We Ship</h2>
        <p style="font-size:16px;color:#444;line-height:1.8;margin-bottom:14px;">We currently ship to <strong>40+ US states</strong>. Due to varying state regulations around functional supplements, some states may have shipping restrictions. Your delivery address at checkout will confirm availability.</p>
        <p style="font-size:16px;color:#444;line-height:1.8;">We do not currently ship internationally, but are working to expand. Sign up for our email list to be notified when your country becomes available.</p>
      </div>

      <div style="margin-bottom:48px;">
        <h2 style="font-size:24px;font-weight:900;margin-bottom:16px;padding-bottom:12px;border-bottom:2px solid var(--green-light);">Tracking Your Order</h2>
        <p style="font-size:16px;color:#444;line-height:1.8;margin-bottom:14px;">Once your order ships, you'll receive an email with your tracking number. You can track your package directly on the carrier's website or through the link in your shipping confirmation email.</p>
        <p style="font-size:16px;color:#444;line-height:1.8;">If you haven't received a tracking email within 2 business days of placing your order, please check your spam folder first, then contact us at <a href="mailto:support@happiefusion.com" style="color:var(--green);font-weight:600;">support@happiefusion.com</a>.</p>
      </div>

      <div style="margin-bottom:48px;">
        <h2 style="font-size:24px;font-weight:900;margin-bottom:16px;padding-bottom:12px;border-bottom:2px solid var(--green-light);">Damaged or Missing Orders</h2>
        <p style="font-size:16px;color:#444;line-height:1.8;margin-bottom:14px;">If your order arrives damaged or goes missing, please contact us within <strong>7 days of the expected delivery date</strong>. We'll reship your order at no charge or issue a full refund — your choice.</p>
        <p style="font-size:16px;color:#444;line-height:1.8;">Please take photos of any damaged packaging and include them in your email to help us file a carrier claim.</p>
      </div>

      <div style="background:var(--green-dark);border-radius:20px;padding:36px;text-align:center;">
        <h3 style="color:#fff;font-size:20px;font-weight:800;margin-bottom:10px;">Questions about your order?</h3>
        <p style="color:rgba(255,255,255,0.8);font-size:15px;margin-bottom:20px;">Our team responds within 1 business day.</p>
        <a href="/pages/contact" style="background:#fff;color:var(--green-dark);border-radius:50px;padding:13px 32px;font-size:15px;font-weight:700;display:inline-block;">Contact Us →</a>
      </div>

    </div>
  </section>

</div>

