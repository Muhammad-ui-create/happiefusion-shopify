<section class="ss-section">
  <div class="ss-inner">

    <!-- Left: pitch -->
    <div class="ss-pitch">
      <div class="ss-eyebrow">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-9-9c2.5 0 4.7 1 6.3 2.7M21 4v5h-5"/></svg>
        Subscribe &amp; Save
      </div>
      <h2 class="ss-headline">Save <span class="ss-highlight">15%</span> every month.<br>Never run out again.</h2>
      <p class="ss-sub">Lock in 15% off every order with free shipping on every delivery — and never run out. Cancel anytime, no fees.</p>

      <ul class="ss-benefits">
        <li>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#52B788" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <div>
            <strong>15% off every order</strong>
            <span>Save $3.75 on every 6-pack, every time</span>
          </div>
        </li>
        <li>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#52B788" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <div>
            <strong>Free shipping, every delivery</strong>
            <span>No order minimum required</span>
          </div>
        </li>
        <li>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#52B788" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <div>
            <strong>Cancel or pause anytime</strong>
            <span>One click. No fees. No questions.</span>
          </div>
        </li>
        <li>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#52B788" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <div>
            <strong>Early access to new flavors</strong>
            <span>Subscribers get them first, every time</span>
          </div>
        </li>
      </ul>

      <a href="/collections/all" class="ss-cta">
        Start Saving 15% →
      </a>
      <p class="ss-fineprint">4.9★ from Amazon-verified reviews · Cancel anytime · No hidden fees</p>
    </div>

    <!-- Right: price comparison card -->
    <div class="ss-card">
      <div class="ss-card-header">
        <div class="ss-card-tag">YOUR SAVINGS</div>
        <div class="ss-card-title">6-Pack · Any Flavor</div>
      </div>

      <div class="ss-price-row ss-price-onetime">
        <div class="ss-price-label">One-time purchase</div>
        <div class="ss-price-amount">$24.99</div>
      </div>

      <div class="ss-vs">
        <span>VS</span>
      </div>

      <div class="ss-price-row ss-price-sub">
        <div>
          <div class="ss-price-label-sub">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-9-9c2.5 0 4.7 1 6.3 2.7M21 4v5h-5"/></svg>
            Subscribe &amp; Save
          </div>
          <div class="ss-savings-badge">SAVE 15%</div>
        </div>
        <div class="ss-price-amount ss-price-discounted">
          <span class="ss-price-cross">$24.99</span>
          <strong>$21.24</strong>
        </div>
      </div>

      <div class="ss-frequencies">
        <div class="ss-freq-label">Delivery</div>
        <div class="ss-freq-pills">
          <span class="ss-freq-pill ss-freq-active">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:6px;vertical-align:-2px;"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            Once per month
          </span>
          <span class="ss-freq-pill ss-freq-skip">Skip a month anytime</span>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
.ss-section {
  background: linear-gradient(180deg, var(--cream, #F5F0E8) 0%, #FFFDF7 100%);
  padding: 90px 24px;
  border-top: 1px solid rgba(0,0,0,0.05);
  border-bottom: 1px solid rgba(0,0,0,0.05);
}
.ss-inner {
  max-width: 1180px; margin: 0 auto;
  display: grid; grid-template-columns: 1.1fr 1fr;
  gap: 60px; align-items: center;
}

/* Pitch */
.ss-eyebrow {
  display: inline-flex; align-items: center; gap: 7px;
  background: rgba(82,183,136,0.12);
  border: 1px solid rgba(82,183,136,0.25);
  color: var(--green-dark, #2D6A4F);
  font-size: 11px; font-weight: 800; letter-spacing: 0.14em;
  text-transform: uppercase;
  padding: 7px 16px; border-radius: 50px; margin-bottom: 18px;
}
.ss-headline {
  font-size: clamp(28px, 4vw, 44px); font-weight: 900;
  color: #111; line-height: 1.1; margin: 0 0 16px;
}
.ss-highlight {
  background: linear-gradient(120deg, transparent 30%, rgba(245,166,35,0.35) 30%, rgba(245,166,35,0.35) 90%, transparent 90%);
  color: var(--green-dark, #2D6A4F);
  padding: 0 4px;
}
.ss-sub {
  font-size: 16px; color: #555; line-height: 1.75;
  margin-bottom: 28px; max-width: 480px;
}

.ss-benefits {
  list-style: none; padding: 0; margin: 0 0 32px;
  display: flex; flex-direction: column; gap: 14px;
}
.ss-benefits li {
  display: flex; align-items: flex-start; gap: 14px;
}
.ss-benefits svg { flex-shrink: 0; margin-top: 2px; }
.ss-benefits strong {
  display: block; font-size: 15px; font-weight: 800;
  color: #111; margin-bottom: 2px;
}
.ss-benefits span {
  display: block; font-size: 13px; color: #777;
}

.ss-cta {
  display: inline-flex; align-items: center;
  background: var(--green-dark, #2D6A4F); color: #fff;
  border-radius: 50px; padding: 16px 36px;
  font-size: 15px; font-weight: 800; letter-spacing: 0.02em;
  text-decoration: none;
  transition: background 0.2s, transform 0.2s;
  box-shadow: 0 8px 24px rgba(45,106,79,0.25);
}
.ss-cta:hover {
  background: var(--green, #52B788);
  transform: translateY(-2px);
}
.ss-fineprint {
  font-size: 12px; color: #999; margin: 12px 0 0;
}

/* Card */
.ss-card {
  /* Same iridescent mesh as the site header, softened for a large surface.
     Inner rows sit on top as frosted white panels so the copy stays crisp. */
  background-color: #FCF9F4;
  background-image:
    radial-gradient(56% 125% at  6% 34%, rgba(45,200,214,0.82)  0%, rgba(45,200,214,0)  60%),
    radial-gradient(52% 120% at 22% 80%, rgba(82,205,150,0.78)  0%, rgba(82,205,150,0)  60%),
    radial-gradient(50% 118% at 38% 16%, rgba(255,190,60,0.80)  0%, rgba(255,190,60,0)  58%),
    radial-gradient(52% 120% at 55% 84%, rgba(255,122,138,0.76) 0%, rgba(255,122,138,0) 60%),
    radial-gradient(54% 122% at 71% 22%, rgba(214,72,178,0.72)  0%, rgba(214,72,178,0)  60%),
    radial-gradient(56% 125% at 87% 78%, rgba(138,96,232,0.78)  0%, rgba(138,96,232,0)  62%),
    radial-gradient(58% 128% at 99% 30%, rgba(86,110,226,0.72)  0%, rgba(86,110,226,0)  62%);
  background-size: 200% 200%, 215% 215%, 190% 190%, 225% 225%, 205% 205%, 235% 235%, 220% 220%;
  background-repeat: no-repeat;
  animation: navSilk 12s ease-in-out infinite;
  border-radius: 28px;
  padding: 36px 32px;
  border: 1.5px solid rgba(0,0,0,0.06);
  box-shadow: 0 24px 60px rgba(0,0,0,0.08);
  position: relative;
}
.ss-card-header { margin-bottom: 24px; }
.ss-card-tag {
  font-size: 10px; font-weight: 800; letter-spacing: 0.16em;
  color: #999; text-transform: uppercase; margin-bottom: 6px;
}
.ss-card-title {
  font-size: 17px; font-weight: 800; color: #111;
}

/* Price rows */
.ss-price-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 18px 20px; border-radius: 16px;
  margin-bottom: 8px;
}
.ss-price-onetime {
  background: rgba(255,255,255,0.74);
  border: 1.5px solid rgba(0,0,0,0.06);
}
.ss-price-sub {
  background: rgba(255,255,255,0.88);
  border: 2px solid var(--green, #52B788);
  box-shadow: 0 8px 24px rgba(82,183,136,0.15);
}
.ss-price-label {
  font-size: 14px; font-weight: 700; color: #555;
}
.ss-price-label-sub {
  display: flex; align-items: center; gap: 6px;
  font-size: 14px; font-weight: 800; color: var(--green-dark, #2D6A4F);
  margin-bottom: 4px;
}
.ss-savings-badge {
  display: inline-block;
  font-size: 10px; font-weight: 900; letter-spacing: 0.1em;
  background: #F5A623; color: #1A1A1A;
  padding: 3px 8px; border-radius: 50px;
}
.ss-price-amount {
  font-size: 22px; font-weight: 900; color: #111;
  text-align: right;
}
.ss-price-discounted strong {
  color: var(--green-dark, #2D6A4F);
}
.ss-price-cross {
  display: block;
  font-size: 13px; font-weight: 600;
  color: #999; text-decoration: line-through;
}

.ss-vs {
  text-align: center; margin: -2px 0;
  position: relative;
}
.ss-vs span {
  display: inline-block;
  font-size: 10px; font-weight: 800; letter-spacing: 0.15em;
  color: #ccc; background: #fff;
  padding: 4px 10px; border-radius: 50px;
  position: relative; z-index: 1;
}

/* Yearly */
.ss-yearly {
  margin-top: 20px; padding: 18px 20px;
  background: var(--cream, #F5F0E8); border-radius: 14px;
  display: flex; flex-direction: column; gap: 8px;
}
.ss-yearly-row {
  display: flex; justify-content: space-between; align-items: center;
  font-size: 13px; color: #666;
}
.ss-yearly-row strong { color: #111; font-weight: 800; }
.ss-yearly-big {
  font-size: 20px;
  color: var(--green-dark, #2D6A4F) !important;
}

/* Frequencies */
.ss-frequencies { margin-top: 24px; padding-top: 24px; border-top: 1px solid rgba(0,0,0,0.06); }
.ss-freq-label {
  font-size: 11px; font-weight: 800; letter-spacing: 0.12em;
  color: #999; text-transform: uppercase; margin-bottom: 10px;
}
.ss-freq-pills {
  display: flex; gap: 8px; flex-wrap: wrap;
}
.ss-freq-pill {
  font-size: 12px; font-weight: 700;
  background: rgba(255,255,255,0.72); color: #555;
  border: 1.5px solid rgba(0,0,0,0.07);
  padding: 8px 14px; border-radius: 50px;
}
.ss-freq-active {
  background: var(--green-dark, #2D6A4F) !important;
  color: #fff !important;
  border-color: var(--green-dark, #2D6A4F) !important;
}

@media (prefers-reduced-motion: reduce) {
  .ss-card { animation: none; }
}

/* Mobile */
@media (max-width: 900px) {
  .ss-inner { grid-template-columns: 1fr; gap: 40px; }
  .ss-section { padding: 60px 20px; }
  .ss-card { padding: 28px 22px; }
}
</style>

{% schema %}
{
  "name": "Subscribe & Save",
  "settings": []
}
{% endschema %}
