                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" fill="#6260AE" stroke="none"/><path d="M8 12l3 3 5-5" stroke="#fff"/></svg>
              </td>
              <td class="comp-x">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#bbb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M15 9l-6 6M9 9l6 6"/></svg>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- SEO: Internal Links Hub -->
  <div style="background:var(--cream);padding:48px 24px;border-top:1px solid rgba(0,0,0,0.07);">
    <div style="max-width:1100px;margin:0 auto;">
      <h2 style="font-size:18px;font-weight:800;margin-bottom:20px;color:var(--green-dark);">Learn more about Happie Fungi Fusion</h2>
      <div style="display:flex;flex-wrap:wrap;gap:12px;">
        <a href="/pages/the-science" style="display:inline-flex;align-items:center;gap:6px;background:#fff;border:1px solid rgba(0,0,0,0.1);border-radius:50px;padding:8px 18px;font-size:13px;font-weight:600;color:var(--green);text-decoration:none;">🔬 The Science Behind Dual Extraction</a>
        <a href="/pages/mushrooms" style="display:inline-flex;align-items:center;gap:6px;background:#fff;border:1px solid rgba(0,0,0,0.1);border-radius:50px;padding:8px 18px;font-size:13px;font-weight:600;color:var(--green);text-decoration:none;">🍄 About Lion's Mane, Cordyceps &amp; Reishi</a>
        <a href="/pages/faq" style="display:inline-flex;align-items:center;gap:6px;background:#fff;border:1px solid rgba(0,0,0,0.1);border-radius:50px;padding:8px 18px;font-size:13px;font-weight:600;color:var(--green);text-decoration:none;">❓ Frequently Asked Questions</a>
        <a href="/pages/reviews" style="display:inline-flex;align-items:center;gap:6px;background:#fff;border:1px solid rgba(0,0,0,0.1);border-radius:50px;padding:8px 18px;font-size:13px;font-weight:600;color:var(--green);text-decoration:none;">⭐ Customer Reviews</a>
        <a href="/pages/shipping-policy" style="display:inline-flex;align-items:center;gap:6px;background:#fff;border:1px solid rgba(0,0,0,0.1);border-radius:50px;padding:8px 18px;font-size:13px;font-weight:600;color:var(--green);text-decoration:none;">📦 Shipping Info</a>
      </div>
    </div>
  </div>

  <!-- Related Products -->
  {% assign related = collections['all'].products %}
  {% if related.size > 1 %}
    <div class="related-products">
      <h2 class="related-title">More Functional Mushroom Seltzers</h2>
      <div class="products-grid">
        {% for p in related limit: 4 %}
          {% unless p.id == product.id %}
            {% render 'product-card', product: p %}
          {% endunless %}
        {% endfor %}
      </div>
    </div>
  {% endif %}
</div>

<!-- Product JSON for JS -->
<script>
  window.productData = {
    variants: [
      {% for variant in product.variants %}
      {
        id: {{ variant.id }},
        title: {{ variant.title | json }},
        price: {{ variant.price }},
        available: {{ variant.available }},
        option1: {{ variant.option1 | json }},
        option2: {{ variant.option2 | json }},
        option3: {{ variant.option3 | json }},
        selling_plan_allocations: [
          {% for allocation in variant.selling_plan_allocations %}
          {
            selling_plan_id: {{ allocation.selling_plan.id }},
            price: {{ allocation.price }},
            compare_at_price: {{ allocation.compare_at_price }}
          }{% unless forloop.last %},{% endunless %}
          {% endfor %}
        ]
      }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ]
  };

  // Flavor swatch — update label on hover/click
  document.querySelectorAll('.flavor-swatch').forEach(btn => {
    btn.addEventListener('mouseenter', () => {
      const label = document.getElementById('selected-flavor-label');
      if (label) label.textContent = btn.dataset.value;
    });
  });
</script>

