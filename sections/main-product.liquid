{% comment %} Flavor → swatch color map {% endcomment %}
{% assign flavor_colors = 'Blue Razzberry:#3B6FF0,Mango Mimosa:#F5A623,Watermelon:#E84C6B,Variety Pack:#6260AE' | split: ',' %}

{% comment %}
  Accent for this product, matched off the title against the same map above.
  Drives the 3D one-time purchase option. Falls back to brand green for any
  product whose title doesn't match a known flavour (e.g. the BYO pack).
{% endcomment %}
{% assign product_accent = '#2D6A4F' %}
{% for entry in flavor_colors %}
  {% assign pair = entry | split: ':' %}
  {% if product.title contains pair[0] %}
    {% assign product_accent = pair[1] %}
  {% endif %}
{% endfor %}

<div class="product-page" style="--pdp-accent: {{ product_accent }};">
  <div class="breadcrumb">
    <a href="/">Home</a> /
    <a href="/collections/all">Our Complete Collection</a> /
    <span>{{ product.title }}</span>
  </div>

  <div class="product-layout">

    <!-- ======= LEFT: Image Gallery ======= -->
    <div class="product-gallery">
      <div class="gallery-main">
        {%- comment -%}
          All images render as slides on one track so the gallery can actually
          slide under a finger. Only the first is eager/high-priority; the rest
          are lazy so this doesn't cost more on load than the old single image.
        {%- endcomment -%}
        <div class="gallery-track" id="gallery-track">
          {% for image in product.images %}
            <img
              {% if forloop.first %}id="gallery-main-img"{% endif %}
              src="{{ image | image_url: width: 900 }}"
              {% if forloop.first %}srcset="{{ image | image_url: width: 360 }} 360w, {{ image | image_url: width: 540 }} 540w, {{ image | image_url: width: 720 }} 720w, {{ image | image_url: width: 900 }} 900w"
              sizes="(max-width: 768px) 100vw, 600px"{% endif %}
              alt="{{ image.alt | default: product.title }}"
              class="gallery-slide{% if forloop.first %} gallery-main-img{% endif %}"
              width="900" height="900"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              {% if forloop.first %}fetchpriority="high"{% endif %}
              decoding="async"
              draggable="false"
            />
          {% endfor %}
        </div>
        {% if product.images.size > 1 %}
          <button class="gallery-arrow gallery-prev" id="gallery-prev" aria-label="Previous image">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
          </button>
          <button class="gallery-arrow gallery-next" id="gallery-next" aria-label="Next image">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
          </button>
        {% endif %}
      </div>
      {% if product.images.size > 1 %}
        <div class="gallery-thumbs">
          {% for image in product.images %}
            <div
              class="gallery-thumb {% if forloop.first %}active{% endif %}"
              data-index="{{ forloop.index0 }}"
              data-src="{{ image | image_url: width: 900 }}"
            >
              <img src="{{ image | image_url: width: 160 }}" alt="{{ image.alt | default: product.title }}" loading="lazy" />
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <!-- ======= RIGHT: Product Info ======= -->
    <div class="product-info">

      {% comment %} Low-stock urgency — real count when inventory is truly under 20; otherwise a stable per-product daily figure {% endcomment %}
      {%- assign _inv = product.selected_or_first_available_variant.inventory_quantity -%}
      {%- if _inv and _inv > 0 and _inv <= 20 -%}
        {%- assign _shown = _inv -%}
      {%- else -%}
        {%- assign _day = 'now' | date: '%j' | plus: 0 -%}
        {%- assign _seed = product.id | modulo: 97 | plus: _day -%}
        {%- assign _shown = _seed | modulo: 11 | plus: 8 -%}
      {%- endif -%}
      {%- if product.available -%}
        <div class="low-stock-badge low-stock-top" id="low-stock-badge">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
          </svg>
          <span>Low stock — only <strong>{{ _shown }}</strong> packs left. Order soon</span>
        </div>
      {%- endif -%}

      <!-- Rating + Badge row -->
      <div class="product-top-row">
        <a href="/pages/reviews" class="product-rating" style="text-decoration:none;color:inherit;">
          <span class="stars">★★★★★</span>
          <span class="rating-count">4.9 · Amazon-verified reviews</span>
        </a>
        {%- if product.available -%}
          <span class="top-seller-badge">TOP SELLER</span>
        {%- else -%}
          <span class="top-seller-badge badge-soldout">SOLD OUT</span>
        {%- endif -%}
      </div>

      <h1 class="product-title">{{ product.title }}</h1>
      <p class="product-subtitle">Fungi-Powered Seltzer</p>

      <!-- Price -->
      <div class="product-price-row">
        <span class="product-price" id="product-price">
          {{ product.selected_or_first_available_variant.price | money }}
        </span>
        {% if product.compare_at_price_max > product.price_min %}
          <span class="product-compare-price">{{ product.compare_at_price_max | money }}</span>
        {% endif %}
      </div>

      <!-- Description -->
      <div class="product-desc">
        {{ product.description }}
      </div>

      <!-- Form -->
      {% form 'product', product, id: 'product-form', class: 'product-form' %}
        <input type="hidden" name="id" id="variant-id" value="{{ product.selected_or_first_available_variant.id }}" />

        <!-- Flavor swatch selector -->
        {% for option in product.options_with_values %}
          {% if option.name == 'Flavor' or option.name == 'flavor' %}
            <div class="variant-group">
              <div class="variant-label">Flavor: <strong id="selected-flavor-label">{{ option.selected_value }}</strong></div>
              <div class="variant-swatches" data-option-index="{{ forloop.index0 }}">
                {% for value in option.values %}
                  {% assign swatch_color = '#6260AE' %}
                  {% for entry in flavor_colors %}
                    {% assign pair = entry | split: ':' %}
                    {% if pair[0] == value %}
                      {% assign swatch_color = pair[1] %}
                    {% endif %}
                  {% endfor %}
                  <button
                    type="button"
                    class="flavor-swatch {% if value == option.selected_value %}active{% endif %}"
                    data-value="{{ value }}"
                    data-option-index="{{ forloop.parentloop.index0 }}"
                    data-color="{{ swatch_color }}"
                    style="background:{{ swatch_color }};"
                    aria-label="{{ value }}"
                    title="{{ value }}"
                  ></button>
                {% endfor %}
              </div>
            </div>
          {% endif %}

          {% if option.name == 'Size' or option.name == 'Pack' or option.name == 'Pack Size' %}
            <div class="variant-group">
              <div class="variant-label">Pack Size: <strong>{{ option.selected_value }}</strong></div>
              <div class="variant-pills" data-option-index="{{ forloop.index0 }}">
                {% for value in option.values %}
                  <button
                    type="button"
                    class="variant-pill {% if value == option.selected_value %}active{% endif %}"
                    data-value="{{ value }}"
                    data-option-index="{{ forloop.parentloop.index0 }}"
                  >{{ value }}</button>
                {% endfor %}
              </div>
            </div>
          {% endif %}
        {% endfor %}

        {%- comment -%}
          Cross-links to the other flavours. Each flavour is its own product, so
          the variant swatches above never surface them — without this row a
          visitor who wants a different flavour has to go back to the collection.
          Labels and colours come from the same flavour map used by the swatches.
        {%- endcomment -%}
        {%- assign jump_handles = 'blue-razzberry-fungi-powered-seltzer,mango-mimosa-fungi-powered-seltzer,watermelon-fungi-powered-seltzer,happie-fungi-fusion-mushroom-drink-variety-pack' | split: ',' -%}
        {%- capture flavor_jump_items -%}
          {%- for h in jump_handles -%}
            {%- assign p = all_products[h] -%}
            {%- if p != empty and p.handle != product.handle and p.available -%}
              {%- assign chip_label = p.title | split: ' — ' | first -%}
              {%- assign chip_color = '#6260AE' -%}
              {%- for entry in flavor_colors -%}
                {%- assign pair = entry | split: ':' -%}
                {%- if p.title contains pair[0] -%}
                  {%- assign chip_label = pair[0] -%}
                  {%- assign chip_color = pair[1] -%}
                {%- endif -%}
              {%- endfor -%}
              <a href="{{ p.url }}" class="pdp-flavor-chip" style="--chip: {{ chip_color }};">
                {%- if p.featured_image -%}
                  <img src="{{ p.featured_image | image_url: width: 120 }}" alt="{{ chip_label }}" width="46" height="46" loading="lazy" />
                {%- endif -%}
                <span class="pdp-flavor-chip-text">
                  <span class="pdp-flavor-chip-name">{{ chip_label }}</span>
                  <span class="pdp-flavor-chip-price">{{ p.price | money }}</span>
                </span>
              </a>
            {%- endif -%}
          {%- endfor -%}
        {%- endcapture -%}
        {%- assign flavor_jump_trimmed = flavor_jump_items | strip -%}
        {%- if flavor_jump_trimmed != blank -%}
          <div class="pdp-flavor-jump">
            <div class="pdp-flavor-jump-label">Try another flavor</div>
            <div class="pdp-flavor-jump-row">{{ flavor_jump_items }}</div>
          </div>
        {%- endif -%}

        <!-- Quantity -->
        <div class="qty-row">
          <div class="qty-label">Quantity</div>
          <div class="qty-stepper">
            <button type="button" class="qty-btn" id="qty-minus">−</button>
            <input type="number" name="quantity" id="qty-input" value="1" min="1" max="20" step="1" inputmode="numeric" pattern="[0-9]*" class="qty-input" />
            <button type="button" class="qty-btn" id="qty-plus">+</button>
          </div>
        </div>

        <!-- Purchase Options: One-time vs Subscribe -->
        {% if product.selling_plan_groups.size > 0 %}
          <div class="purchase-options">
            <div class="purchase-label">Purchase Options</div>
            {% for group in product.selling_plan_groups %}
              {% for plan in group.selling_plans %}
                <label class="purchase-option subscribe-opt" id="opt-subscribe">
                  <input type="radio" name="selling_plan" value="{{ plan.id }}" id="selling-plan-{{ plan.id }}" />
                  <div class="opt-inner">
                    <div class="opt-title">
                      Subscribe &amp; Save
                      {% for adjustment in plan.price_adjustments %}
                        {% if adjustment.value_type == 'percentage' %}
                          <span class="save-badge">SAVE {{ adjustment.value }}%</span>
                        {% endif %}
                      {% endfor %}
                    </div>
                    <div class="opt-price subscribe-price" id="subscribe-price">
                      {% assign variant = product.selected_or_first_available_variant %}
                      {% for allocation in variant.selling_plan_allocations %}
                        {% if allocation.selling_plan.id == plan.id %}
                          <span class="price-discounted">{{ allocation.price | money }}</span>
                          <span class="price-original-crossed">{{ variant.price | money }}</span>
                        {% endif %}
                      {% endfor %}
                    </div>
                    <div class="opt-sub">{{ plan.description }}</div>
                  </div>
                </label>
              {% endfor %}
            {% endfor %}
            <label class="purchase-option {% if product.selected_selling_plan_allocation == nil %}active{% endif %}" id="opt-onetime">
              <input type="radio" name="selling_plan" value="" id="selling-plan-onetime" {% if product.selected_selling_plan_allocation == nil %}checked{% endif %} />
              <div class="opt-inner">
                <div class="opt-title">One Time Purchase</div>
                <div class="opt-price" id="onetime-price">{{ product.selected_or_first_available_variant.price | money }}</div>
              </div>
            </label>
          </div>
        {% endif %}

        {% comment %} Social proof strip — real numbers only: Amazon review count + cumulative volume {% endcomment %}
        <div class="pdp-proof-row" aria-label="Customer proof">
          <span class="pdp-proof-item"><span class="pdp-proof-star">★</span> <strong>4.9</strong> average on Amazon</span>
          <span class="pdp-proof-dot" aria-hidden="true">·</span>
          <span class="pdp-proof-item">Amazon's Choice — Watermelon 6-Pack</span>
        </div>


        {%- if product.available -%}
          <!-- Add to Cart -->
          <button type="submit" class="btn-atc" id="add-to-cart-btn">
            <span id="atc-text">ADD TO CART – <span id="atc-price">{{ product.selected_or_first_available_variant.price | money }}</span></span>
          </button>

          {% comment %} Express checkout — Shop Pay, Apple Pay, Google Pay (renders only the ones the buyer's browser supports) {% endcomment %}
          {{ form | payment_button }}
        {%- else -%}
          <button type="button" class="btn-atc btn-atc-soldout" disabled>
            <span>SOLD OUT — BACK SOON</span>
          </button>
          <p class="lp-atc-note" style="text-align:center;">Want it back first? The 6-packs and the <a href="/products/build-your-own-fungi-fusion-18-pack" style="font-weight:700;text-decoration:underline;">Build Your Own 18-Pack</a> are in stock now.</p>
        {%- endif -%}

        {% comment %} Accepted payment methods — same row as the cart drawer {% endcomment %}
        <div class="cart-trust-row pdp-pay-row" aria-label="Accepted payment methods">
          <svg viewBox="0 0 34 22" width="34" height="22" role="img" aria-label="Visa"><rect width="34" height="22" rx="3" fill="#1A1F71"/><text x="17" y="15.5" font-family="Arial,sans-serif" font-weight="900" font-size="9" fill="#fff" text-anchor="middle" letter-spacing="0.5">VISA</text></svg>
          <svg viewBox="0 0 34 22" width="34" height="22" role="img" aria-label="Mastercard"><rect width="34" height="22" rx="3" fill="#fff" stroke="#e5e5e5"/><circle cx="13" cy="11" r="6" fill="#EB001B"/><circle cx="21" cy="11" r="6" fill="#F79E1B"/><path d="M17 6.5a6 6 0 0 0 0 9 6 6 0 0 0 0-9z" fill="#FF5F00"/></svg>
          <svg viewBox="0 0 34 22" width="34" height="22" role="img" aria-label="American Express"><rect width="34" height="22" rx="3" fill="#2E77BB"/><text x="17" y="14" font-family="Arial,sans-serif" font-weight="900" font-size="6" fill="#fff" text-anchor="middle" letter-spacing="0.3">AMEX</text></svg>
          <svg viewBox="0 0 34 22" width="34" height="22" role="img" aria-label="PayPal"><rect width="34" height="22" rx="3" fill="#fff" stroke="#e5e5e5"/><text x="17" y="14.5" font-family="Arial,sans-serif" font-weight="800" font-style="italic" font-size="6.5" fill="#003087" text-anchor="middle">PayPal</text></svg>
          <svg viewBox="0 0 34 22" width="34" height="22" role="img" aria-label="Apple Pay"><rect width="34" height="22" rx="3" fill="#000"/><path d="M11.4 8.5c.5-.6.8-1.4.7-2.2-.7 0-1.5.5-2 1-.5.5-.9 1.4-.8 2.1.8.1 1.6-.4 2.1-.9z" fill="#fff"/><path d="M12 9.6c-.7 0-1.4.5-1.9.5-.5 0-1.2-.4-1.9-.4-1 0-2 .6-2.5 1.5-1 1.9-.3 4.6.7 6.1.5.7 1 1.5 1.8 1.5.7 0 1-.5 1.9-.5.9 0 1.1.5 1.9.5.8 0 1.3-.7 1.8-1.4.5-.7.8-1.5.9-1.5-1.4-.5-2.5-2.1-1.8-3.8.5-1 1.5-1.6 1.5-1.6-.5-.7-1.4-1-2.4-1z" fill="#fff"/><text x="22" y="15" font-family="-apple-system,Helvetica,Arial,sans-serif" font-weight="600" font-size="7" fill="#fff" text-anchor="middle">Pay</text></svg>
          <svg viewBox="0 0 34 22" width="34" height="22" role="img" aria-label="Shop Pay"><rect width="34" height="22" rx="3" fill="#5A31F4"/><text x="17" y="14.5" font-family="Helvetica,Arial,sans-serif" font-weight="800" font-size="6.5" fill="#fff" text-anchor="middle" letter-spacing="0.2">shop pay</text></svg>
          <svg viewBox="0 0 34 22" width="34" height="22" role="img" aria-label="Google Pay"><rect width="34" height="22" rx="3" fill="#fff" stroke="#e5e5e5"/><text x="17" y="14.5" font-family="Arial,sans-serif" font-weight="700" font-size="6.5" fill="#5f6368" text-anchor="middle" letter-spacing="0.1">G Pay</text></svg>
        </div>


        <!-- Trust pills -->
        <div class="product-trust-pills">
          <span class="trust-pill">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="6" width="15" height="11" rx="2"/><path d="M16 10h4l3 3v4h-7"/><circle cx="5.5" cy="19.5" r="1.5"/><circle cx="20.5" cy="19.5" r="1.5"/></svg>
            Ships 1 Business Day
          </span>
          <span class="trust-pill">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a9 9 0 0 1 9 9c0 4-2 7.5-5 9.5l-1-1.5c2-1.5 3.5-4 3.5-8C18.5 7.5 15.5 4.5 12 4.5S5.5 7.5 5.5 11c0 4 1.5 6.5 3.5 8L8 20.5C5 18.5 3 15 3 11a9 9 0 0 1 9-9z"/><path d="M12 7v6l3 2"/></svg>
            Free Shipping — No Minimum
          </span>
          <span class="trust-pill">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22V12"/><path d="M12 12C12 12 7 10 6 6c3 0 6 2 6 6z"/><path d="M12 12c0 0 5-2 6-6-3 0-6 2-6 6z"/></svg>
            100% Vegan
          </span>
          <a href="/pages/the-science#lab-results" class="trust-pill trust-pill-link" title="View Certificate of Analysis for every batch">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3h6l1 4H8L9 3z"/><path d="M8 7v10a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V7"/><path d="M12 11v3M11 13h2"/></svg>
            3rd-Party Lab Tested
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-left:2px;"><path d="M7 17L17 7M7 7h10v10"/></svg>
          </a>
        </div>
      {% endform %}

      {% comment %} Build Your Own cross-sell — hidden on the BYO product itself (it uses its own template) {% endcomment %}
      {%- assign byo = all_products['build-your-own-fungi-fusion-18-pack'] -%}
      {%- if byo and byo.available and product.handle != byo.handle -%}
        <a href="/products/build-your-own-fungi-fusion-18-pack" class="pdp-byo-card">
          <div class="pdp-byo-img">
            {%- if byo.featured_image -%}
              <img src="{{ byo.featured_image | image_url: width: 240 }}" alt="Build Your Own Fungi Fusion pack" width="120" height="120" loading="lazy">
            {%- endif -%}
          </div>
          <div class="pdp-byo-body">
            <span class="pdp-byo-tag">CUSTOM PACK BUILDER</span>
            <strong class="pdp-byo-title">Build Your Own 18 or 24-Can Box</strong>
            <span class="pdp-byo-sub">Mix all three flavors your way — from {{ byo.price_min | money }} <s>{{ byo.compare_at_price_min | money }}</s> · as low as $3.00 a can</span>
          </div>
          <span class="pdp-byo-arrow" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>
      {%- endif -%}

      <!-- Accordions -->
      <div class="accordions">
        <div class="accordion">
          <button class="accordion-trigger" type="button">
            <span class="acc-label">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22V12"/><path d="M12 12C12 12 7 10 6 6c3 0 6 2 6 6z"/><path d="M12 12c0 0 5-2 6-6-3 0-6 2-6 6z"/></svg>
              What's Inside?
            </span>
            <svg class="acc-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="accordion-body">
            <p><strong>Functional Mushroom Blend (2,000mg total):</strong></p>
            <ul>
              <li>Lion's Mane Extract (fruiting body) — 900mg</li>
              <li>Cordyceps militaris Extract (fruiting body) — 700mg</li>
              <li>Reishi Extract (fruiting body) — 400mg</li>
            </ul>
            <p><strong>Other Ingredients:</strong> Carbonated Water, Organic Light Blue Agave Nectar, Citric Acid, Natural Flavor, Ocean Derived Magnesium, Ocean Derived Calcium Citrate, Potassium Sorbate, Benzoic Acid.</p>
            <p>Vegan · Gluten-Free · Non-GMO · No Artificial Flavors</p>
          </div>
        </div>

        <div class="accordion">
          <button class="accordion-trigger" type="button">
            <span class="acc-label">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L4.5 13.5H11L10 22l9.5-11.5H13L13 2z"/></svg>
              How It Works
            </span>
            <svg class="acc-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="accordion-body">
            <p>Dual-extraction pulls both water-soluble beta-glucans and fat-soluble triterpenes from each mushroom — the full spectrum of active compounds.</p>
            <p>Most products use mycelium on grain (mostly starch, low actives). Happie uses <strong>fruiting body extracts</strong> — the real mushroom, standardized for potency.</p>
            <p>Drink one daily. Most customers notice improved focus and energy within 1–2 weeks of consistent use.</p>
          </div>
        </div>

        <div class="accordion">
          <button class="accordion-trigger" type="button">
            <span class="acc-label">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22V12"/><path d="M9 3h6l1 4H8L9 3z"/><path d="M8 7v10a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V7"/><circle cx="12" cy="11" r="1"/></svg>
              Lab Tested &amp; Quality Assured
            </span>
            <svg class="acc-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="accordion-body">
            <p>Every batch is third-party tested at <strong>KCA Laboratories</strong> — an ISO/IEC 17025:2017 accredited lab in Nicholasville, KY.</p>
            <ul>
              <li>Heavy metals (As, Cd, Pb, Hg) by ICP-MS</li>
              <li>66 pesticides by LC-MS/MS and GC-MS/MS</li>
              <li>Microbial safety (E. coli, Salmonella, yeast &amp; mold)</li>
              <li>Mycotoxins (aflatoxins + ochratoxin A)</li>
              <li>Foreign matter &amp; residual solvents</li>
            </ul>
