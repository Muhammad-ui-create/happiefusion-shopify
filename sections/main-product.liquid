              </td>
              <td class="comp-x">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#bbb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M15 9l-6 6M9 9l6 6"/></svg>
              </td>
            </tr>
            <tr>
              <td class="comp-feature">Mineral-Infused Formula</td>
              <td class="comp-check">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" fill="#6260AE" stroke="none"/><path d="M8 12l3 3 5-5" stroke="#fff"/></svg>
