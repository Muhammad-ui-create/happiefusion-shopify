{% comment %} Flavor → swatch color map {% endcomment %}
{% assign flavor_colors = 'Blue Razzberry:#3B6FF0,Mango Mimosa:#F5A623,Watermelon:#E84C6B,Variety Pack:#6260AE' | split: ',' %}

<div class="product-page">
  <div class="breadcrumb">
    <a href="/">Home</a> /
    <a href="/collections/all">Our Complete Collection</a> /
    <span>{{ product.title }}</span>
  </div>

  <div class="product-layout">

    <!-- ======= LEFT: Image Gallery ======= -->
    <div class="product-gallery">
      <div class="gallery-main">
        {% assign first_image = product.images | first %}
        <img
          id="gallery-main-img"
          src="{{ first_image | image_url: width: 900 }}"
          alt="{{ first_image.alt | default: product.title | append: ' — functional mushroom seltzer with Lion\'s Mane, Cordyceps & Reishi' }}"
          class="gallery-main-img"
          width="900" height="900"
          loading="eager"
        />
        {% if product.images.size > 1 %}
          <button class="gallery-arrow gallery-prev" id="gallery-prev" aria-label="Previous image">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
          </button>
          <button class="gallery-arrow gallery-next" id="gallery-next" aria-label="Next image">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
          </button>
        {% endif %}
      </div>
      {% if product.images.size > 1 %}
        <div class="gallery-thumbs">
          {% for image in product.images %}
            <div
              class="gallery-thumb {% if forloop.first %}active{% endif %}"
              data-index="{{ forloop.index0 }}"
              data-src="{{ image | image_url: width: 900 }}"
            >
              <img src="{{ image | image_url: width: 160 }}" alt="{{ image.alt | default: product.title | append: ' — Happie Fungi Fusion' }}" loading="lazy" width="160" height="160" />
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <!-- ======= RIGHT: Product Info ======= -->
    <div class="product-info">

      <!-- Rating + Badge row -->
      <div class="product-top-row">
        <div class="product-rating">
          <span class="stars">★★★★★</span>
          <span class="rating-count">4.9 (1,200+ reviews)</span>
        </div>
        <span class="top-seller-badge">TOP SELLER</span>
      </div>

      <h1 class="product-title">{{ product.title }}</h1>
      <p class="product-subtitle">Fungi-Powered Seltzer</p>

      <!-- Price -->
      <div class="product-price-row">
        <span class="product-price" id="product-price">
          {{ product.selected_or_first_available_variant.price | money }}
        </span>
        {% if product.compare_at_price_max > product.price_min %}
          <span class="product-compare-price">{{ product.compare_at_price_max | money }}</span>
        {% endif %}
      </div>

      <!-- Description -->
      <div class="product-desc">
        {{ product.description }}
      </div>

      <!-- Form -->
      {% form 'product', product, id: 'product-form', class: 'product-form' %}
        <input type="hidden" name="id" id="variant-id" value="{{ product.selected_or_first_available_variant.id }}" />

        <!-- Flavor swatch selector -->
        {% for option in product.options_with_values %}
          {% if option.name == 'Flavor' or option.name == 'flavor' %}
            <div class="variant-group">
              <div class="variant-label">Flavor: <strong id="selected-flavor-label">{{ option.selected_value }}</strong></div>
              <div class="variant-swatches" data-option-index="{{ forloop.index0 }}">
                {% for value in option.values %}
                  {% assign swatch_color = '#6260AE' %}
                  {% for entry in flavor_colors %}
                    {% assign pair = entry | split: ':' %}
                    {% if pair[0] == value %}
                      {% assign swatch_color = pair[1] %}
                    {% endif %}
                  {% endfor %}
                  <button
                    type="button"
                    class="flavor-swatch {% if value == option.selected_value %}active{% endif %}"
                    data-value="{{ value }}"
                    data-option-index="{{ forloop.parentloop.index0 }}"
                    data-color="{{ swatch_color }}"
                    style="background:{{ swatch_color }};"
                    aria-label="{{ value }}"
                    title="{{ value }}"
                  ></button>
                {% endfor %}
              </div>
            </div>
          {% endif %}

          {% if option.name == 'Size' or option.name == 'Pack' or option.name == 'Pack Size' %}
            <div class="variant-group">
              <div class="variant-label">Pack Size: <strong>{{ option.selected_value }}</strong></div>
              <div class="variant-pills" data-option-index="{{ forloop.index0 }}">
                {% for value in option.values %}
                  <button
                    type="button"
                    class="variant-pill {% if value == option.selected_value %}active{% endif %}"
                    data-value="{{ value }}"
                    data-option-index="{{ forloop.parentloop.index0 }}"
                  >{{ value }}</button>
                {% endfor %}
              </div>
            </div>
          {% endif %}
        {% endfor %}

        <!-- Quantity -->
        <div class="qty-row">
          <div class="qty-label">Quantity</div>
          <div class="qty-stepper">
            <button type="button" class="qty-btn" id="qty-minus">−</button>
            <input type="number" name="quantity" id="qty-input" value="1" min="1" class="qty-input" />
            <button type="button" class="qty-btn" id="qty-plus">+</button>
          </div>
        </div>

        <!-- Purchase Options: Subscribe (default) vs One-time -->
        {% if product.selling_plan_groups.size > 0 %}
          <div class="purchase-options purchase-options-v2">
            <div class="purchase-header">
              <div class="purchase-label">Choose Your Plan</div>
              <span class="purchase-best-tag">⚡ MOST POPULAR</span>
            </div>

            {% for group in product.selling_plan_groups %}
              {% for plan in group.selling_plans %}
                <label class="purchase-option subscribe-opt subscribe-opt-v2 active" id="opt-subscribe">
                  <input type="radio" name="selling_plan" value="{{ plan.id }}" id="selling-plan-{{ plan.id }}" checked />
                  <div class="opt-inner">
                    <div class="opt-top">
                      <div class="opt-title">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:6px;vertical-align:-3px;"><path d="M21 12a9 9 0 1 1-9-9c2.5 0 4.7 1 6.3 2.7M21 4v5h-5"/></svg>
                        Subscribe &amp; Save
                        {% for adjustment in plan.price_adjustments %}
                          {% if adjustment.value_type == 'percentage' %}
                            <span class="save-badge save-badge-v2">SAVE {{ adjustment.value }}%</span>
                          {% endif %}
                        {% endfor %}
                      </div>
                      <div class="opt-price subscribe-price" id="subscribe-price">
                        {% assign variant = product.selected_or_first_available_variant %}
                        {% for allocation in variant.selling_plan_allocations %}
                          {% if allocation.selling_plan.id == plan.id %}
                            <span class="price-discounted">{{ allocation.price | money }}</span>
                            <span class="price-original-crossed">{{ variant.price | money }}</span>
                          {% endif %}
                        {% endfor %}
                      </div>
                    </div>
                    <ul class="opt-perks">
                      <li>✓ Free shipping every order</li>
                      <li>✓ Skip, pause, or cancel anytime</li>
                      <li>✓ Early access to new flavors</li>
                    </ul>
                    <div class="opt-sub">{{ plan.description }}</div>
                  </div>
                </label>
              {% endfor %}
            {% endfor %}

            <label class="purchase-option" id="opt-onetime">
              <input type="radio" name="selling_plan" value="" id="selling-plan-onetime" />
              <div class="opt-inner">
                <div class="opt-top">
                  <div class="opt-title">One-Time Purchase</div>
                  <div class="opt-price" id="onetime-price">{{ product.selected_or_first_available_variant.price | money }}</div>
                </div>
              </div>
            </label>
          </div>

          <style>
          .purchase-options-v2 { display: flex; flex-direction: column; gap: 10px; margin-bottom: 18px; }
          .purchase-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; }
          .purchase-label { font-size: 12px; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; color: #666; }
          .purchase-best-tag { font-size: 10px; font-weight: 900; letter-spacing: 0.12em; background: #F5A623; color: #1A1A1A; padding: 4px 10px; border-radius: 50px; }
          .subscribe-opt-v2 {
            background: linear-gradient(135deg, #E8F5EC, #D4EDDE) !important;
            border: 2.5px solid #2D6A4F !important;
            box-shadow: 0 8px 24px rgba(45,106,79,0.15);
            border-radius: 16px !important;
            padding: 16px 18px !important;
            position: relative;
          }
          .subscribe-opt-v2 .opt-title { color: #2D6A4F; font-weight: 800; }
          .save-badge-v2 { background: #F5A623 !important; color: #1A1A1A !important; font-weight: 900 !important; }
          .opt-top { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; margin-bottom: 10px; }
          .opt-perks { list-style: none; padding: 0; margin: 10px 0 4px; font-size: 13px; color: #2D6A4F; display: flex; flex-direction: column; gap: 4px; }
          .opt-perks li { font-weight: 600; }
          .opt-sub { font-size: 12px; color: #555; margin-top: 6px; }
          .purchase-option:not(.subscribe-opt-v2) { padding: 14px 18px !important; border: 1.5px solid rgba(0,0,0,0.1) !important; border-radius: 14px !important; }
          .purchase-option:not(.subscribe-opt-v2):hover { border-color: rgba(45,106,79,0.4) !important; }
          </style>
        {% endif %}

        <!-- Add to Cart -->
        <button type="submit" class="btn-atc" id="add-to-cart-btn">
          <span id="atc-text">ADD TO CART – <span id="atc-price">{{ product.selected_or_first_available_variant.price | money }}</span></span>
        </button>

        <!-- Trust pills -->
        <div class="product-trust-pills">
          <span class="trust-pill">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="6" width="15" height="11" rx="2"/><path d="M16 10h4l3 3v4h-7"/><circle cx="5.5" cy="19.5" r="1.5"/><circle cx="20.5" cy="19.5" r="1.5"/></svg>
            Ships 1 Business Day
          </span>
          <span class="trust-pill">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a9 9 0 0 1 9 9c0 4-2 7.5-5 9.5l-1-1.5c2-1.5 3.5-4 3.5-8C18.5 7.5 15.5 4.5 12 4.5S5.5 7.5 5.5 11c0 4 1.5 6.5 3.5 8L8 20.5C5 18.5 3 15 3 11a9 9 0 0 1 9-9z"/><path d="M12 7v6l3 2"/></svg>
            Free Shipping $75+
          </span>
          <span class="trust-pill">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22V12"/><path d="M12 12C12 12 7 10 6 6c3 0 6 2 6 6z"/><path d="M12 12c0 0 5-2 6-6-3 0-6 2-6 6z"/></svg>
            100% Vegan
          </span>
          <span class="trust-pill">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3h6l1 4H8L9 3z"/><path d="M8 7v10a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V7"/><path d="M12 11v3M11 13h2"/></svg>
            3rd-Party Lab Tested
          </span>
        </div>
      {% endform %}

      <!-- Accordions -->
      <div class="accordions">
        <div class="accordion">
          <button class="accordion-trigger" type="button">
            <span class="acc-label">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22V12"/><path d="M12 12C12 12 7 10 6 6c3 0 6 2 6 6z"/><path d="M12 12c0 0 5-2 6-6-3 0-6 2-6 6z"/></svg>
              What's Inside?
            </span>
            <svg class="acc-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="accordion-body">
            <p><strong>Functional Mushroom Blend (2,000mg total):</strong></p>
            <ul>
              <li>Lion's Mane Extract (fruiting body) — 900mg</li>
              <li>Cordyceps militaris Extract (fruiting body) — 700mg</li>
              <li>Reishi Extract (fruiting body) — 400mg</li>
            </ul>
            <p><strong>Other Ingredients:</strong> Carbonated Water, Organic Light Blue Agave Nectar, Citric Acid, Natural Flavor, Ocean Derived Magnesium, Ocean Derived Calcium Citrate, Potassium Sorbate, Benzoic Acid.</p>
            <p>Vegan · Gluten-Free · Non-GMO · No Artificial Flavors</p>
          </div>
        </div>

        <div class="accordion">
          <button class="accordion-trigger" type="button">
            <span class="acc-label">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L4.5 13.5H11L10 22l9.5-11.5H13L13 2z"/></svg>
              How It Works
            </span>
            <svg class="acc-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="accordion-body">
            <p>Dual-extraction pulls both water-soluble beta-glucans and fat-soluble triterpenes from each mushroom — the full spectrum of active compounds.</p>
            <p>Most products use mycelium on grain (mostly starch, low actives). Happie uses <strong>fruiting body extracts</strong> — the real mushroom, standardized for potency.</p>
            <p>Drink one daily. Most customers notice improved focus and energy within 1–2 weeks of consistent use.</p>
          </div>
        </div>

        <div class="accordion">
          <button class="accordion-trigger" type="button">
            <span class="acc-label">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22V12"/><path d="M9 3h6l1 4H8L9 3z"/><path d="M8 7v10a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V7"/><circle cx="12" cy="11" r="1"/></svg>
              Lab Tested &amp; Quality Assured
            </span>
            <svg class="acc-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="accordion-body">
            <p>Every batch is third-party tested for:</p>
            <ul>
              <li>Heavy metals &amp; contaminants</li>
              <li>Microbial safety</li>
              <li>Potency verification (beta-glucan content)</li>
              <li>Pesticides &amp; herbicides</li>
            </ul>
            <p>Each can is QR-coded to the full lab report. You deserve to know exactly what you're drinking.</p>
          </div>
        </div>
      </div>

    </div><!-- /product-info -->
  </div><!-- /product-layout -->

