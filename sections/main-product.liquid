<!-- Product JSON for JS -->
<script>
  window.productData = {
    variants: [
      {% for variant in product.variants %}
      {
        id: {{ variant.id }},
        title: {{ variant.title | json }},
        price: {{ variant.price }},
        available: {{ variant.available }},
        option1: {{ variant.option1 | json }},
        option2: {{ variant.option2 | json }},
        option3: {{ variant.option3 | json }},
        selling_plan_allocations: [
          {% for allocation in variant.selling_plan_allocations %}
          {
            selling_plan_id: {{ allocation.selling_plan.id }},
            price: {{ allocation.price }},
            compare_at_price: {{ allocation.compare_at_price }}
          }{% unless forloop.last %},{% endunless %}
          {% endfor %}
        ]
      }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ]
  };

  // Flavor swatch — update label on hover/click
  document.querySelectorAll('.flavor-swatch').forEach(btn => {
    btn.addEventListener('mouseenter', () => {
      const label = document.getElementById('selected-flavor-label');
      if (label) label.textContent = btn.dataset.value;
    });
  });

  /* ── Subscription policy disclosure toggle ──
     Shopify auto-injects "This item is a deferred, subscription, or recurring purchase…"
     under the buy buttons whenever the product HAS selling plans — even when the buyer
     has One Time Purchase selected. That reads as "I'm about to get auto-billed" to cold
     traffic. Hide it unless Subscribe & Save is actually selected; it must stay visible
     when a selling plan IS selected (required consent disclosure). */
  (function() {
    // Shopify renders the consent text as <small id="shopify-buyer-consent"> inside
    // .shopify-payment-button. CSS hides it by default (see happie.css); this toggle
    // re-shows it whenever a selling plan is actually selected — required consent.
    function applyVisibility() {
      var checked = document.querySelector('input[name="selling_plan"]:checked');
      document.body.classList.toggle('subscription-selected', !!(checked && checked.value));
    }
    applyVisibility();
    document.querySelectorAll('input[name="selling_plan"]').forEach(function(radio) {
      radio.addEventListener('change', applyVisibility);
    });
  })();
</script>

{%- if product.available -%}
<!-- ── Sticky mobile ATC bar — appears once the buy box scrolls out of view ── -->
<div class="pdp-sticky-atc" id="pdp-sticky-atc" style="--pdp-accent: {{ product_accent }};">
  <div class="pdp-sticky-info">
    <span class="pdp-sticky-title">{{ product.title | split: ' — ' | first | escape }}</span>
    <span class="pdp-sticky-price" id="pdp-sticky-price">{{ product.selected_or_first_available_variant.price | money }}</span>
  </div>
  <button type="button" class="pdp-sticky-btn" id="pdp-sticky-btn">ADD TO CART</button>
</div>
<script>
  (function() {
    var bar = document.getElementById('pdp-sticky-atc');
    var mainBtn = document.getElementById('add-to-cart-btn');
    if (!bar || !mainBtn) return;
    // Proxy the real ATC so quantity, selling plan, and the AJAX handler all apply
    document.getElementById('pdp-sticky-btn').addEventListener('click', function() {
      mainBtn.click();
      bar.classList.remove('is-visible');
    });
    if ('IntersectionObserver' in window) {
      new IntersectionObserver(function(entries) {
        var e = entries[0];
        // Show only after the buy box has scrolled up out of view (not while it's still below the fold)
        var passed = !e.isIntersecting && e.boundingClientRect.top < 0;
        bar.classList.toggle('is-visible', passed);
      }, { threshold: 0 }).observe(mainBtn);
    }
    // Keep the sticky price in sync with the main price (variant/plan changes rewrite #atc-price)
    var priceSrc = document.getElementById('atc-price');
    var priceDst = document.getElementById('pdp-sticky-price');
    if (priceSrc && priceDst && 'MutationObserver' in window) {
      new MutationObserver(function() { priceDst.textContent = priceSrc.textContent; })
        .observe(priceSrc, { childList: true, characterData: true, subtree: true });
    }
  })();
</script>
{%- endif -%}

