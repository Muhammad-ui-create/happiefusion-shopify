  background: var(--green, #52B788);
  color: #fff;
  transform: rotate(180deg);
}

.faq-answer {
  padding: 0 24px 20px;
  border-top: 1px solid rgba(82,183,136,0.12);
}
.faq-answer p {
  font-size: 15px; color: #555;
  line-height: 1.8; margin: 16px 0 0;
}
.faq-answer strong { color: #222; }

/* Contact CTA */
.faq-contact {
  padding: 60px 24px 80px;
  background: var(--cream, #F5F0E8);
  text-align: center;
}
.faq-contact-card {
  max-width: 520px; margin: 0 auto;
  background: #fff;
  border: 1px solid rgba(0,0,0,0.07);
  border-radius: 28px;
  padding: 48px 40px;
  box-shadow: 0 8px 40px rgba(0,0,0,0.06);
}
.faq-contact-icon {
  width: 60px; height: 60px; border-radius: 18px;
  background: linear-gradient(135deg, #D8F3DC, #B7E4C7);
  color: var(--green-dark, #2D6A4F);
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 20px;
}
.faq-contact-card h2 {
  font-size: 24px; font-weight: 900;
  color: #111; margin: 0 0 10px;
}
.faq-contact-card p {
  font-size: 15px; color: #777;
  line-height: 1.6; margin: 0 0 28px;
}
.faq-contact-btn {
  display: inline-block;
  background: var(--green-dark, #2D6A4F);
  color: #fff; border-radius: 50px;
  padding: 14px 36px;
  font-size: 15px; font-weight: 700;
  text-decoration: none;
  transition: background 0.2s, transform 0.2s;
}
.faq-contact-btn:hover {
  background: var(--green, #52B788);
  transform: translateY(-2px);
}

/* Reduced motion */
@media (prefers-reduced-motion: reduce) {
  .faq-chevron, .faq-item, .faq-contact-btn { transition: none; }
}

/* Mobile */
@media (max-width: 640px) {
  .faq-hero { padding: 80px 20px 60px; }
  .faq-hero-title { font-size: 32px; }
  .faq-content { padding: 52px 16px; }
  .faq-question { padding: 16px 18px; }
  .faq-answer { padding: 0 18px 16px; }
  .faq-group-header { flex-wrap: wrap; }
  .faq-contact-card { padding: 32px 24px; }
}

/* Step-by-step lists inside FAQ answers (HowTo schema) */
.howto-steps {
  list-style: none;
  counter-reset: howto;
  padding: 0;
  margin: 14px 0 4px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.howto-steps li {
  counter-increment: howto;
  position: relative;
  padding: 12px 14px 12px 48px;
  background: rgba(45,106,79,0.04);
  border-left: 3px solid var(--green, #2D6A4F);
  border-radius: 8px;
  font-size: 14.5px;
  line-height: 1.6;
}
.howto-steps li::before {
  content: counter(howto);
  position: absolute;
  left: 12px; top: 12px;
  width: 26px; height: 26px;
  border-radius: 50%;
  background: var(--green, #2D6A4F);
  color: #fff;
  font-size: 13px;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}
.howto-steps li strong { color: var(--ink, #1A1A1A); }
</style>

