<div class="inner-page">

  <div style="background:linear-gradient(135deg,#f5f0e8 0%,#d8f3dc 100%);padding:90px 48px;text-align:center;">
    <div style="max-width:700px;margin:0 auto;">
      <div style="font-size:11px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#2D6A4F;margin-bottom:14px;">Get in Touch</div>
      <h1 style="font-size:clamp(34px,5vw,56px);font-weight:900;line-height:1.05;margin:0 0 18px;">We're Real People.<br>We Actually Respond.</h1>
      <p style="color:#6B6B6B;font-size:17px;line-height:1.65;max-width:480px;margin:0 auto;">Questions about your order, our products, or just want to say hi? We respond within 1 business day.</p>
    </div>
  </div>

  <section style="padding:80px 48px;background:#fff;">
    <div style="max-width:1000px;margin:0 auto;display:grid;grid-template-columns:1fr 1.4fr;gap:72px;align-items:start;">

      <!-- Left: Info -->
      <div>
        <h2 style="font-size:22px;font-weight:900;margin-bottom:24px;">Contact Info</h2>

        <div style="display:flex;flex-direction:column;gap:20px;margin-bottom:40px;">
          <div style="display:flex;gap:16px;align-items:flex-start;">
            <div style="width:44px;height:44px;background:var(--green-light);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;">📧</div>
            <div>
              <div style="font-weight:700;font-size:15px;margin-bottom:4px;">Email</div>
              <a href="mailto:support@happiefusion.com" style="color:var(--green);font-size:15px;">support@happiefusion.com</a>
              <div style="font-size:13px;color:var(--gray);margin-top:2px;">Response within 1 business day</div>
            </div>
          </div>

          <div style="display:flex;gap:16px;align-items:flex-start;">
            <div style="width:44px;height:44px;background:var(--green-light);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;">📍</div>
            <div>
              <div style="font-weight:700;font-size:15px;margin-bottom:4px;">Based In</div>
              <div style="font-size:15px;color:#444;">Northern California, USA</div>
              <div style="font-size:13px;color:var(--gray);margin-top:2px;">Shipping from NorCal warehouse</div>
            </div>
          </div>

          <div style="display:flex;gap:16px;align-items:flex-start;">
            <div style="width:44px;height:44px;background:var(--green-light);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;">🕐</div>
            <div>
              <div style="font-weight:700;font-size:15px;margin-bottom:4px;">Support Hours</div>
              <div style="font-size:15px;color:#444;">Monday – Friday</div>
              <div style="font-size:13px;color:var(--gray);margin-top:2px;">9am – 5pm PST</div>
            </div>
          </div>
        </div>

        <div style="background:var(--cream);border-radius:20px;padding:24px;">
          <h3 style="font-size:16px;font-weight:800;margin-bottom:16px;">Quick links</h3>
          <div style="display:flex;flex-direction:column;gap:10px;">
            <a href="/pages/faq" style="font-size:14px;color:var(--green);font-weight:600;display:flex;align-items:center;gap:8px;">📋 View FAQ →</a>
            <a href="/policies/shipping-policy" style="font-size:14px;color:var(--green);font-weight:600;display:flex;align-items:center;gap:8px;">🚚 Shipping Policy →</a>
            <a href="/policies/refund-policy" style="font-size:14px;color:var(--green);font-weight:600;display:flex;align-items:center;gap:8px;">↩️ Returns & Refunds →</a>
            <a href="/collections/all" style="font-size:14px;color:var(--green);font-weight:600;display:flex;align-items:center;gap:8px;">🛍️ Shop Now →</a>
          </div>
        </div>
      </div>

      <!-- Right: Contact form -->
      <div>
        <h2 style="font-size:22px;font-weight:900;margin-bottom:24px;">Send Us a Message</h2>
        {% form 'contact' %}
          {% if form.posted_successfully? %}
            <div style="background:var(--green-light);border-radius:16px;padding:24px;text-align:center;border:2px solid var(--green);">
              <div style="font-size:32px;margin-bottom:10px;">✅</div>
              <h3 style="font-size:18px;font-weight:800;color:var(--green-dark);margin-bottom:8px;">Message sent!</h3>
              <p style="color:var(--green-dark);font-size:15px;">Thanks for reaching out. We'll get back to you within 1 business day.</p>
            </div>
          {% else %}
            {% if form.errors %}
              <div style="background:#fff0f0;border-radius:12px;padding:16px;margin-bottom:20px;border:1px solid #f5a5a5;font-size:14px;color:#c0392b;">
                {{ form.errors | default_errors }}
              </div>
            {% endif %}

            <div style="display:flex;flex-direction:column;gap:18px;">
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                <div>
                  <label style="display:block;font-size:13px;font-weight:700;margin-bottom:6px;color:#444;">First Name</label>
                  <input type="text" name="contact[first_name]" placeholder="Jamie" style="width:100%;padding:13px 16px;border:2px solid rgba(0,0,0,0.12);border-radius:12px;font-size:15px;font-family:inherit;outline:none;transition:border-color 0.15s;" onfocus="this.style.borderColor='#2D6A4F'" onblur="this.style.borderColor='rgba(0,0,0,0.12)'" />
                </div>
                <div>
                  <label style="display:block;font-size:13px;font-weight:700;margin-bottom:6px;color:#444;">Last Name</label>
                  <input type="text" name="contact[last_name]" placeholder="Smith" style="width:100%;padding:13px 16px;border:2px solid rgba(0,0,0,0.12);border-radius:12px;font-size:15px;font-family:inherit;outline:none;transition:border-color 0.15s;" onfocus="this.style.borderColor='#2D6A4F'" onblur="this.style.borderColor='rgba(0,0,0,0.12)'" />
                </div>
              </div>

              <div>
                <label style="display:block;font-size:13px;font-weight:700;margin-bottom:6px;color:#444;">Email <span style="color:#e74c3c;">*</span></label>
                <input type="email" name="contact[email]" required placeholder="you@example.com" style="width:100%;padding:13px 16px;border:2px solid rgba(0,0,0,0.12);border-radius:12px;font-size:15px;font-family:inherit;outline:none;transition:border-color 0.15s;" onfocus="this.style.borderColor='#2D6A4F'" onblur="this.style.borderColor='rgba(0,0,0,0.12)'" />
              </div>

              <div>
                <label style="display:block;font-size:13px;font-weight:700;margin-bottom:6px;color:#444;">Subject</label>
                <select name="contact[subject]" style="width:100%;padding:13px 16px;border:2px solid rgba(0,0,0,0.12);border-radius:12px;font-size:15px;font-family:inherit;outline:none;background:#fff;cursor:pointer;">
                  <option value="">Select a topic...</option>
                  <option value="Order & Shipping">Order &amp; Shipping</option>
                  <option value="Subscription Help">Subscription Help</option>
                  <option value="Product Question">Product Question</option>
                  <option value="Returns & Refunds">Returns &amp; Refunds</option>
                  <option value="Wholesale Inquiry">Wholesale Inquiry</option>
                  <option value="Other">Other</option>
                </select>
              </div>

              <div>
                <label style="display:block;font-size:13px;font-weight:700;margin-bottom:6px;color:#444;">Message <span style="color:#e74c3c;">*</span></label>
                <textarea name="contact[body]" required rows="5" placeholder="Tell us how we can help..." style="width:100%;padding:13px 16px;border:2px solid rgba(0,0,0,0.12);border-radius:12px;font-size:15px;font-family:inherit;outline:none;resize:vertical;transition:border-color 0.15s;" onfocus="this.style.borderColor='#2D6A4F'" onblur="this.style.borderColor='rgba(0,0,0,0.12)'"></textarea>
              </div>

              <button type="submit" style="background:var(--green);color:#fff;border-radius:12px;padding:16px 32px;font-size:16px;font-weight:800;width:100%;cursor:pointer;border:none;font-family:inherit;transition:background 0.15s;" onmouseover="this.style.background='#1B4332'" onmouseout="this.style.background='#2D6A4F'">
                Send Message →
              </button>
            </div>
          {% endif %}
        {% endform %}
      </div>
    </div>
  </section>

</div>

{% schema %}
{ "name": "Page: Contact", "settings": [] }
{% endschema %}
