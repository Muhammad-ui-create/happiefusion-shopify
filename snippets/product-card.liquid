{% comment %} Assign a background color per flavor handle {% endcomment %}
{% assign card_bg = '#6260AE' %}
{% if product.handle contains 'blue-razz' %}
  {% assign card_bg = '#3B6FF0' %}
{% elsif product.handle contains 'mango' %}
  {% assign card_bg = '#F5A623' %}
{% elsif product.handle contains 'watermelon' %}
  {% assign card_bg = '#E84C6B' %}
{% elsif product.handle contains 'variety' %}
  {% assign card_bg = '#52B788' %}
{% endif %}

<div class="product-card">

  <!-- Colored image panel -->
  <a href="{{ product.url }}" class="product-card-img-wrap" style="background:{{ card_bg }};">
    {% if product.tags contains 'bestseller' or product.tags contains 'top-seller' %}
      <span class="card-top-badge">TOP SELLER</span>
    {% endif %}
    {% if product.featured_image %}
      <img
        src="{{ product.featured_image | image_url: width: 600 }}"
        alt="{{ product.title }}"
        loading="lazy"
        class="product-card-img"
      />
    {% endif %}
  </a>

  <!-- Card body -->
  <div class="product-card-body">
    <h3 class="product-card-title">{{ product.title }}</h3>
    <p class="product-card-desc">{{ product.description | strip_html | truncate: 72 }}</p>

    <div class="product-card-pricing">
      <span class="starting-at-label">Starting At</span>
      <div class="product-card-price">{{ product.price_min | money }}</div>
    </div>

    <a href="{{ product.url }}" class="btn-shop-now">Shop Now</a>
  </div>

</div>
