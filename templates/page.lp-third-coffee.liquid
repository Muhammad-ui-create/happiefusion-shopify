{% layout none %}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Quit the Coffee Crash — Happie Fungi Fusion Blue Razzberry</title>
  <meta name="description" content="Cup three is asking too much. 900mg Lion's Mane + 700mg Cordyceps. Zero caffeine. Zero crash. Tastes like real fruit. 15% off — code WELCOME15.">
  <meta name="robots" content="noindex,nofollow">
  <link rel="icon" type="image/png" href="{{ 'happie-favicon.png' | asset_url }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --off-white:  #F7F8FB;
      --paper:      #FFFFFF;
      --ink:        #0E1226;
      --ink-2:      #2B3146;
      --ink-3:      #5C627A;
      --ink-4:      #9BA1B5;
      --razz:       #3B6FF0;
      --razz-dk:    #1B3B7A;
      --razz-deep:  #0B2347;
      --razz-pale:  #DFE9FE;
      --razz-bright:#5DCBF5;
      --coffee:     #6B4423;
      --coffee-lt:  #C9A572;
      --coffee-pale:#EFE5D2;
      --warn:       #C73E47;
      --good:       #22A87B;
      --gold:       #F5A623;
      --line:       rgba(14,18,38,0.08);
    }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Poppins', system-ui, -apple-system, sans-serif;
      background: var(--off-white);
      color: var(--ink);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }
    img { max-width: 100%; display: block; }
    a { text-decoration: none; color: inherit; }

    /* ── NAV — BIG LOGO ── */
    .lp-nav {
      position: sticky; top: 0; z-index: 100;
      padding: 14px 32px;
      display: flex; justify-content: space-between; align-items: center;
      background: rgba(247,248,251,0.94);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--line);
    }
    .lp-nav-logo img {
      height: 80px;
      width: auto;
      display: block;
    }
    .lp-nav-cta {
      background: var(--ink); color: var(--paper);
      border-radius: 50px; padding: 11px 24px;
      font-size: 13px; font-weight: 700; letter-spacing: 0.04em;
      transition: background 0.2s;
    }
    .lp-nav-cta:hover { background: var(--razz-dk); }

    /* ── HERO ── */
    .hero {
      padding: 80px 32px 90px;
      background:
        radial-gradient(ellipse at 75% 25%, rgba(59,111,240,0.12) 0%, transparent 60%),
        radial-gradient(ellipse at 15% 80%, rgba(93,203,245,0.1) 0%, transparent 55%),
        linear-gradient(180deg, var(--off-white) 0%, #EAF0FC 100%);
      position: relative; overflow: hidden;
    }
    .hero-inner {
      max-width: 1180px; margin: 0 auto;
      display: grid; grid-template-columns: 1.1fr 1fr;
      gap: 64px; align-items: center;
    }
    .hero-eyebrow {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--paper);
      border: 1.5px solid var(--line);
      color: var(--ink-2);
      font-size: 11px; font-weight: 700; letter-spacing: 0.16em;
      text-transform: uppercase;
      padding: 8px 18px; border-radius: 50px;
      margin-bottom: 24px;
    }
    .hero-eyebrow-dot {
      width: 7px; height: 7px; border-radius: 50%;
      background: var(--razz); animation: pulse 2s infinite;
    }
    @keyframes pulse { 0%,100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.5; transform: scale(1.2); } }

    .hero-headline {
      font-size: clamp(42px, 7vw, 86px);
      font-weight: 900; line-height: 0.98;
      color: var(--ink); margin-bottom: 22px;
      letter-spacing: -0.03em;
    }
    .hero-headline .crash {
      color: var(--razz-dk);
      position: relative; display: inline-block;
    }
    .hero-headline .crash::after {
      content: ''; position: absolute;
      left: 0; right: 0; bottom: 8px;
      height: 14px; background: var(--razz-bright);
      z-index: -1; opacity: 0.45;
    }
    .hero-sub {
      font-size: 19px; color: var(--ink-3);
      line-height: 1.6; margin-bottom: 32px;
      max-width: 480px;
    }
    .hero-sub strong { color: var(--ink); font-weight: 700; }
    .hero-sub em { font-style: normal; color: var(--razz-dk); font-weight: 600; }

    .hero-doses {
      display: flex; gap: 0;
      margin-bottom: 32px;
      padding: 22px 0;
      border-top: 1.5px solid var(--line);
      border-bottom: 1.5px solid var(--line);
    }
    .hero-dose {
      flex: 1; padding: 0 14px;
      text-align: center;
    }
    .hero-dose + .hero-dose { border-left: 1px solid var(--line); }
    .hero-dose-num {
      font-size: 22px; font-weight: 900;
      color: var(--ink); display: block;
      line-height: 1;
    }
    .hero-dose-name {
      font-size: 10px; letter-spacing: 0.12em;
      color: var(--ink-3); text-transform: uppercase;
      font-weight: 700; margin-top: 6px;
    }
    .hero-cta-stack {
      display: flex; flex-direction: column;
      gap: 14px; align-items: flex-start;
    }
    .btn-primary {
      display: inline-flex; align-items: center; gap: 10px;
      background: var(--ink); color: var(--paper);
      border-radius: 50px; padding: 17px 32px;
      font-family: 'Poppins', sans-serif;
      font-size: 15px; font-weight: 800;
      letter-spacing: 0.02em;
      transition: all 0.2s;
      box-shadow: 0 12px 28px rgba(14,18,38,0.18);
    }
    .btn-primary:hover { background: var(--razz-dk); transform: translateY(-2px); }
    .btn-primary svg { transition: transform 0.2s; }
    .btn-primary:hover svg { transform: translateX(3px); }
    .hero-code-row {
      display: flex; align-items: center; gap: 10px;
      font-size: 13px; color: var(--ink-3);
    }
    .hero-code-row strong {
      background: var(--razz); color: var(--paper);
      padding: 4px 10px; border-radius: 8px;
      font-weight: 800; letter-spacing: 0.06em;
      font-family: 'Poppins', monospace;
    }

    /* Hero visual */
    .hero-visual {
      position: relative;
      display: flex; justify-content: center; align-items: center;
      min-height: 500px;
    }
    .hero-can-wrap {
      position: relative;
      filter: drop-shadow(0 32px 50px rgba(59,111,240,0.3));
    }
    .hero-can-glow {
      position: absolute; inset: 0;
      background: radial-gradient(circle at center, rgba(59,111,240,0.32) 0%, transparent 65%);
      transform: scale(1.6);
    }
    .hero-can {
      width: 300px; max-width: 80vw; position: relative; z-index: 2;
    }
    /* Floating "cup 3" rejection card */
    .hero-cup-card {
      position: absolute; top: 30px; right: -25px;
      background: var(--paper);
      border: 1.5px solid var(--line);
      border-radius: 18px;
      padding: 14px 18px;
      box-shadow: 0 16px 36px rgba(14,18,38,0.12);
      transform: rotate(3deg);
      z-index: 3;
      display: flex; align-items: center; gap: 10px;
      max-width: 220px;
    }
    .hero-cup-icon {
      width: 36px; height: 36px; border-radius: 50%;
      background: var(--coffee-pale); color: var(--coffee);
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
      font-size: 20px;
      position: relative;
    }
    .hero-cup-icon::after {
      content: ''; position: absolute;
      width: 32px; height: 2px;
      background: var(--warn);
      transform: rotate(-45deg);
      top: 50%; left: 50%;
      margin-left: -16px; margin-top: -1px;
    }
    .hero-cup-text strong {
      display: block; font-size: 13px; font-weight: 800; color: var(--ink);
      line-height: 1.2; margin-bottom: 2px;
    }
    .hero-cup-text span {
      font-size: 11px; color: var(--ink-3);
      letter-spacing: 0.04em;
    }
    .hero-flavor-tag {
      position: absolute; bottom: 30px; left: -25px;
      background: var(--razz); color: var(--paper);
      padding: 9px 20px; border-radius: 50px;
      font-size: 12px; font-weight: 800; letter-spacing: 0.08em;
      text-transform: uppercase;
      transform: rotate(-4deg);
      box-shadow: 0 12px 28px rgba(59,111,240,0.4);
      z-index: 3;
    }

    /* ── "GAME CHANGER" CALLOUT ── */
    .game-section {
      padding: 100px 32px;
      background: var(--ink);
      color: var(--paper);
      position: relative; overflow: hidden;
    }
    .game-section::before {
      content: ''; position: absolute; inset: 0;
      background:
        radial-gradient(ellipse at 30% 30%, rgba(59,111,240,0.15) 0%, transparent 60%),
        radial-gradient(ellipse at 75% 70%, rgba(93,203,245,0.08) 0%, transparent 55%);
      pointer-events: none;
    }
    .game-inner {
      max-width: 920px; margin: 0 auto;
      text-align: center; position: relative;
    }
    .game-eyebrow {
      display: inline-block;
      font-size: 11px; font-weight: 800;
      letter-spacing: 0.16em; text-transform: uppercase;
      background: var(--razz); color: var(--paper);
      padding: 6px 16px; border-radius: 50px;
      margin-bottom: 22px;
    }
    .game-headline {
      font-size: clamp(34px, 5vw, 60px);
      font-weight: 900; line-height: 1.05;
      color: var(--paper); margin-bottom: 28px;
      letter-spacing: -0.02em;
    }
    .game-headline .quote-mark {
      color: var(--razz-bright);
      font-family: Georgia, serif;
      font-size: 1.2em; line-height: 0;
      position: relative; top: 0.1em;
    }
    .game-headline em {
      font-style: normal; color: var(--razz-bright);
    }
    .game-body {
      font-size: 18px; color: rgba(255,255,255,0.75);
      line-height: 1.7; max-width: 660px;
      margin: 0 auto;
    }
    .game-body strong { color: var(--paper); }

    /* ── COMPARE ── */
    .compare-section {
      padding: 100px 32px;
      background: var(--off-white);
    }
    .compare-inner { max-width: 1080px; margin: 0 auto; }
    .compare-header { text-align: center; margin-bottom: 56px; }
    .compare-eyebrow {
      font-size: 11px; font-weight: 800;
      letter-spacing: 0.16em; text-transform: uppercase;
      color: var(--razz); margin-bottom: 14px;
    }
    .compare-title {
      font-size: clamp(28px, 4vw, 44px);
      font-weight: 900; color: var(--ink);
      line-height: 1.15; letter-spacing: -0.02em;
    }
    .compare-title em { font-style: normal; color: var(--razz-dk); }
    .compare-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 22px;
    }
    .compare-col {
      background: var(--paper);
      border-radius: 24px;
      padding: 40px 32px;
      border: 1.5px solid var(--line);
      position: relative;
    }
    .compare-col.bad {
      background: linear-gradient(165deg, #F3E9D9, #E8DAB8);
      border-color: rgba(107,68,35,0.2);
    }
    .compare-col.good {
      background: linear-gradient(165deg, var(--paper), var(--razz-pale));
      border: 2.5px solid var(--razz);
      box-shadow: 0 20px 50px rgba(59,111,240,0.15);
    }
    .compare-col.good::after {
      content: 'CUP THREE ALTERNATIVE';
      position: absolute; top: -12px; right: 20px;
      background: var(--ink); color: var(--razz-bright);
      padding: 5px 14px; border-radius: 50px;
      font-size: 10px; font-weight: 900; letter-spacing: 0.14em;
    }
    .compare-col-tag {
      display: inline-block;
      font-size: 10px; font-weight: 800; letter-spacing: 0.18em;
      text-transform: uppercase; padding: 6px 14px; border-radius: 50px;
      margin-bottom: 18px;
    }
    .compare-col.bad .compare-col-tag { background: rgba(107,68,35,0.15); color: var(--coffee); }
    .compare-col.good .compare-col-tag { background: var(--razz); color: var(--paper); }
    .compare-col h3 {
      font-size: 24px; font-weight: 900;
      color: var(--ink); margin-bottom: 22px;
      line-height: 1.2;
    }
    .compare-list { list-style: none; padding: 0; }
    .compare-list li {
      display: flex; align-items: flex-start; gap: 12px;
      font-size: 15px; color: var(--ink-2);
      line-height: 1.55;
      padding: 12px 0;
      border-bottom: 1px solid var(--line);
    }
    .compare-list li:last-child { border-bottom: none; }
    .compare-list li svg { flex-shrink: 0; margin-top: 2px; }
    .compare-col.bad .compare-list svg { stroke: var(--coffee); }
    .compare-col.good .compare-list svg { stroke: var(--good); }

    /* ── THE SCIENCE / SUSTAINED FOCUS ── */
    .science-section {
      padding: 100px 32px;
      background: linear-gradient(180deg, var(--off-white) 0%, #EAF0FC 100%);
    }
    .science-inner {
      max-width: 1080px; margin: 0 auto;
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 64px; align-items: center;
    }
    .science-text h2 {
      font-size: clamp(28px, 4vw, 44px);
      font-weight: 900; color: var(--ink);
      line-height: 1.15; margin-bottom: 22px;
      letter-spacing: -0.02em;
    }
    .science-text h2 em { font-style: normal; color: var(--razz-dk); }
    .science-text p {
      font-size: 16px; color: var(--ink-3);
      line-height: 1.8; margin-bottom: 16px;
    }
    .science-text p strong { color: var(--ink); }

    .science-mush-stack {
      display: flex; flex-direction: column; gap: 14px;
      margin-top: 28px;
    }
    .science-mush-card {
      display: flex; align-items: center; gap: 18px;
      background: var(--paper);
      border-radius: 18px;
      padding: 18px 22px;
      border: 1px solid var(--line);
    }
    .science-mush-dose {
      font-size: 22px; font-weight: 900;
      color: var(--razz-dk); min-width: 70px;
    }
    .science-mush-info strong {
      display: block; font-size: 14px; color: var(--ink);
      font-weight: 800; margin-bottom: 2px;
    }
    .science-mush-info span {
      font-size: 13px; color: var(--ink-3); line-height: 1.5;
    }

    .science-visual {
      background: var(--ink);
      border-radius: 32px;
      padding: 56px 36px;
      text-align: center;
      position: relative; overflow: hidden;
      color: var(--paper);
    }
    .science-visual::before {
      content: ''; position: absolute; inset: 0;
      background: radial-gradient(ellipse at center, rgba(59,111,240,0.25) 0%, transparent 65%);
    }
    .science-big-num {
      font-size: 110px; font-weight: 900;
      color: var(--paper); line-height: 1;
      margin-bottom: 6px; letter-spacing: -0.04em;
      position: relative;
    }
    .science-big-num .mg {
      font-size: 28px; color: var(--razz-bright);
      vertical-align: super;
    }
    .science-big-label {
      font-size: 12px; letter-spacing: 0.18em;
      text-transform: uppercase; color: rgba(255,255,255,0.55);
      margin-bottom: 24px; position: relative;
      font-weight: 700;
    }
    .science-divider {
      width: 50px; height: 1px; background: var(--razz-bright);
      margin: 0 auto 20px; position: relative;
    }
    .science-blurb {
      font-size: 15px; color: rgba(255,255,255,0.75);
      line-height: 1.6; max-width: 280px; margin: 0 auto;
      position: relative;
    }

    /* ── REVIEWS ── */
    .reviews-section {
      padding: 100px 32px;
      background: var(--off-white);
      border-top: 1px solid var(--line);
    }
    .reviews-inner { max-width: 1080px; margin: 0 auto; }
    .reviews-header { text-align: center; margin-bottom: 48px; }
    .reviews-eyebrow {
      font-size: 11px; font-weight: 800;
      letter-spacing: 0.16em; text-transform: uppercase;
      color: var(--razz); margin-bottom: 12px;
    }
    .reviews-title {
      font-size: clamp(28px, 4vw, 42px);
      font-weight: 900; color: var(--ink);
      line-height: 1.15; letter-spacing: -0.02em;
    }
    .reviews-title em { font-style: normal; color: var(--razz-dk); }
    .reviews-grid {
      display: grid; grid-template-columns: repeat(3,1fr); gap: 20px;
    }
    .review-card {
      background: var(--paper);
      border: 1.5px solid var(--line);
      border-radius: 20px;
      padding: 28px 26px;
    }
    .review-stars {
      color: var(--gold); font-size: 14px; letter-spacing: 1px;
      margin-bottom: 14px;
    }
    .review-title {
      font-size: 16px; font-weight: 800;
      color: var(--ink); margin-bottom: 10px;
    }
    .review-body {
      font-size: 14px; color: var(--ink-3);
      line-height: 1.7; margin-bottom: 18px;
    }
    .review-by {
      display: flex; align-items: center; gap: 7px;
      font-size: 11px; color: var(--ink-4);
      font-weight: 700; letter-spacing: 0.06em;
      text-transform: uppercase;
      padding-top: 14px;
      border-top: 1px solid var(--line);
    }
    .review-by svg { fill: var(--gold); }

    /* ── TRUST BAR ── */
    .trust-section {
      padding: 50px 32px;
      background: var(--razz-deep);
      color: var(--paper);
    }
    .trust-inner {
      max-width: 1000px; margin: 0 auto;
      display: grid; grid-template-columns: repeat(4,1fr); gap: 0;
      text-align: center;
    }
    .trust-item { padding: 0 16px; }
    .trust-item + .trust-item { border-left: 1px solid rgba(255,255,255,0.12); }
    .trust-item svg { stroke: var(--razz-bright); margin-bottom: 10px; }
    .trust-item strong { display: block; font-size: 13px; margin-bottom: 4px; font-weight: 800; }
    .trust-item span { font-size: 11px; color: rgba(255,255,255,0.6); }

    /* ── FINAL CTA ── */
    .final-cta {
      padding: 120px 32px;
      background:
        radial-gradient(ellipse at center, rgba(59,111,240,0.14) 0%, transparent 60%),
        linear-gradient(180deg, var(--off-white) 0%, #EAF0FC 100%);
      text-align: center;
    }
    .final-cta-inner { max-width: 680px; margin: 0 auto; }
    .final-cta h2 {
      font-size: clamp(34px, 5vw, 58px);
      font-weight: 900; color: var(--ink);
      line-height: 1.05; letter-spacing: -0.025em;
      margin-bottom: 22px;
    }
    .final-cta h2 em {
      font-style: normal; color: var(--razz-dk);
      position: relative; display: inline-block;
    }
    .final-cta h2 em::after {
      content: ''; position: absolute;
      left: 0; right: 0; bottom: 6px;
      height: 12px; background: var(--razz-bright);
      z-index: -1; opacity: 0.4;
    }
    .final-cta p {
      font-size: 17px; color: var(--ink-3);
      line-height: 1.7; margin-bottom: 36px;
      max-width: 480px; margin-left: auto; margin-right: auto;
    }
    .final-cta-row {
      display: flex; justify-content: center; gap: 16px;
      flex-wrap: wrap; align-items: center;
    }
    .disclaimer {
      font-size: 11px; color: var(--ink-4);
      max-width: 560px; margin: 40px auto 0;
      line-height: 1.6;
    }

    /* ── FOOTER ── */
    .lp-footer {
      padding: 28px 32px;
      background: var(--ink);
      color: rgba(255,255,255,0.55);
      display: flex; justify-content: space-between; align-items: center;
      font-size: 12px;
    }
    .lp-footer-links { display: flex; gap: 22px; }
    .lp-footer-links a:hover { color: var(--paper); }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
      .lp-nav-logo img { height: 60px; }
      .hero-inner, .compare-grid, .science-inner, .reviews-grid {
        grid-template-columns: 1fr;
      }
      .hero { padding: 60px 22px 70px; }
      .hero-visual { order: -1; min-height: 400px; }
      .hero-can { width: 230px; }
      .reviews-grid { max-width: 460px; margin-left: auto; margin-right: auto; }
      .trust-inner { grid-template-columns: repeat(2,1fr); gap: 24px; }
      .trust-item + .trust-item { border-left: none; }
      .trust-item:nth-child(odd) { border-right: 1px solid rgba(255,255,255,0.12); }
      .lp-footer { flex-direction: column; gap: 14px; text-align: center; }
      section { padding-left: 20px !important; padding-right: 20px !important; }
    }
  </style>
</head>
<body>

  {%- comment -%} Auto-apply WELCOME15 + redirect to Blue Razzberry product page {%- endcomment -%}
  {%- assign cta_url = '/discount/WELCOME15?redirect=/products/blue-razzberry-fungi-powered-seltzer' -%}

  <!-- NAV — Big logo -->
  <nav class="lp-nav">
    <a href="/" class="lp-nav-logo"><img src="{{ 'happie-logo.png' | asset_url }}" alt="Happie Fusion"></a>
    <a href="{{ cta_url }}" class="lp-nav-cta">Try Blue Razz — 15% Off →</a>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-text">
        <div class="hero-eyebrow">
          <span class="hero-eyebrow-dot"></span>
          The Coffee Switcher · Blue Razzberry
        </div>
        <h1 class="hero-headline">Quit the coffee <span class="crash">crash.</span></h1>
        <p class="hero-sub"><em>Cup three is asking too much.</em> Three real mushrooms — <strong>900mg Lion's Mane + 700mg Cordyceps + 400mg Reishi</strong> — for sustained focus with zero caffeine, zero crash. Tastes like real fruit.</p>
        <div class="hero-doses">
          <div class="hero-dose">
            <span class="hero-dose-num">900mg</span>
            <div class="hero-dose-name">Lion's Mane</div>
          </div>
          <div class="hero-dose">
            <span class="hero-dose-num">700mg</span>
