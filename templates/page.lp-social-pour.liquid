<style>
/* ============================================================
   LANDING PAGE — AS01-A1-2: SOCIAL POUR
   "Looks like a cocktail. Holds like one."
   utm_campaign=FF_ColdAcquisition_Q2 | utm_content=AS01_SocialPour
   ============================================================ */

.lp-sp {
  --sp-dark:    #1A1710;
  --sp-warm:    #2C2415;
  --sp-moss:    #3B4A2F;
  --sp-gold:    #C9A84C;
  --sp-champagne: #F5E6C0;
  --sp-cream:   #FFFDF5;
  --sp-teal:    #1ABC9C;
  --sp-amber:   #D4841A;
  font-family: 'Inter', 'Helvetica Neue', Arial, sans-serif;
}

/* HERO */
.sp-hero {
  position: relative;
  min-height: 100svh;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: var(--sp-warm);
  text-align: center;
  padding: 120px 24px 80px;
}
.sp-hero-bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 70% 60% at 50% 20%, rgba(201,168,76,0.25) 0%, transparent 65%),
    radial-gradient(ellipse 50% 40% at 80% 70%, rgba(59,74,47,0.3) 0%, transparent 60%),
    linear-gradient(165deg, #1A1710 0%, #2C2415 45%, #1E1C10 100%);
  z-index: 0;
}
.sp-hero-bg::before, .sp-hero-bg::after {
  content: '';
  position: absolute;
  border-radius: 50%;
  filter: blur(90px);
  animation: sp-float 9s ease-in-out infinite alternate;
}
.sp-hero-bg::before { width:360px; height:360px; background:rgba(201,168,76,0.18); top:5%; right:15%; }
.sp-hero-bg::after  { width:280px; height:280px; background:rgba(59,74,47,0.25); bottom:10%; left:10%; animation-delay:4s; }
@keyframes sp-float { from { transform:translateY(0) scale(1); } to { transform:translateY(-28px) scale(1.06); } }

.sp-hero-inner { position:relative; z-index:1; max-width:820px; margin:0 auto; }

.sp-eyebrow {
  display:inline-flex; align-items:center; gap:8px;
  background:rgba(201,168,76,0.15); border:1px solid rgba(201,168,76,0.4);
  border-radius:50px; padding:6px 18px;
  font-size:11px; font-weight:700; letter-spacing:0.14em; text-transform:uppercase;
  color:#E8D48A; margin-bottom:28px;
}
.sp-hero-headline {
  font-size:clamp(38px,6.5vw,82px); font-weight:900; line-height:1.04;
  letter-spacing:-0.03em; color:var(--sp-champagne); margin:0 0 22px;
}
.sp-hero-headline em {
  font-style:normal;
  background:linear-gradient(135deg, #C9A84C 0%, #F0D080 50%, #C9A84C 100%);
  -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
}
.sp-hero-sub {
  font-size:clamp(16px,2.2vw,21px); line-height:1.6;
  color:rgba(245,230,192,0.65); max-width:600px; margin:0 auto 42px;
}
.sp-hero-sub strong { color:rgba(245,230,192,0.9); font-weight:600; }

.sp-cta-group { display:flex; align-items:center; justify-content:center; gap:16px; flex-wrap:wrap; }

.sp-btn-primary {
  display:inline-flex; align-items:center; gap:8px;
  background:var(--sp-gold); color:#1A1710; font-weight:800; font-size:15px;
  letter-spacing:0.04em; padding:16px 36px; border-radius:50px; text-decoration:none;
  transition:transform 0.3s cubic-bezier(0.16,1,0.3,1), box-shadow 0.3s cubic-bezier(0.16,1,0.3,1);
  box-shadow:0 8px 32px rgba(201,168,76,0.45);
}
.sp-btn-primary:hover { transform:translateY(-3px) scale(1.03); box-shadow:0 16px 48px rgba(201,168,76,0.55); }

.sp-btn-secondary {
  display:inline-flex; align-items:center; gap:8px;
  background:transparent; color:rgba(245,230,192,0.6); font-size:14px; font-weight:600;
  padding:16px 24px; border-radius:50px; border:1px solid rgba(245,230,192,0.15); text-decoration:none;
  transition:all 0.25s ease;
}
.sp-btn-secondary:hover { color:var(--sp-champagne); border-color:rgba(245,230,192,0.35); }

.sp-hero-discount { margin-top:20px; font-size:13px; color:var(--sp-gold); font-weight:600; letter-spacing:0.04em; }

.sp-hero-visual { margin-top:56px; position:relative; display:inline-block; }
.sp-hero-visual img {
  width:min(280px,65vw); height:auto;
  filter:drop-shadow(0 40px 80px rgba(201,168,76,0.4));
  animation:sp-pour-float 5s ease-in-out infinite;
}
@keyframes sp-pour-float {
  0%,100% { transform:translateY(0) rotate(1deg); }
  50%      { transform:translateY(-16px) rotate(-1deg); }
}

/* SOCIAL PROOF STRIP */
.sp-strip {
  background:var(--sp-gold);
  padding:14px 24px;
  text-align:center;
  font-size:13px; font-weight:700; letter-spacing:0.08em; color:#1A1710;
  text-transform:uppercase;
}

/* PROBLEM */
.sp-problem {
  background:var(--sp-cream);
  padding:88px 24px;
  text-align:center;
}
.sp-section-label { font-size:11px; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; color:var(--sp-moss); margin-bottom:14px; }
.sp-problem-headline { font-size:clamp(26px,4vw,50px); font-weight:900; letter-spacing:-0.025em; color:var(--sp-dark); max-width:720px; margin:0 auto 20px; line-height:1.08; }
.sp-problem-body { font-size:17px; line-height:1.7; color:#555; max-width:580px; margin:0 auto 52px; }

.sp-awkward-cards {
  display:grid; grid-template-columns:repeat(3,1fr); gap:20px;
  max-width:920px; margin:0 auto;
}
.sp-awk-card {
  background:#fff; border-radius:18px; padding:28px 22px;
  border:1px solid rgba(0,0,0,0.07); box-shadow:0 2px 16px rgba(0,0,0,0.04);
  text-align:left;
}
.sp-awk-card .awk-icon { font-size:28px; margin-bottom:12px; }
.sp-awk-card h3 { font-size:15px; font-weight:800; color:var(--sp-dark); margin:0 0 8px; }
.sp-awk-card p { font-size:13px; color:#777; line-height:1.55; margin:0; }

/* SOLUTION */
.sp-solution {
  background:var(--sp-warm);
  padding:100px 24px;
  text-align:center;
}
.sp-solution-label { font-size:11px; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; color:var(--sp-gold); margin-bottom:16px; }
.sp-solution-headline { font-size:clamp(28px,4.5vw,58px); font-weight:900; letter-spacing:-0.03em; color:var(--sp-champagne); max-width:740px; margin:0 auto 20px; line-height:1.05; }
.sp-solution-sub { font-size:17px; color:rgba(245,230,192,0.6); max-width:560px; margin:0 auto 60px; line-height:1.65; }

.sp-cans-row { display:flex; align-items:flex-end; justify-content:center; gap:32px; margin-bottom:48px; flex-wrap:wrap; }
.sp-can-item { display:flex; flex-direction:column; align-items:center; gap:12px; }
.sp-can-item img { width:min(140px,28vw); height:auto; filter:drop-shadow(0 20px 40px rgba(0,0,0,0.5)); transition:transform 0.4s cubic-bezier(0.16,1,0.3,1); }
.sp-can-item:hover img { transform:translateY(-10px) scale(1.06); }
.sp-can-label { font-size:12px; font-weight:700; letter-spacing:0.05em; text-transform:uppercase; color:rgba(245,230,192,0.5); }

.sp-offer-pill {
  display:inline-flex; flex-direction:column; align-items:center;
  background:rgba(201,168,76,0.12); border:1px solid rgba(201,168,76,0.4);
  border-radius:16px; padding:20px 40px; margin-bottom:32px; gap:4px;
}
.sp-offer-pill .offer-main { font-size:20px; font-weight:900; color:var(--sp-gold); }
.sp-offer-pill .offer-sub { font-size:13px; color:rgba(245,230,192,0.5); }
.sp-offer-pill .offer-code { font-size:12px; font-weight:700; color:var(--sp-gold); letter-spacing:0.12em; background:rgba(201,168,76,0.15); border-radius:6px; padding:3px 10px; margin-top:6px; text-transform:uppercase; }

/* LION'S MANE SPOTLIGHT */
.sp-lionsmane {
  background:var(--sp-cream);
  padding:100px 24px;
}
.sp-lm-inner { max-width:1100px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; gap:80px; align-items:center; }
.sp-lm-visual { display:flex; align-items:center; justify-content:center; }
.sp-lm-circle {
  width:min(360px,90%); aspect-ratio:1; border-radius:50%;
  background:radial-gradient(ellipse at 40% 35%, #3B4A2F, #1A1710);
  display:flex; align-items:center; justify-content:center;
  box-shadow:0 40px 100px rgba(59,74,47,0.3);
  position:relative;
}
.sp-lm-circle img { width:72%; height:auto; filter:drop-shadow(0 20px 40px rgba(0,0,0,0.5)); }
.sp-lm-float-badge {
  position:absolute; background:#fff; border-radius:14px; padding:12px 18px;
  box-shadow:0 8px 30px rgba(0,0,0,0.12); display:flex; align-items:center; gap:10px;
  font-size:13px; font-weight:700; color:var(--sp-dark); white-space:nowrap;
}
.sp-lm-float-badge span { font-size:20px; font-weight:900; color:var(--sp-moss); }
.sp-lm-float-badge:first-of-type { top:8%; right:-6%; }
.sp-lm-float-badge:last-of-type  { bottom:10%; left:-4%; }

.sp-lm-content .sp-section-label { color:var(--sp-moss); }
.sp-lm-headline { font-size:clamp(26px,3.5vw,44px); font-weight:900; letter-spacing:-0.025em; color:var(--sp-dark); margin:0 0 20px; line-height:1.1; }
.sp-lm-body { font-size:16px; line-height:1.75; color:#555; margin-bottom:36px; }

.sp-benefit-list { list-style:none; padding:0; margin:0 0 40px; display:flex; flex-direction:column; gap:14px; }
.sp-benefit-list li { display:flex; align-items:flex-start; gap:12px; font-size:15px; color:#333; line-height:1.5; }
.sp-benefit-check { flex-shrink:0; width:22px; height:22px; border-radius:50%; background:var(--sp-moss); display:flex; align-items:center; justify-content:center; margin-top:1px; }

.sp-dosage-box { display:flex; align-items:center; gap:14px; background:rgba(59,74,47,0.08); border:1px solid rgba(59,74,47,0.2); border-radius:14px; padding:16px 22px; width:fit-content; }
.sp-dosage-num { font-size:32px; font-weight:900; color:var(--sp-moss); line-height:1; }
.sp-dosage-label { font-size:12px; font-weight:700; color:#888; text-transform:uppercase; letter-spacing:0.08em; line-height:1.4; }

/* COCKTAIL LOOK */
.sp-cocktail {
  background:var(--sp-dark);
  padding:100px 24px;
  text-align:center;
}
.sp-cocktail-headline { font-size:clamp(28px,4.5vw,56px); font-weight:900; letter-spacing:-0.03em; color:var(--sp-champagne); max-width:720px; margin:0 auto 16px; line-height:1.05; }
.sp-cocktail-sub { font-size:17px; color:rgba(245,230,192,0.5); max-width:540px; margin:0 auto 56px; }

.sp-compare-grid { display:grid; grid-template-columns:1fr auto 1fr; gap:24px; max-width:880px; margin:0 auto 48px; align-items:center; }
.sp-compare-col { background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); border-radius:22px; padding:30px 22px; }
.sp-compare-col.is-happie { background:rgba(201,168,76,0.1); border-color:rgba(201,168,76,0.35); box-shadow:0 0 60px rgba(201,168,76,0.15); }
.sp-col-label { font-size:11px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; margin-bottom:18px; color:rgba(255,255,255,0.4); }
.sp-compare-col.is-happie .sp-col-label { color:#E8D48A; }
.sp-col-name { font-size:20px; font-weight:900; color:#fff; margin-bottom:22px; }
.sp-compare-col.is-happie .sp-col-name { color:var(--sp-champagne); }
.sp-col-items { list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:11px; }
.sp-col-items li { display:flex; align-items:center; gap:10px; font-size:14px; color:rgba(255,255,255,0.65); text-align:left; }
.sp-compare-vs { font-size:18px; font-weight:900; color:rgba(255,255,255,0.18); letter-spacing:0.1em; }

/* REVIEWS */
.sp-reviews {
  background:var(--sp-cream);
  padding:100px 24px;
  text-align:center;
}
.sp-reviews-headline { font-size:clamp(26px,3.5vw,44px); font-weight:900; letter-spacing:-0.025em; color:var(--sp-dark); margin:0 auto 48px; max-width:600px; line-height:1.1; }
.sp-reviews-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; max-width:1000px; margin:0 auto 48px; }
.sp-review-card { background:#fff; border-radius:20px; padding:28px; text-align:left; border:1px solid rgba(0,0,0,0.06); box-shadow:0 4px 24px rgba(0,0,0,0.05); position:relative; }
.sp-review-stars { display:flex; gap:3px; margin-bottom:14px; color:#C9A84C; }
.sp-review-text { font-size:14px; line-height:1.65; color:#444; margin-bottom:18px; font-style:italic; }
.sp-review-author { display:flex; align-items:center; gap:10px; }
.sp-review-avatar { width:38px; height:38px; border-radius:50%; background:linear-gradient(135deg,var(--sp-moss),var(--sp-gold)); display:flex; align-items:center; justify-content:center; font-weight:800; font-size:13px; color:#fff; flex-shrink:0; }
.sp-review-name { font-size:13px; font-weight:700; color:var(--sp-dark); }
.sp-review-tag { font-size:11px; color:#aaa; }
.sp-verified { position:absolute; top:20px; right:20px; background:rgba(59,74,47,0.1); border-radius:6px; padding:3px 8px; font-size:10px; font-weight:700; color:var(--sp-moss); letter-spacing:0.05em; text-transform:uppercase; }

/* TRUST BAR */
.sp-trust { background:#fff; padding:36px 24px; border-top:1px solid rgba(0,0,0,0.07); border-bottom:1px solid rgba(0,0,0,0.07); }
.sp-trust-inner { display:flex; align-items:center; justify-content:center; gap:44px; flex-wrap:wrap; max-width:900px; margin:0 auto; }
.sp-trust-item { display:flex; align-items:center; gap:10px; font-size:13px; font-weight:700; color:#444; }
.sp-trust-item svg { color:var(--sp-moss); flex-shrink:0; }

/* FINAL CTA */
.sp-final {
  background:var(--sp-warm);
  padding:120px 24px;
  text-align:center;
  position:relative;
  overflow:hidden;
}
.sp-final::before { content:''; position:absolute; width:700px; height:700px; border-radius:50%; background:radial-gradient(circle,rgba(201,168,76,0.2) 0%,transparent 70%); top:50%; left:50%; transform:translate(-50%,-50%); pointer-events:none; }
.sp-final-inner { position:relative; z-index:1; max-width:680px; margin:0 auto; }
.sp-final-label { font-size:11px; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; color:var(--sp-gold); margin-bottom:20px; }
.sp-final-headline { font-size:clamp(34px,5.5vw,68px); font-weight:900; letter-spacing:-0.03em; color:var(--sp-champagne); line-height:1.03; margin:0 0 20px; }
.sp-final-sub { font-size:17px; color:rgba(245,230,192,0.55); line-height:1.65; margin-bottom:36px; }
.sp-final-offer { display:inline-flex; align-items:center; gap:8px; background:rgba(201,168,76,0.12); border:1px solid rgba(201,168,76,0.35); border-radius:50px; padding:8px 22px; font-size:13px; font-weight:700; color:var(--sp-gold); margin-bottom:32px; }

/* MOBILE */
@media (max-width: 768px) {
  .sp-awkward-cards, .sp-reviews-grid { grid-template-columns:1fr; max-width:420px; margin-left:auto; margin-right:auto; }
  .sp-lm-inner { grid-template-columns:1fr; gap:48px; text-align:center; }
  .sp-lm-visual { order:-1; }
  .sp-benefit-list li { text-align:left; }
  .sp-dosage-box { margin:0 auto; }
  .sp-compare-grid { grid-template-columns:1fr; max-width:420px; margin-left:auto; margin-right:auto; }
  .sp-compare-vs { display:none; }
  .sp-lm-circle { width:min(260px,80vw); }
  .sp-lm-float-badge { display:none; }
}
@media (max-width: 480px) {
  .sp-hero { padding:100px 20px 60px; }
  .sp-btn-primary { font-size:14px; padding:14px 28px; }
  .sp-final { padding:80px 20px; }
  .sp-cans-row { gap:16px; }
  .sp-can-item img { width:min(100px,26vw); }
}
</style>

{% assign discount_code = 'WELCOME15' %}
