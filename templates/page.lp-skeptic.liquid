{% layout none %}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Mushroom coffee wasn't your thing? Try this instead — Happie Fungi Fusion</title>
  <meta name="description" content="Mushroom coffee turned a lot of us off. This is different. Three real mushrooms in a Blue Raspberry sparkling seltzer. 40 cal. No caffeine. No crash. 15% off your first order — code FUNGI15.">
  <meta name="robots" content="noindex,nofollow">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;0,6..72,700;1,6..72,500;1,6..72,600&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --off-white:  #F7F8FB;
      --white:      #FFFFFF;
      --ink:        #0F1419;
      --ink-2:      #1E2734;
      --ink-3:      #475569;
      --ink-4:      #94A3B8;
      --blue:       #3B6FF0;
      --blue-dk:    #1B3B7A;
      --blue-soft:  #DFE9FE;
      --blue-deep:  #0B2347;
      --razz:       #3B85F2;
      --razz-pale:  #E5EEFF;
      --coffee:     #8B6F47;
      --coffee-pale:#EFE5D6;
      --warn:       #DC7E3E;
      --good:       #22A87B;
      --line:       rgba(15,20,25,0.08);
    }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Inter', sans-serif;
      background: var(--off-white);
      color: var(--ink);
      line-height: 1.55;
      -webkit-font-smoothing: antialiased;
    }
    img { max-width: 100%; display: block; }
    a { text-decoration: none; color: inherit; }
    .editorial { font-family: 'Newsreader', Georgia, serif; }

    /* ── NAV ── */
    .lp-nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      padding: 12px 28px;
      display: flex; justify-content: space-between; align-items: center;
      background: rgba(247,248,251,0.92);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--line);
    }
    .lp-nav-logo img { height: 42px; width: auto; }
    .lp-nav-cta {
      background: var(--ink); color: var(--white);
      border-radius: 50px; padding: 9px 22px;
      font-size: 12px; font-weight: 700; letter-spacing: 0.04em;
      transition: background 0.2s;
    }
    .lp-nav-cta:hover { background: var(--blue-dk); }

    /* ── HERO ── */
    .hero {
      padding: 120px 28px 60px;
      background:
        radial-gradient(ellipse at 70% 30%, rgba(59,111,240,0.08) 0%, transparent 60%),
        linear-gradient(180deg, var(--off-white) 0%, #EEF2FB 100%);
      position: relative; overflow: hidden;
    }
    .hero-inner {
      max-width: 1180px; margin: 0 auto;
      display: grid; grid-template-columns: 1.1fr 1fr;
      gap: 64px; align-items: center;
    }
    .hero-eyebrow {
      display: inline-flex; align-items: center; gap: 7px;
      background: var(--white);
      border: 1px solid var(--line);
      color: var(--ink-3);
      font-size: 12px; font-weight: 600;
      padding: 7px 14px; border-radius: 50px;
      margin-bottom: 22px;
    }
    .hero-eyebrow .dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--good); animation: pulse 2s infinite;
    }
    @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.4; } }

    .hero-headline {
      font-family: 'Newsreader', serif;
      font-size: clamp(40px, 6.5vw, 78px);
      font-weight: 600; line-height: 1.0;
      color: var(--ink); margin-bottom: 22px;
      letter-spacing: -0.03em;
    }
    .hero-headline em {
      font-style: italic; color: var(--blue-dk); font-weight: 600;
    }
    .hero-body {
      font-size: 18px; color: var(--ink-3);
      line-height: 1.65; margin-bottom: 32px;
      max-width: 500px;
    }
    .hero-body strong { color: var(--ink); font-weight: 700; }

    .hero-cta-stack { display: flex; flex-direction: column; gap: 14px; max-width: 380px; }
    .btn-primary {
      display: inline-flex; align-items: center; justify-content: center; gap: 10px;
      background: var(--ink); color: var(--white);
      border-radius: 14px; padding: 18px 28px;
      font-size: 15px; font-weight: 800; letter-spacing: 0.01em;
      transition: all 0.2s;
      box-shadow: 0 8px 24px rgba(15,20,25,0.15);
    }
    .btn-primary:hover { background: var(--blue-dk); transform: translateY(-2px); }
    .btn-primary svg { transition: transform 0.2s; }
    .btn-primary:hover svg { transform: translateX(3px); }
    .hero-code-row {
      display: flex; align-items: center; gap: 10px;
      font-size: 13px; color: var(--ink-3);
    }
    .hero-code-row strong {
      font-family: 'Inter', monospace;
      background: var(--razz-pale); color: var(--blue-dk);
      padding: 4px 10px; border-radius: 8px;
      font-weight: 800; letter-spacing: 0.05em;
      border: 1px dashed var(--blue);
    }
    .hero-checkmarks {
      display: flex; gap: 24px; flex-wrap: wrap;
      margin-top: 20px;
      padding-top: 20px;
      border-top: 1px solid var(--line);
    }
    .hero-checkmark {
      display: flex; align-items: center; gap: 7px;
      font-size: 13px; font-weight: 600; color: var(--ink-2);
    }
    .hero-checkmark svg { stroke: var(--good); }

    /* Hero visual */
    .hero-visual {
      position: relative;
      display: flex; justify-content: center; align-items: center;
      min-height: 500px;
    }
    .hero-can-wrap {
      position: relative;
      filter: drop-shadow(0 30px 50px rgba(59,111,240,0.25));
    }
    .hero-can-glow {
      position: absolute; inset: 0;
      background: radial-gradient(circle at center, rgba(59,111,240,0.18) 0%, transparent 65%);
      transform: scale(1.7);
    }
    .hero-can {
      width: 280px; max-width: 75vw; position: relative; z-index: 2;
    }
    /* Floating skeptic-to-believer testimonial */
    .hero-floating-card {
      position: absolute; bottom: 30px; left: -10px;
      background: var(--white);
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 14px 18px;
      max-width: 240px;
      box-shadow: 0 16px 40px rgba(15,20,25,0.12);
      z-index: 3;
      transform: rotate(-2deg);
    }
    .hero-floating-stars {
      color: #F5A623; font-size: 12px; letter-spacing: 1px;
      margin-bottom: 6px;
    }
    .hero-floating-text {
      font-family: 'Newsreader', serif;
      font-size: 13px; font-style: italic;
      color: var(--ink-2); line-height: 1.5;
      margin-bottom: 8px;
    }
    .hero-floating-by {
      font-size: 11px; color: var(--ink-4);
      font-weight: 600;
    }
    .hero-flavor-pill {
      position: absolute; top: 30px; right: -10px;
      background: var(--blue); color: var(--white);
      padding: 8px 16px; border-radius: 50px;
      font-size: 11px; font-weight: 800; letter-spacing: 0.08em;
      text-transform: uppercase;
      transform: rotate(3deg);
      box-shadow: 0 8px 20px rgba(59,111,240,0.35);
      z-index: 3;
    }

    /* ── HONEST INTRO ── */
    .honest-section {
      padding: 100px 28px;
      background: var(--white);
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
    }
    .honest-inner { max-width: 720px; margin: 0 auto; text-align: center; }
    .honest-eyebrow {
      font-size: 11px; font-weight: 700; letter-spacing: 0.2em;
      text-transform: uppercase; color: var(--blue);
      margin-bottom: 14px;
    }
    .honest-title {
      font-family: 'Newsreader', serif;
      font-size: clamp(28px, 4vw, 44px);
      font-weight: 600; color: var(--ink);
      line-height: 1.15; margin-bottom: 24px;
      letter-spacing: -0.02em;
    }
    .honest-title em { font-style: italic; color: var(--blue-dk); }
    .honest-body {
      font-size: 17px; color: var(--ink-3);
      line-height: 1.75;
    }
    .honest-body strong { color: var(--ink); }

    /* ── COMPARISON: COFFEE vs FUNGI FUSION ── */
    .compare-section {
      padding: 100px 28px;
      background: var(--off-white);
    }
    .compare-inner { max-width: 1080px; margin: 0 auto; }
    .compare-header { text-align: center; margin-bottom: 56px; }
    .compare-header h2 {
      font-family: 'Newsreader', serif;
      font-size: clamp(28px, 4vw, 44px);
      font-weight: 600; color: var(--ink);
      line-height: 1.15; letter-spacing: -0.02em;
    }
    .compare-header h2 em { font-style: italic; color: var(--blue-dk); }
    .compare-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 20px;
    }
    .compare-col {
      background: var(--white);
      border-radius: 24px;
      padding: 36px 30px;
      border: 1.5px solid var(--line);
      position: relative;
    }
    .compare-col.win {
      background: linear-gradient(180deg, var(--white), var(--razz-pale));
      border: 2px solid var(--blue);
      box-shadow: 0 20px 50px rgba(59,111,240,0.15);
    }
    .compare-col.win::after {
      content: 'THIS IS US';
      position: absolute; top: -12px; right: 20px;
      background: var(--ink); color: var(--white);
      padding: 5px 12px; border-radius: 50px;
      font-size: 10px; font-weight: 900; letter-spacing: 0.14em;
    }
    .compare-col-label {
      display: inline-block;
      font-size: 11px; font-weight: 800; letter-spacing: 0.18em;
      text-transform: uppercase;
      padding: 5px 12px; border-radius: 50px;
      margin-bottom: 18px;
    }
    .compare-col.lose .compare-col-label { background: var(--coffee-pale); color: var(--coffee); }
    .compare-col.win .compare-col-label { background: var(--blue); color: var(--white); }
    .compare-col h3 {
      font-family: 'Newsreader', serif;
      font-size: 22px; font-weight: 600;
      color: var(--ink); margin-bottom: 22px;
      line-height: 1.2;
    }
    .compare-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 10px; }
    .compare-list li {
      display: flex; align-items: flex-start; gap: 10px;
      font-size: 14.5px; color: var(--ink-3);
      line-height: 1.55;
      padding: 10px 0;
      border-bottom: 1px solid var(--line);
    }
    .compare-list li:last-child { border-bottom: none; }
    .compare-list li svg { flex-shrink: 0; margin-top: 2px; }
    .compare-col.win .compare-list li svg { stroke: var(--good); }
    .compare-col.lose .compare-list li svg { stroke: var(--ink-4); }

    /* ── THE 3 MUSHROOMS ── */
    .mush-section {
      padding: 100px 28px;
      background: var(--ink);
      color: var(--white);
    }
    .mush-inner { max-width: 1080px; margin: 0 auto; }
    .mush-header { text-align: center; margin-bottom: 56px; }
    .mush-eyebrow {
      font-size: 11px; font-weight: 700; letter-spacing: 0.2em;
      text-transform: uppercase; color: var(--razz);
      margin-bottom: 14px;
    }
    .mush-title {
      font-family: 'Newsreader', serif;
      font-size: clamp(28px, 4vw, 44px);
      font-weight: 600; color: var(--white);
      line-height: 1.15; letter-spacing: -0.02em;
    }
    .mush-title em { font-style: italic; color: var(--razz); }
    .mush-grid {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px;
    }
    .mush-card {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 20px;
      padding: 32px 28px;
      transition: transform 0.2s, background 0.2s;
    }
    .mush-card:hover {
      transform: translateY(-4px);
      background: rgba(255,255,255,0.07);
    }
    .mush-card-num {
      font-family: 'Newsreader', serif;
      font-size: 11px; font-weight: 600; font-style: italic;
      color: var(--razz); letter-spacing: 0.12em;
      text-transform: uppercase; margin-bottom: 16px;
    }
    .mush-card-dose {
      font-family: 'Newsreader', serif;
      font-size: 52px; font-weight: 600;
      color: var(--white); line-height: 1;
      margin-bottom: 6px;
    }
    .mush-card-name {
      font-size: 12px; font-weight: 700; letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.55); margin-bottom: 18px;
    }
    .mush-card-tag {
      display: inline-block;
      font-family: 'Newsreader', serif;
      font-style: italic; font-size: 19px;
      color: var(--razz); margin-bottom: 12px;
    }
    .mush-card-desc {
      font-size: 14px; color: rgba(255,255,255,0.7);
      line-height: 1.65;
    }

    /* ── REVIEWS ── */
    .rev-section {
      padding: 100px 28px;
      background: var(--off-white);
    }
    .rev-inner { max-width: 1080px; margin: 0 auto; }
    .rev-header { text-align: center; margin-bottom: 48px; }
    .rev-eyebrow {
      font-size: 11px; font-weight: 700; letter-spacing: 0.2em;
      text-transform: uppercase; color: var(--blue);
      margin-bottom: 12px;
    }
    .rev-title {
      font-family: 'Newsreader', serif;
      font-size: clamp(28px, 4vw, 42px);
      font-weight: 600; color: var(--ink);
      letter-spacing: -0.02em; margin-bottom: 12px;
    }
    .rev-title em { font-style: italic; color: var(--blue-dk); }
    .rev-rating-row {
      display: inline-flex; align-items: center; gap: 12px;
      font-size: 14px; color: var(--ink-3);
    }
    .rev-rating-row .stars { color: #F5A623; font-size: 16px; }
    .rev-grid {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;
      margin-top: 12px;
    }
    .rev-card {
      background: var(--white);
      border: 1px solid var(--line);
      border-radius: 20px;
      padding: 28px;
    }
    .rev-card-stars {
      color: #F5A623; font-size: 14px; letter-spacing: 1px;
      margin-bottom: 14px;
    }
    .rev-card-title {
      font-family: 'Newsreader', serif;
      font-size: 17px; font-weight: 600;
      color: var(--ink); margin-bottom: 10px;
      line-height: 1.3;
    }
    .rev-card-body {
      font-size: 14px; color: var(--ink-3);
      line-height: 1.7; margin-bottom: 18px;
    }
    .rev-card-by {
      display: flex; align-items: center; gap: 8px;
      font-size: 12px; color: var(--ink-4);
      padding-top: 14px;
      border-top: 1px solid var(--line);
    }
    .rev-card-by svg { fill: #F5A623; }

    /* ── TRUST BAR ── */
    .trust-section {
      padding: 50px 28px;
      background: var(--blue-deep);
      color: var(--white);
    }
    .trust-inner {
      max-width: 1000px; margin: 0 auto;
      display: grid; grid-template-columns: repeat(4,1fr); gap: 0;
      text-align: center;
    }
    .trust-item { padding: 0 16px; }
    .trust-item + .trust-item { border-left: 1px solid rgba(255,255,255,0.12); }
    .trust-item svg { stroke: var(--razz); margin-bottom: 10px; }
    .trust-item strong { display: block; font-size: 13px; margin-bottom: 4px; font-weight: 800; letter-spacing: 0.04em; }
    .trust-item span { font-size: 11px; color: rgba(255,255,255,0.6); letter-spacing: 0.04em; }

    /* ── FINAL CTA ── */
    .final-cta {
      padding: 110px 28px;
      background:
        radial-gradient(ellipse at center, rgba(59,111,240,0.12) 0%, transparent 60%),
        linear-gradient(180deg, var(--off-white) 0%, #EEF2FB 100%);
      text-align: center;
    }
    .final-cta-inner { max-width: 680px; margin: 0 auto; }
    .final-cta h2 {
      font-family: 'Newsreader', serif;
      font-size: clamp(34px, 5vw, 58px);
      font-weight: 600; color: var(--ink);
      line-height: 1.05; letter-spacing: -0.025em;
      margin-bottom: 22px;
    }
    .final-cta h2 em { font-style: italic; color: var(--blue-dk); }
    .final-cta p {
      font-size: 17px; color: var(--ink-3);
      line-height: 1.65; margin-bottom: 36px;
      max-width: 480px; margin-left: auto; margin-right: auto;
    }
    .final-cta-btns {
      display: flex; justify-content: center; gap: 14px;
      flex-wrap: wrap; align-items: center;
    }
    .btn-secondary {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--white); color: var(--ink);
      border: 1.5px solid var(--line);
      border-radius: 14px; padding: 17px 26px;
      font-size: 14px; font-weight: 700;
      transition: all 0.2s;
    }
    .btn-secondary:hover { border-color: var(--blue); color: var(--blue-dk); }
    .disclaimer {
      font-size: 11px; color: var(--ink-4);
      max-width: 560px; margin: 36px auto 0;
      line-height: 1.6;
    }

    /* ── FOOTER ── */
    .lp-footer {
      padding: 26px 28px;
      background: var(--ink);
      color: rgba(255,255,255,0.55);
      display: flex; justify-content: space-between; align-items: center;
      font-size: 12px;
    }
    .lp-footer-links { display: flex; gap: 22px; }
    .lp-footer-links a:hover { color: var(--white); }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
      .hero-inner, .compare-grid, .mush-grid, .rev-grid { grid-template-columns: 1fr; }
      .hero { padding: 100px 22px 50px; }
      .hero-visual { order: -1; min-height: 380px; }
      .hero-can { width: 220px; }
      .rev-grid { max-width: 480px; margin: 0 auto; }
      .trust-inner { grid-template-columns: repeat(2,1fr); gap: 24px; }
      .trust-item + .trust-item { border-left: none; }
      .trust-item:nth-child(odd) { border-right: 1px solid rgba(255,255,255,0.12); }
      .lp-footer { flex-direction: column; gap: 14px; text-align: center; }
      section { padding-left: 20px !important; padding-right: 20px !important; }
    }
  </style>
</head>
<body>

  <!-- Auto-apply discount URL used across all CTAs -->
  {%- assign cta_url = '/discount/FUNGI15?redirect=/products/blue-razzberry-fungi-powered-seltzer' -%}

  <!-- NAV -->
  <nav class="lp-nav">
    <a href="/" class="lp-nav-logo"><img src="{{ 'happie-logo.png' | asset_url }}" alt="Happie Fusion"></a>
    <a href="{{ cta_url }}" class="lp-nav-cta">Try Blue Razz →</a>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-text">
        <div class="hero-eyebrow">
          <span class="dot"></span>
          Honest take · For the mushroom-curious
        </div>
        <h1 class="hero-headline editorial">Mushroom coffee wasn't <em>your thing?</em></h1>
        <p class="hero-body">Fair. Mushroom coffee turned a lot of us off the whole category too. <strong>Fungi Fusion is different</strong> — three real mushrooms (Lion's Mane, Cordyceps, Reishi) in a sparkling Blue Raspberry seltzer that actually tastes like a drink, not a supplement.</p>
        <div class="hero-cta-stack">
          <a href="{{ cta_url }}" class="btn-primary">
            Try Blue Razzberry — 15% Off
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <div class="hero-code-row">
            Discount auto-applied at checkout · code <strong>FUNGI15</strong>
          </div>
        </div>
        <div class="hero-checkmarks">
          <div class="hero-checkmark">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            40 calories
          </div>
          <div class="hero-checkmark">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            No caffeine
          </div>
          <div class="hero-checkmark">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            No crash
          </div>
          <div class="hero-checkmark">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Doesn't taste like a supplement
          </div>
        </div>
      </div>
      <div class="hero-visual">
        <div class="hero-can-wrap">
          <div class="hero-can-glow"></div>
          <img src="{{ 'can-blue-razzberry.png' | asset_url }}" alt="Happie Fungi Fusion Blue Razzberry" class="hero-can">
          <div class="hero-floating-card">
            <div class="hero-floating-stars">★★★★★</div>
            <div class="hero-floating-text">"I'd written off mushroom drinks. This actually tastes like a real drink. Came back for the variety pack."</div>
            <div class="hero-floating-by">— Jamie K., former skeptic</div>
          </div>
          <div class="hero-flavor-pill">Blue Razzberry</div>
        </div>
      </div>
    </div>
  </section>

  <!-- HONEST INTRO -->
  <section class="honest-section">
    <div class="honest-inner">
      <div class="honest-eyebrow">Real talk</div>
      <h2 class="honest-title editorial">If mushroom coffee burned you, <em>we get it.</em></h2>
      <p class="honest-body">
