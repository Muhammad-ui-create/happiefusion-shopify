{% layout none %}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Mushroom coffee wasn't your thing? Try this. — Happie Fungi Fusion</title>
  <meta name="description" content="Most people are skeptical at first. Fungi Fusion is different — three real mushrooms in a sparkling seltzer that actually tastes like Blue Raspberry. 40 cal. No caffeine. Code FUNGI15.">
  <meta name="robots" content="noindex,nofollow">
  <link rel="icon" type="image/png" href="{{ 'happie-favicon.png' | asset_url }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:         #F8FAFD;
      --paper:      #FFFFFF;
      --ink:        #0B142D;
      --ink-2:      #2C3552;
      --ink-3:      #5D6588;
      --ink-4:      #9CA3BD;
      --razz:       #3B6FF0;
      --razz-dk:    #1B3B7A;
      --razz-deep:  #0B2347;
      --razz-pale:  #E6EDFE;
      --razz-bright:#5DCBF5;
      --candy:      #6B8CF7;
      --gold:       #F5A623;
      --line:       rgba(11,20,45,0.08);
    }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Poppins', system-ui, -apple-system, sans-serif;
      background: var(--bg);
      color: var(--ink);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }
    img { max-width: 100%; display: block; }
    a { text-decoration: none; color: inherit; }

    /* ── NAV — BIG LOGO ── */
    .lp-nav {
      position: sticky; top: 0; z-index: 100;
      padding: 14px 32px;
      display: flex; justify-content: space-between; align-items: center;
      background: rgba(248,250,253,0.94);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--line);
    }
    .lp-nav-logo img {
      height: 80px;
      width: auto;
      display: block;
    }
    .lp-nav-cta {
      background: var(--ink); color: var(--paper);
      border-radius: 50px; padding: 11px 24px;
      font-size: 13px; font-weight: 700; letter-spacing: 0.04em;
      transition: background 0.2s;
    }
    .lp-nav-cta:hover { background: var(--razz-dk); }

    /* ── HERO ── */
    .hero {
      padding: 80px 32px 90px;
      background:
        radial-gradient(ellipse at 80% 30%, rgba(59,111,240,0.15) 0%, transparent 55%),
        radial-gradient(ellipse at 10% 90%, rgba(93,203,245,0.12) 0%, transparent 55%),
        linear-gradient(180deg, var(--bg) 0%, #ECF2FE 100%);
      position: relative; overflow: hidden;
    }
    .hero-inner {
      max-width: 1180px; margin: 0 auto;
      display: grid; grid-template-columns: 1.1fr 1fr;
      gap: 64px; align-items: center;
    }

    .hero-eyebrow {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--paper);
      border: 1.5px solid var(--line);
      color: var(--ink-2);
      font-size: 11px; font-weight: 700; letter-spacing: 0.16em;
      text-transform: uppercase;
      padding: 8px 18px; border-radius: 50px;
      margin-bottom: 24px;
    }
    .hero-eyebrow-dot {
      width: 7px; height: 7px; border-radius: 50%;
      background: var(--razz); animation: pulse 2s infinite;
    }
    @keyframes pulse { 0%,100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.5; transform: scale(1.2); } }

    .hero-headline {
      font-size: clamp(40px, 6vw, 78px);
      font-weight: 900; line-height: 1.0;
      color: var(--ink); margin-bottom: 22px;
      letter-spacing: -0.025em;
    }
    .hero-headline .em {
      color: var(--razz-dk);
      position: relative; display: inline-block;
    }
    .hero-headline .em::after {
      content: ''; position: absolute;
      left: 0; right: 0; bottom: 6px;
      height: 14px; background: var(--razz-bright);
      z-index: -1; opacity: 0.45;
    }
    .hero-sub {
      font-size: 18px; color: var(--ink-3);
      line-height: 1.65; margin-bottom: 28px;
      max-width: 500px;
    }
    .hero-sub strong { color: var(--ink); font-weight: 700; }
    .hero-sub em {
      font-style: normal; color: var(--razz-dk); font-weight: 600;
    }

    /* Pill row */
    .hero-pills {
      display: flex; flex-wrap: wrap; gap: 8px;
      margin-bottom: 32px;
    }
    .hero-pill {
      display: inline-flex; align-items: center; gap: 7px;
      background: var(--paper);
      border: 1.5px solid var(--line);
      padding: 8px 14px; border-radius: 50px;
      font-size: 12px; font-weight: 700;
      color: var(--ink-2);
    }
    .hero-pill svg { stroke: var(--razz); }

    .hero-cta-stack {
      display: flex; flex-direction: column;
      gap: 14px; align-items: flex-start;
    }
    .btn-primary {
      display: inline-flex; align-items: center; gap: 10px;
      background: var(--ink); color: var(--paper);
      border-radius: 50px; padding: 17px 32px;
      font-family: 'Poppins', sans-serif;
      font-size: 15px; font-weight: 800;
      letter-spacing: 0.02em;
      transition: all 0.2s;
      box-shadow: 0 12px 28px rgba(11,20,45,0.18);
    }
    .btn-primary:hover { background: var(--razz-dk); transform: translateY(-2px); }
    .btn-primary svg { transition: transform 0.2s; }
    .btn-primary:hover svg { transform: translateX(3px); }
    .hero-code-row {
      display: flex; align-items: center; gap: 10px;
      font-size: 13px; color: var(--ink-3);
    }
    .hero-code-row strong {
      background: var(--razz); color: var(--paper);
      padding: 4px 10px; border-radius: 8px;
      font-weight: 800; letter-spacing: 0.06em;
      font-family: 'Poppins', monospace;
    }

    /* Hero visual — with "Wow" reaction card */
    .hero-visual {
      position: relative;
      display: flex; justify-content: center; align-items: center;
      min-height: 500px;
    }
    .hero-can-wrap {
      position: relative;
      filter: drop-shadow(0 32px 50px rgba(59,111,240,0.3));
    }
    .hero-can-glow {
      position: absolute; inset: 0;
      background: radial-gradient(circle at center, rgba(59,111,240,0.35) 0%, transparent 65%);
      transform: scale(1.6);
    }
    .hero-can {
      width: 290px; max-width: 80vw; position: relative; z-index: 2;
    }
    /* "Wow" reaction card */
    .hero-wow-card {
      position: absolute; top: 20px; right: -30px;
      background: var(--paper);
      border: 1.5px solid var(--line);
      border-radius: 20px;
      padding: 16px 20px;
      box-shadow: 0 20px 40px rgba(11,20,45,0.15);
      transform: rotate(4deg);
      z-index: 3;
      text-align: center;
      max-width: 180px;
    }
    .hero-wow-emoji {
      font-size: 36px; line-height: 1; margin-bottom: 4px;
    }
    .hero-wow-text {
      font-size: 16px; font-weight: 900;
      color: var(--razz-dk); margin-bottom: 4px;
    }
    .hero-wow-sub {
      font-size: 10px; color: var(--ink-3);
      letter-spacing: 0.1em; text-transform: uppercase;
      font-weight: 700;
    }
    .hero-stars-card {
      position: absolute; bottom: 30px; left: -30px;
      background: var(--paper);
      border: 1.5px solid var(--line);
      border-radius: 16px;
      padding: 12px 18px;
      box-shadow: 0 16px 32px rgba(11,20,45,0.12);
      transform: rotate(-3deg);
      z-index: 3;
    }
    .hero-stars-rating {
      color: var(--gold); font-size: 14px; letter-spacing: 1px;
      margin-bottom: 2px;
    }
    .hero-stars-text {
      font-size: 11px; color: var(--ink-2);
      font-weight: 700;
    }

    /* ── SKEPTIC INTRO SECTION ── */
    .skep-section {
      padding: 110px 32px;
      background: var(--paper);
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
    }
    .skep-inner {
      max-width: 820px; margin: 0 auto;
      text-align: center;
    }
    .skep-eyebrow {
      font-size: 11px; font-weight: 800;
      letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--razz); margin-bottom: 14px;
    }
    .skep-title {
      font-size: clamp(28px, 4vw, 46px);
      font-weight: 900; color: var(--ink);
      line-height: 1.15; margin-bottom: 24px;
      letter-spacing: -0.02em;
    }
    .skep-title em { font-style: normal; color: var(--razz-dk); }
    .skep-body {
      font-size: 18px; color: var(--ink-3);
      line-height: 1.8;
    }
    .skep-body strong { color: var(--ink); font-weight: 700; }

    /* ── 3 PROOF POINTS ── */
    .proof-section {
      padding: 100px 32px;
      background: var(--bg);
    }
    .proof-inner { max-width: 1080px; margin: 0 auto; }
    .proof-header { text-align: center; margin-bottom: 56px; }
    .proof-title {
      font-size: clamp(28px, 4vw, 44px);
      font-weight: 900; color: var(--ink);
      line-height: 1.15; letter-spacing: -0.02em;
    }
    .proof-title em { font-style: normal; color: var(--razz-dk); }
    .proof-grid {
      display: grid; grid-template-columns: repeat(3,1fr); gap: 20px;
    }
    .proof-card {
      background: var(--paper);
      border: 1.5px solid var(--line);
      border-radius: 22px;
      padding: 36px 28px;
      transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
    }
    .proof-card:hover {
      transform: translateY(-4px);
      border-color: rgba(59,111,240,0.35);
      box-shadow: 0 16px 40px rgba(59,111,240,0.1);
    }
    .proof-num {
      font-size: 56px; font-weight: 900;
      color: var(--razz-dk); line-height: 1;
      margin-bottom: 6px; letter-spacing: -0.03em;
    }
    .proof-num .mg {
      font-size: 22px; vertical-align: super;
      color: var(--razz); font-weight: 700;
    }
    .proof-mushroom {
      font-size: 11px; font-weight: 800;
      letter-spacing: 0.16em; text-transform: uppercase;
      color: var(--razz); margin-bottom: 16px;
    }
    .proof-card h3 {
      font-size: 19px; font-weight: 900;
      color: var(--ink); margin-bottom: 10px;
      line-height: 1.2;
    }
    .proof-card p {
      font-size: 14px; color: var(--ink-3);
      line-height: 1.65;
    }

    /* ── BIG QUOTE ── */
    .quote-section {
      padding: 110px 32px;
      background: var(--ink);
      color: var(--paper);
      position: relative; overflow: hidden;
    }
    .quote-section::before {
      content: ''; position: absolute; inset: 0;
      background: radial-gradient(ellipse at 30% 30%, rgba(59,111,240,0.18) 0%, transparent 60%);
      pointer-events: none;
    }
    .quote-inner {
      max-width: 880px; margin: 0 auto;
      text-align: center; position: relative;
    }
    .quote-mark {
      font-family: Georgia, serif;
      font-size: 100px; line-height: 1;
      color: var(--razz-bright);
      margin-bottom: 12px;
    }
    .quote-text {
      font-size: clamp(28px, 4vw, 44px);
      font-weight: 900; line-height: 1.2;
      color: var(--paper); margin-bottom: 28px;
      letter-spacing: -0.02em;
    }
    .quote-text em { font-style: normal; color: var(--razz-bright); }
    .quote-author {
      font-size: 13px; letter-spacing: 0.14em;
      text-transform: uppercase; color: rgba(255,255,255,0.5);
      font-weight: 700;
    }

    /* ── COMPARISON ── */
    .compare-section {
      padding: 110px 32px;
      background: var(--bg);
    }
    .compare-inner { max-width: 1080px; margin: 0 auto; }
    .compare-header { text-align: center; margin-bottom: 56px; }
    .compare-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 20px;
    }
    .compare-col {
      background: var(--paper);
      border-radius: 24px;
      padding: 36px 30px;
      border: 1.5px solid var(--line);
      position: relative;
    }
    .compare-col.bad {
      background: linear-gradient(165deg, #F2EBDE, #E8DAB8);
      border-color: rgba(107,68,35,0.2);
    }
    .compare-col.good {
      background: linear-gradient(165deg, var(--paper), var(--razz-pale));
      border: 2.5px solid var(--razz);
      box-shadow: 0 20px 50px rgba(59,111,240,0.15);
    }
    .compare-col.good::after {
      content: 'TASTES LIKE A REAL DRINK';
      position: absolute; top: -12px; right: 18px;
      background: var(--ink); color: var(--razz-bright);
      padding: 5px 14px; border-radius: 50px;
      font-size: 10px; font-weight: 900; letter-spacing: 0.12em;
    }
    .compare-col-tag {
      display: inline-block;
      font-size: 10px; font-weight: 800; letter-spacing: 0.18em;
      text-transform: uppercase; padding: 5px 12px; border-radius: 50px;
      margin-bottom: 16px;
    }
    .compare-col.bad .compare-col-tag { background: rgba(107,68,35,0.15); color: #6B4423; }
    .compare-col.good .compare-col-tag { background: var(--razz); color: var(--paper); }
    .compare-col h3 {
      font-size: 22px; font-weight: 900;
      color: var(--ink); margin-bottom: 20px;
      line-height: 1.2;
    }
    .compare-list { list-style: none; padding: 0; }
    .compare-list li {
      display: flex; align-items: flex-start; gap: 10px;
      font-size: 14.5px; color: var(--ink-2);
      line-height: 1.55;
      padding: 11px 0;
      border-bottom: 1px solid var(--line);
    }
    .compare-list li:last-child { border-bottom: none; }
    .compare-list li svg { flex-shrink: 0; margin-top: 2px; }
    .compare-col.bad .compare-list svg { stroke: #6B4423; }
    .compare-col.good .compare-list svg { stroke: var(--razz-dk); }

    /* ── REVIEWS ── */
    .reviews-section {
      padding: 110px 32px;
      background: var(--paper);
    }
    .reviews-inner { max-width: 1080px; margin: 0 auto; }
    .reviews-header { text-align: center; margin-bottom: 52px; }
    .reviews-eyebrow {
      font-size: 11px; font-weight: 800;
      letter-spacing: 0.18em; text-transform: uppercase;
      color: var(--razz); margin-bottom: 12px;
    }
    .reviews-title {
      font-size: clamp(28px, 4vw, 42px);
      font-weight: 900; color: var(--ink);
      line-height: 1.15; letter-spacing: -0.02em;
      margin-bottom: 12px;
    }
    .reviews-title em { font-style: normal; color: var(--razz-dk); }
    .reviews-rating {
      display: inline-flex; align-items: center; gap: 12px;
      font-size: 14px; color: var(--ink-3);
    }
    .reviews-rating .stars { color: var(--gold); font-size: 16px; }
    .reviews-grid {
      display: grid; grid-template-columns: repeat(3,1fr); gap: 20px;
      margin-top: 24px;
    }
    .review-card {
      background: var(--bg);
      border: 1.5px solid var(--line);
      border-radius: 20px;
      padding: 30px 26px;
    }
    .review-stars {
      color: var(--gold); font-size: 14px; letter-spacing: 1px;
      margin-bottom: 14px;
    }
    .review-title {
      font-size: 16px; font-weight: 800;
      color: var(--ink); margin-bottom: 10px;
    }
    .review-body {
      font-size: 14px; color: var(--ink-3);
      line-height: 1.7; margin-bottom: 18px;
    }
    .review-by {
      display: flex; align-items: center; gap: 7px;
      font-size: 11px; color: var(--ink-4);
      font-weight: 700; letter-spacing: 0.06em;
      text-transform: uppercase;
      padding-top: 14px;
      border-top: 1px solid var(--line);
    }
    .review-by svg { fill: var(--gold); }

    /* ── TRUST BAR ── */
    .trust-section {
      padding: 50px 32px;
      background: var(--razz-deep);
      color: var(--paper);
    }
    .trust-inner {
      max-width: 1000px; margin: 0 auto;
      display: grid; grid-template-columns: repeat(4,1fr); gap: 0;
      text-align: center;
    }
    .trust-item { padding: 0 16px; }
    .trust-item + .trust-item { border-left: 1px solid rgba(255,255,255,0.12); }
    .trust-item svg { stroke: var(--razz-bright); margin-bottom: 10px; }
    .trust-item strong { display: block; font-size: 13px; margin-bottom: 4px; font-weight: 800; }
    .trust-item span { font-size: 11px; color: rgba(255,255,255,0.6); }

    /* ── FINAL CTA ── */
    .final-cta {
      padding: 120px 32px;
      background:
        radial-gradient(ellipse at center, rgba(59,111,240,0.15) 0%, transparent 60%),
        linear-gradient(180deg, var(--bg) 0%, #ECF2FE 100%);
      text-align: center;
    }
    .final-cta-inner { max-width: 680px; margin: 0 auto; }
    .final-cta h2 {
      font-size: clamp(34px, 5vw, 58px);
      font-weight: 900; color: var(--ink);
      line-height: 1.05; letter-spacing: -0.025em;
      margin-bottom: 22px;
    }
    .final-cta h2 em {
      font-style: normal; color: var(--razz-dk);
      position: relative; display: inline-block;
    }
    .final-cta h2 em::after {
      content: ''; position: absolute;
      left: 0; right: 0; bottom: 6px;
      height: 12px; background: var(--razz-bright);
      z-index: -1; opacity: 0.4;
    }
    .final-cta p {
      font-size: 17px; color: var(--ink-3);
      line-height: 1.7; margin-bottom: 36px;
      max-width: 480px; margin-left: auto; margin-right: auto;
    }
    .final-cta-row {
      display: flex; justify-content: center; gap: 16px;
      flex-wrap: wrap; align-items: center;
    }
    .disclaimer {
      font-size: 11px; color: var(--ink-4);
      max-width: 560px; margin: 40px auto 0;
      line-height: 1.6;
    }

    /* ── FOOTER ── */
    .lp-footer {
      padding: 28px 32px;
      background: var(--ink);
      color: rgba(255,255,255,0.55);
      display: flex; justify-content: space-between; align-items: center;
      font-size: 12px;
    }
    .lp-footer-links { display: flex; gap: 22px; }
    .lp-footer-links a:hover { color: var(--paper); }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
      .lp-nav-logo img { height: 60px; }
      .hero-inner, .compare-grid, .proof-grid, .reviews-grid {
        grid-template-columns: 1fr;
      }
      .hero { padding: 60px 22px 70px; }
      .hero-visual { order: -1; min-height: 380px; }
      .hero-can { width: 220px; }
      .hero-wow-card, .hero-stars-card { transform: rotate(0); }
      .proof-grid, .reviews-grid { gap: 14px; }
      .reviews-grid { max-width: 460px; margin-left: auto; margin-right: auto; }
      .trust-inner { grid-template-columns: repeat(2,1fr); gap: 24px; }
      .trust-item + .trust-item { border-left: none; }
      .trust-item:nth-child(odd) { border-right: 1px solid rgba(255,255,255,0.12); }
      .lp-footer { flex-direction: column; gap: 14px; text-align: center; }
      section { padding-left: 20px !important; padding-right: 20px !important; }
    }
  </style>
</head>
<body>

  {%- assign cta_url = '/discount/FUNGI15?redirect=/products/blue-razzberry-fungi-powered-seltzer' -%}

  <!-- NAV — big logo -->
  <nav class="lp-nav">
    <a href="/" class="lp-nav-logo"><img src="{{ 'happie-logo.png' | asset_url }}" alt="Happie Fusion"></a>
    <a href="{{ cta_url }}" class="lp-nav-cta">Try Blue Razz — 15% Off →</a>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-text">
        <div class="hero-eyebrow">
          <span class="hero-eyebrow-dot"></span>
          For Mushroom-Curious Skeptics
        </div>
        <h1 class="hero-headline">Mushroom coffee wasn't <span class="em">your thing?</span></h1>
        <p class="hero-sub">Fair. <em>Most people are skeptical at first.</em> Mushroom coffee turned a lot of us off the whole category — earthy, bitter, somehow both weak and overpriced. <strong>Fungi Fusion is different.</strong> Three real mushrooms in a sparkling seltzer that actually tastes like Blue Raspberry.</p>
        <div class="hero-pills">
          <span class="hero-pill">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Real fruit flavor
          </span>
          <span class="hero-pill">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            40 calories
          </span>
          <span class="hero-pill">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            No caffeine
          </span>
          <span class="hero-pill">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            No crash
          </span>
        </div>
        <div class="hero-cta-stack">
          <a href="{{ cta_url }}" class="btn-primary">
            Try Blue Razzberry — 15% Off
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <div class="hero-code-row">Code <strong>FUNGI15</strong> auto-applies at checkout</div>
        </div>
      </div>
      <div class="hero-visual">
