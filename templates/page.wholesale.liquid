    radial-gradient(56% 125% at  8% 30%, rgba(45,200,214,0.42)  0%, rgba(45,200,214,0)  62%),
    radial-gradient(52% 120% at 30% 82%, rgba(82,205,150,0.40)  0%, rgba(82,205,150,0)  62%),
    radial-gradient(50% 118% at 52% 14%, rgba(255,190,60,0.36)  0%, rgba(255,190,60,0)  60%),
    radial-gradient(54% 122% at 74% 80%, rgba(255,122,138,0.34) 0%, rgba(255,122,138,0) 62%),
    radial-gradient(56% 125% at 95% 26%, rgba(138,96,232,0.38)  0%, rgba(138,96,232,0)  62%);
  background-size: 200% 200%, 215% 215%, 190% 190%, 225% 225%, 235% 235%;
  background-repeat: no-repeat;
  animation: navSilk 26s ease-in-out infinite;
}
@media (prefers-reduced-motion: reduce) { .whl-hero { animation: none; } }
.whl-hero > *:not(.wave-field) { position: relative; z-index: 1; }
