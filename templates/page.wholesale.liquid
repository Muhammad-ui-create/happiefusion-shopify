  padding: 7px 15px; border-radius: 50px; margin-bottom: 16px;
}
.whl-title { font-size: clamp(34px,5.4vw,58px); font-weight: 900; letter-spacing: -0.02em; color: #16181B; margin-bottom: 14px; }
