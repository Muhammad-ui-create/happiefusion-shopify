{% layout none %}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Quit the Coffee Crash — Happie Fungi Fusion</title>
  <meta name="description" content="900mg Lion's Mane · 700mg Cordyceps · 400mg Reishi. Per can. The morning routine without the crash. Use FUNGI15 for 15% off.">
  <meta name="robots" content="noindex,nofollow">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;0,9..144,800;1,9..144,400;1,9..144,500&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --cottage:    #FBF6EA;
      --cream:      #F2E9D2;
      --cream-dk:   #E8DCBF;
      --linen:      #FFFEF7;
      --sage:       #A8B89A;
      --sage-dk:    #6B7F5E;
      --sage-lt:    #D0DBC4;
      --earth:      #C9A266;
      --earth-dk:   #8E6F3F;
      --earth-lt:   #E8D5A3;
      --mango:      #E89B3C;
      --mango-dk:   #C97F1F;
      --brown:      #3D2F22;
      --brown-lt:   #6B5743;
      --brown-md:   #8A745E;
    }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Inter', sans-serif;
      background: var(--linen);
      color: var(--brown);
      line-height: 1.6;
    }
    img { max-width: 100%; display: block; }
    a { text-decoration: none; color: inherit; }
    .serif { font-family: 'Fraunces', Georgia, serif; }

    /* ── NAV ── */
    .lp-nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      padding: 14px 32px;
      display: flex; justify-content: space-between; align-items: center;
      background: rgba(255,254,247,0.92);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(61,47,34,0.08);
    }
    .lp-nav-logo img { height: 44px; width: auto; }
    .lp-nav-cta {
      background: var(--brown); color: var(--linen);
      border-radius: 50px; padding: 9px 22px;
      font-size: 12px; font-weight: 700; letter-spacing: 0.06em;
    }

    /* ── HERO ── */
    .hero {
      padding: 130px 32px 80px;
      background:
        radial-gradient(ellipse at 75% 20%, rgba(232,155,60,0.18) 0%, transparent 55%),
        radial-gradient(ellipse at 15% 85%, rgba(168,184,154,0.15) 0%, transparent 60%),
        linear-gradient(165deg, var(--linen) 0%, var(--cream) 60%, var(--cream-dk) 100%);
      position: relative; overflow: hidden;
    }
    .hero-inner {
      max-width: 1180px; margin: 0 auto;
      display: grid; grid-template-columns: 1.05fr 1fr;
      gap: 64px; align-items: center;
    }
    .hero-eyebrow {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(107,127,94,0.12);
      border: 1px solid rgba(107,127,94,0.22);
      color: var(--sage-dk);
      font-size: 11px; font-weight: 700; letter-spacing: 0.18em;
      text-transform: uppercase;
      padding: 7px 18px; border-radius: 50px;
      margin-bottom: 24px;
    }
    .hero-headline {
      font-family: 'Fraunces', serif;
      font-size: clamp(44px, 7vw, 88px);
      font-weight: 600;
      line-height: 0.95;
      color: var(--brown); margin-bottom: 22px;
      letter-spacing: -0.02em;
    }
    .hero-headline em {
      font-style: italic; font-weight: 400;
      color: var(--mango-dk);
    }
    .hero-sub {
      font-family: 'Fraunces', serif;
      font-size: clamp(18px, 1.8vw, 21px);
      font-weight: 400;
      color: var(--brown-lt);
      line-height: 1.5; margin-bottom: 36px;
      max-width: 480px;
    }
    .hero-doses {
      display: flex; gap: 0; flex-wrap: wrap;
      margin-bottom: 36px;
      border-top: 1px solid rgba(61,47,34,0.1);
      border-bottom: 1px solid rgba(61,47,34,0.1);
      padding: 18px 0;
    }
    .hero-dose {
      flex: 1; min-width: 100px;
      padding: 0 16px;
      text-align: center;
    }
    .hero-dose + .hero-dose { border-left: 1px solid rgba(61,47,34,0.1); }
    .hero-dose-num {
      font-family: 'Fraunces', serif;
      font-size: 22px; font-weight: 700;
      color: var(--brown); display: block;
      line-height: 1;
    }
    .hero-dose-name {
      font-size: 10px; letter-spacing: 0.16em;
      color: var(--brown-md); text-transform: uppercase;
      font-weight: 700; margin-top: 6px;
    }
    .hero-dose-sub {
      font-size: 11px; font-style: italic;
      color: var(--sage-dk); margin-top: 2px;
      font-family: 'Fraunces', serif;
    }

    .hero-cta-group {
      display: flex; align-items: center; gap: 18px; flex-wrap: wrap;
    }
    .btn-primary {
      display: inline-flex; align-items: center; gap: 10px;
      background: var(--brown); color: var(--linen);
      border-radius: 50px; padding: 17px 36px;
      font-size: 15px; font-weight: 800; letter-spacing: 0.03em;
      box-shadow: 0 8px 24px rgba(61,47,34,0.18);
      transition: all 0.2s;
    }
    .btn-primary:hover { background: var(--brown-lt); transform: translateY(-2px); }
    .hero-code {
      font-size: 13px; color: var(--brown-lt);
    }
    .hero-code strong {
      font-family: monospace;
      background: var(--earth); color: var(--brown);
      padding: 3px 9px; border-radius: 6px;
      font-weight: 800; letter-spacing: 0.06em;
    }

    /* Hero visual */
    .hero-visual {
      position: relative;
      display: flex; justify-content: center; align-items: center;
      min-height: 520px;
    }
    .hero-can-wrap {
      position: relative;
      filter: drop-shadow(0 32px 60px rgba(201,162,102,0.3));
    }
    .hero-can-bg {
      position: absolute; inset: 0;
      background: radial-gradient(circle at center, rgba(232,213,163,0.5) 0%, transparent 65%);
      transform: scale(1.6);
    }
    .hero-can {
      width: 300px; max-width: 80vw; position: relative; z-index: 2;
      border-radius: 24px;
    }
    /* The 3 mushroom proof points floating around */
    .hero-proof {
      position: absolute;
      background: var(--linen);
      border: 1px solid rgba(61,47,34,0.1);
      border-radius: 14px;
      padding: 10px 14px;
      box-shadow: 0 12px 32px rgba(61,47,34,0.1);
      font-size: 12px;
      display: flex; align-items: center; gap: 8px;
      z-index: 3;
    }
    .hero-proof-dot {
      width: 28px; height: 28px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 14px; flex-shrink: 0;
    }
    .hero-proof-info strong {
      display: block;
      font-family: 'Fraunces', serif;
      font-size: 13px; color: var(--brown);
      font-weight: 700; line-height: 1;
    }
    .hero-proof-info span {
      font-size: 10px; color: var(--brown-md);
      letter-spacing: 0.06em; text-transform: uppercase;
    }
    .hero-proof-1 { top: 20px; left: -10px; transform: rotate(-3deg); }
    .hero-proof-1 .hero-proof-dot { background: rgba(168,184,154,0.3); color: var(--sage-dk); }
    .hero-proof-2 { top: 200px; right: -20px; transform: rotate(2deg); }
    .hero-proof-2 .hero-proof-dot { background: rgba(232,155,60,0.2); color: var(--mango-dk); }
    .hero-proof-3 { bottom: 30px; left: 10px; transform: rotate(-1deg); }
    .hero-proof-3 .hero-proof-dot { background: rgba(184,144,96,0.25); color: var(--earth-dk); }

    /* ── PARALLEL POSITIONING (3 vs 1) ── */
    .parallel-section {
      padding: 110px 32px;
      background: var(--cottage);
    }
    .parallel-inner { max-width: 1080px; margin: 0 auto; }
    .parallel-header { text-align: center; margin-bottom: 56px; }
    .parallel-eyebrow {
      font-size: 11px; font-weight: 700; letter-spacing: 0.2em;
      text-transform: uppercase; color: var(--mango-dk);
      margin-bottom: 14px;
    }
    .parallel-title {
      font-family: 'Fraunces', serif;
      font-size: clamp(32px, 4.5vw, 52px);
      font-weight: 600; color: var(--brown);
      line-height: 1.1; margin-bottom: 18px;
    }
    .parallel-title em { font-style: italic; color: var(--mango-dk); }
    .parallel-sub {
      font-family: 'Fraunces', serif;
      font-size: 19px; font-weight: 400;
      color: var(--brown-lt); max-width: 580px;
      margin: 0 auto; line-height: 1.5;
    }

    /* Comparison */
    .parallel-compare {
      display: grid; grid-template-columns: 1fr 1.4fr; gap: 24px;
      align-items: stretch;
    }
    .compare-card {
      background: var(--linen);
      border-radius: 24px;
      padding: 36px 32px;
      border: 1px solid rgba(61,47,34,0.06);
      display: flex; flex-direction: column;
    }
    .compare-card.featured {
      background: linear-gradient(165deg, #FDF4E0, #F4E2B8);
      border: 2px solid var(--earth);
      box-shadow: 0 16px 40px rgba(201,162,102,0.2);
      position: relative;
    }
    .compare-card.featured::after {
      content: 'FUNGI FUSION';
      position: absolute; top: 16px; right: 18px;
      font-size: 9px; font-weight: 900; letter-spacing: 0.18em;
      color: var(--earth-dk); background: var(--linen);
      padding: 4px 10px; border-radius: 50px;
    }
    .compare-card h3 {
      font-family: 'Fraunces', serif;
      font-size: 22px; font-weight: 600;
      color: var(--brown); margin-bottom: 24px;
    }
    .compare-ingredient {
      display: flex; align-items: center; gap: 16px;
      padding: 14px 0;
      border-bottom: 1px solid rgba(61,47,34,0.08);
    }
    .compare-ingredient:last-child { border-bottom: none; }
    .compare-ingredient-dose {
      font-family: 'Fraunces', serif;
      font-size: 22px; font-weight: 700;
      min-width: 75px; color: var(--brown);
    }
    .compare-card.standard .compare-ingredient-dose { color: var(--brown-md); }
    .compare-ingredient-info strong {
      display: block; font-size: 14px; font-weight: 800;
      color: var(--brown);
    }
    .compare-ingredient-info span {
      font-size: 12px; color: var(--brown-md);
      font-family: 'Fraunces', serif; font-style: italic;
    }
    .compare-empty {
      padding: 20px 0; text-align: center;
      font-size: 14px; color: var(--brown-md);
      font-style: italic;
    }

    /* ── COFFEE vs HAPPIE ── */
    .switch-section {
      padding: 110px 32px;
      background: var(--linen);
    }
    .switch-inner { max-width: 1080px; margin: 0 auto; }
    .switch-header { text-align: center; margin-bottom: 56px; }
    .switch-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 0;
      background: var(--cottage); border-radius: 24px;
      overflow: hidden; border: 1px solid rgba(61,47,34,0.07);
    }
    .switch-col {
      padding: 40px 32px;
      display: flex; flex-direction: column;
    }
    .switch-col.coffee {
      background: linear-gradient(165deg, #F0E5D2, #DDCFB5);
    }
    .switch-col.happie {
      background: linear-gradient(165deg, #FFFEF7, #F5EFE0);
    }
    .switch-col-label {
      display: inline-block;
      font-size: 10px; font-weight: 800; letter-spacing: 0.18em;
      text-transform: uppercase; padding: 5px 12px;
      border-radius: 50px; margin-bottom: 16px; align-self: flex-start;
    }
    .switch-col.coffee .switch-col-label { background: rgba(61,47,34,0.15); color: var(--brown); }
    .switch-col.happie .switch-col-label { background: var(--brown); color: var(--linen); }
    .switch-col h3 {
      font-family: 'Fraunces', serif;
      font-size: 26px; font-weight: 600;
      color: var(--brown); margin-bottom: 8px;
      line-height: 1.15;
    }
    .switch-col p {
      font-size: 14px; color: var(--brown-lt);
      line-height: 1.7; margin-bottom: 20px;
    }
    .switch-timeline { list-style: none; padding: 0; flex: 1; }
    .switch-timeline li {
      display: flex; align-items: flex-start; gap: 12px;
      padding: 10px 0; font-size: 13.5px; line-height: 1.6;
    }
    .switch-time {
      font-family: 'Fraunces', serif;
      font-weight: 700; font-size: 13px;
      color: var(--brown-md); min-width: 60px;
    }

    /* ── REVIEWS ── */
    .reviews-section {
      padding: 110px 32px;
      background: var(--cream);
    }
    .reviews-inner { max-width: 1100px; margin: 0 auto; }
    .reviews-header { text-align: center; margin-bottom: 52px; }
    .reviews-grid {
      display: grid; grid-template-columns: repeat(3,1fr); gap: 22px;
    }
    .review-card {
      background: var(--linen);
      border-radius: 22px;
      padding: 30px 28px;
      border: 1px solid rgba(61,47,34,0.06);
    }
    .review-stars {
      color: var(--mango); font-size: 14px; letter-spacing: 1px;
      margin-bottom: 12px;
    }
    .review-text {
      font-family: 'Fraunces', serif;
      font-size: 15px; font-style: italic; font-weight: 400;
      color: var(--brown-lt); line-height: 1.65;
      margin-bottom: 18px;
    }
    .review-by {
      font-size: 12px; color: var(--sage-dk);
      font-weight: 800; letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    /* ── TRUST BAR ── */
    .trust-section {
      padding: 60px 32px;
      background: var(--brown);
      color: var(--cream);
    }
    .trust-inner {
      max-width: 1000px; margin: 0 auto;
      display: grid; grid-template-columns: repeat(4,1fr); gap: 0;
      text-align: center;
    }
    .trust-item { padding: 0 16px; }
    .trust-item + .trust-item { border-left: 1px solid rgba(242,233,210,0.15); }
    .trust-item svg { stroke: var(--earth-lt); margin-bottom: 10px; }
    .trust-item strong { display: block; font-size: 13px; margin-bottom: 4px; font-weight: 800; }
    .trust-item span { font-size: 12px; color: rgba(242,233,210,0.7); }

    /* ── FINAL CTA ── */
    .final-cta {
      padding: 130px 32px;
      background:
        radial-gradient(ellipse at 30% 30%, rgba(232,155,60,0.18) 0%, transparent 60%),
        radial-gradient(ellipse at 70% 70%, rgba(168,184,154,0.15) 0%, transparent 60%),
        linear-gradient(165deg, var(--linen) 0%, var(--cream) 100%);
      text-align: center;
    }
    .final-cta-inner { max-width: 720px; margin: 0 auto; }
    .final-cta h2 {
      font-family: 'Fraunces', serif;
      font-size: clamp(40px, 5.5vw, 64px);
      font-weight: 600; color: var(--brown);
      line-height: 1.02; margin-bottom: 22px;
    }
    .final-cta h2 em { font-style: italic; color: var(--mango-dk); }
    .final-cta p {
      font-family: 'Fraunces', serif;
      font-size: 19px; color: var(--brown-lt);
      line-height: 1.55; margin-bottom: 40px;
      max-width: 520px; margin-left: auto; margin-right: auto;
    }
    .final-cta-row {
      display: flex; justify-content: center; gap: 18px;
      flex-wrap: wrap; align-items: center;
    }
    .disclaimer {
      font-size: 11px; color: var(--brown-md); opacity: 0.7;
      max-width: 540px; margin: 48px auto 0;
      line-height: 1.6;
    }

    /* ── FOOTER ── */
    .lp-footer {
      padding: 28px 32px;
      background: var(--brown);
      color: rgba(242,233,210,0.7);
      display: flex; justify-content: space-between; align-items: center;
      font-size: 12px;
    }
    .lp-footer-links { display: flex; gap: 22px; }
    .lp-footer-links a:hover { color: var(--linen); }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
      .hero-inner { grid-template-columns: 1fr; gap: 56px; }
      .hero { padding: 110px 24px 60px; }
      .hero-visual { order: -1; min-height: 400px; }
      .hero-can { width: 230px; }
      .hero-proof { font-size: 10px; padding: 8px 11px; }
      .hero-proof-dot { width: 22px; height: 22px; font-size: 11px; }
      .parallel-compare { grid-template-columns: 1fr; }
      .switch-grid { grid-template-columns: 1fr; }
      .reviews-grid { grid-template-columns: 1fr; max-width: 480px; margin-left: auto; margin-right: auto; }
      .trust-inner { grid-template-columns: repeat(2,1fr); gap: 24px; }
      .trust-item + .trust-item { border-left: none; }
      .trust-item:nth-child(odd) { border-right: 1px solid rgba(242,233,210,0.15); }
      .lp-footer { flex-direction: column; gap: 14px; text-align: center; }
      section { padding-left: 20px !important; padding-right: 20px !important; }
    }
  </style>
</head>
<body>

  <!-- NAV -->
