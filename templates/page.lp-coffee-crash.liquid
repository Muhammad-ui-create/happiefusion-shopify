        </div>
        <div class="compare-card featured">
          <h3>Happie Fungi Fusion</h3>
          <div class="compare-ingredient">
            <div class="compare-ingredient-dose">900mg</div>
            <div class="compare-ingredient-info">
              <strong>Lion's Mane</strong>
              <span>focus &amp; mental clarity</span>
            </div>
          </div>
          <div class="compare-ingredient">
            <div class="compare-ingredient-dose">700mg</div>
