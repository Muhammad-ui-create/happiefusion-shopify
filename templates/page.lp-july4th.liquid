{%- comment -%}
  Landing page: July 4th — Alcohol Alternative angle
  Code: USA10 (10% off)  ·  Live in Shopify Discounts through Jul 6
  Auto-applies the discount when the user clicks Add to Cart
  Target SKU: Blue Razzberry 6-Pack ($23.99)
{%- endcomment -%}

{%- assign product = all_products['blue-razzberry-fungi-powered-seltzer'] -%}
{%- assign variant = product.selected_or_first_available_variant -%}
{%- assign price = variant.price -%}
{%- assign discounted_price = price | times: 90 | divided_by: 100 -%}
{%- assign savings = price | minus: discounted_price -%}

<div class="lp-july4">

  <!-- ── PROMO BANNER ── -->
  <div class="lp-promo">
    <div class="lp-promo-inner">
      <span class="lp-promo-flag" aria-hidden="true">🇺🇸</span>
      <div class="lp-promo-text">
        <strong>July 4th Independence Day Sale</strong>
        <span>10% Off Sitewide — Code <code>USA10</code> applied automatically at checkout</span>
      </div>
      <span class="lp-promo-flag" aria-hidden="true">🇺🇸</span>
    </div>
  </div>

  <div class="product-page lp-product-page">
    <div class="breadcrumb">
      <a href="/">Home</a> /
      <span>July 4th Special — {{ product.title }}</span>
    </div>

    <div class="product-layout">

      <!-- ======= LEFT: Image Gallery ======= -->
      <div class="product-gallery">
        <div class="gallery-main">
          {%- assign first_image = product.images | first -%}
          <img
            id="gallery-main-img"
            src="{{ first_image | image_url: width: 900 }}"
            alt="{{ first_image.alt | default: product.title }}"
            class="gallery-main-img"
            width="900" height="900"
            loading="eager"
            fetchpriority="high"
          />
        </div>
        {%- if product.images.size > 1 -%}
          <div class="gallery-thumbs">
            {%- for image in product.images -%}
              <div
                class="gallery-thumb {% if forloop.first %}active{% endif %}"
                data-index="{{ forloop.index0 }}"
                data-src="{{ image | image_url: width: 900 }}"
              >
                <img src="{{ image | image_url: width: 160 }}" alt="{{ image.alt | default: product.title }}" loading="lazy" width="160" height="160" />
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <!-- ======= RIGHT: Product Info ======= -->
      <div class="product-info">

        <!-- Limited offer badge -->
        <div class="lp-offer-tag">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <span>LIMITED — Sale Ends July 6</span>
        </div>

        <h1 class="product-title">The Sober-Curious Alternative to Beer & Cocktails</h1>
        <p class="product-subtitle">Blue Razzberry · Functional Mushroom Drink · 6-Pack</p>

        <!-- Price with cut-off + savings -->
        <div class="product-price-row lp-price-row">
          <span class="product-price lp-price-new">{{ discounted_price | money }}</span>
          <span class="product-compare-price lp-price-old">{{ price | money }}</span>
          <span class="lp-price-save">Save {{ savings | money }} with USA10</span>
        </div>

        <!-- Angle-specific description -->
        <div class="product-desc lp-desc">
          <p><strong>This July 4th, raise something that lifts you — not slows you down.</strong></p>
          <p>Happie Fungi Fusion is the alcohol-free can you bring to the cookout. Three functional mushrooms — 900mg Lion's Mane, 700mg Cordyceps, 400mg Reishi — deliver focus, energy, and calm without the next-morning fog.</p>
          <ul class="lp-desc-list">
            <li>✓ <strong>Zero alcohol.</strong> Drive home, host the BBQ, watch the fireworks — clear-headed.</li>
            <li>✓ <strong>Zero caffeine.</strong> No jitters, no 3 AM stare at the ceiling.</li>
            <li>✓ <strong>40 calories</strong> per can. Lightly sweetened with organic agave.</li>
            <li>✓ <strong>Real effects from real mushrooms.</strong> Not a placebo seltzer.</li>
          </ul>
        </div>

        <!-- Quantity -->
        <div class="qty-row">
          <div class="qty-label">Quantity</div>
          <div class="qty-stepper">
            <button type="button" class="qty-btn" id="lp-qty-minus" aria-label="Decrease quantity">−</button>
            <input type="number" id="lp-qty-input" value="1" min="1" max="20" step="1" inputmode="numeric" pattern="[0-9]*" class="qty-input" />
            <button type="button" class="qty-btn" id="lp-qty-plus" aria-label="Increase quantity">+</button>
          </div>
        </div>

        <!-- Add to Cart — auto-applies USA10 at checkout -->
        <button type="button" class="btn-atc lp-atc" id="lp-atc-btn" data-variant-id="{{ variant.id }}" data-discount="USA10">
          <span id="lp-atc-text">ADD TO CART — <s style="opacity:0.55;">{{ price | money }}</s> {{ discounted_price | money }}</span>
        </button>
        <p class="lp-atc-note">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="vertical-align:-2px;margin-right:4px;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <strong>USA10 auto-applied at checkout.</strong> No code needed.
        </p>

        <!-- Trust pills -->
        <div class="product-trust-pills">
          <span class="trust-pill">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="6" width="15" height="11" rx="2"/><path d="M16 10h4l3 3v4h-7"/><circle cx="5.5" cy="19.5" r="1.5"/><circle cx="20.5" cy="19.5" r="1.5"/></svg>
            Free Shipping — No Minimum
          </span>
          <span class="trust-pill">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22V12"/><path d="M12 12C12 12 7 10 6 6c3 0 6 2 6 6z"/><path d="M12 12c0 0 5-2 6-6-3 0-6 2-6 6z"/></svg>
            100% Vegan
          </span>
          <a href="/pages/the-science#lab-results" class="trust-pill trust-pill-link">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3h6l1 4H8L9 3z"/><path d="M8 7v10a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V7"/><path d="M12 11v3M11 13h2"/></svg>
            3rd-Party Lab Tested
          </a>
        </div>

      </div><!-- /product-info -->
    </div><!-- /product-layout -->

    <!-- ── TRUST FAQ ── -->
    <section class="pdp-faq lp-faq">
      <div class="pdp-faq-inner">
        <div class="pdp-faq-head">
          <span class="pdp-faq-eyebrow">First-Time Buyer Questions</span>
          <h2 class="pdp-faq-title">Why this beats a beer at the BBQ.</h2>
        </div>
        <div class="pdp-faq-grid">

          <details class="pdp-faq-item" open>
            <summary class="pdp-faq-q">
              <span class="pdp-faq-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/><circle cx="12" cy="12" r="10"/></svg></span>
              <span>Is this actually 0% alcohol?</span>
              <span class="pdp-faq-chev"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg></span>
            </summary>
            <div class="pdp-faq-a">
              <p><strong>Yes — completely non-alcoholic.</strong> 0.0% ABV. Safe to drink while driving, at work, around the kids, or pregnant (always check with your doctor on the last one). Looks like a craft cocktail, tastes refreshing, but won't put you on the couch.</p>
            </div>
          </details>

          <details class="pdp-faq-item">
            <summary class="pdp-faq-q">
              <span class="pdp-faq-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/></svg></span>
              <span>Will I feel anything at all?</span>
              <span class="pdp-faq-chev"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg></span>
            </summary>
            <div class="pdp-faq-a">
              <p><strong>20–40 minutes in.</strong> Lion's Mane brings clear, calm focus. Cordyceps adds steady energy. Reishi takes the edge off without sedating you. It's a present, sociable feeling — not a buzz, not a stimulant rush.</p>
            </div>
          </details>

          <details class="pdp-faq-item">
            <summary class="pdp-faq-q">
              <span class="pdp-faq-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></span>
              <span>What if I don't like the taste?</span>
              <span class="pdp-faq-chev"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg></span>
            </summary>
            <div class="pdp-faq-a">
              <p><strong>30-day full refund, no return needed.</strong> Email <a href="mailto:orders@livehappie.com">orders@livehappie.com</a> within 30 days. Tastes like sparkling juice — Blue Razz is tart and candy-bright. No earthy mushroom flavor.</p>
            </div>
          </details>

        </div>
      </div>
    </section>

  </div><!-- /product-page -->

</div><!-- /lp-july4 -->

<style>
  .lp-promo {
    background: linear-gradient(90deg, #B22234 0%, #1A2761 50%, #B22234 100%);
    color: #fff;
    padding: 14px 20px;
    text-align: center;
    border-bottom: 3px solid #fff;
    position: relative;
    overflow: hidden;
  }
  .lp-promo::before, .lp-promo::after {
    content: ''; position: absolute; top: 0; bottom: 0; width: 80px;
    background: repeating-linear-gradient(45deg, rgba(255,255,255,0.08), rgba(255,255,255,0.08) 6px, transparent 6px, transparent 12px);
    pointer-events: none;
  }
  .lp-promo::before { left: 0; }
  .lp-promo::after { right: 0; }
  .lp-promo-inner {
    display: inline-flex; align-items: center; gap: 14px;
    position: relative; z-index: 1;
  }
  .lp-promo-flag { font-size: 22px; line-height: 1; }
  .lp-promo-text { display: flex; flex-direction: column; line-height: 1.3; text-align: left; }
  .lp-promo-text strong { font-size: 15px; font-weight: 900; letter-spacing: 0.04em; }
  .lp-promo-text span { font-size: 12px; opacity: 0.92; }
  .lp-promo-text code {
    background: rgba(255,255,255,0.18);
    padding: 1px 8px; border-radius: 4px;
    font-family: 'Poppins', monospace;
    font-weight: 800; letter-spacing: 0.06em;
  }
  .lp-product-page { padding-top: 32px; }
  .lp-offer-tag {
    display: inline-flex; align-items: center; gap: 8px;
    background: linear-gradient(135deg, #B22234, #DC143C);
    color: #fff;
    padding: 8px 16px; border-radius: 50px;
    font-size: 11px; font-weight: 800; letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 18px;
    box-shadow: 0 6px 18px rgba(178,34,52,0.25);
    animation: lpOfferPulse 2.4s ease-in-out infinite;
  }
  @keyframes lpOfferPulse {
    0%, 100% { box-shadow: 0 6px 18px rgba(178,34,52,0.25); }
    50%      { box-shadow: 0 6px 24px rgba(178,34,52,0.45); }
  }
  .lp-price-row { position: relative; }
  .lp-price-new { color: var(--green-dark, #2D6A4F) !important; }
  .lp-price-old { text-decoration: line-through; opacity: 0.7; }
  .lp-price-save {
    background: var(--green-dark, #2D6A4F); color: #fff;
    padding: 5px 12px; border-radius: 50px;
    font-size: 12px; font-weight: 800; letter-spacing: 0.04em;
    margin-left: auto;
  }
  .lp-desc-list { list-style: none; padding: 0; margin: 14px 0 0; }
  .lp-desc-list li { padding: 6px 0; font-size: 14.5px; }
  .lp-desc-list li + li { border-top: 1px dashed rgba(0,0,0,0.06); }
  .lp-atc {
    background: linear-gradient(135deg, var(--green-dark, #2D6A4F), #1B4332) !important;
    color: #fff !important;
    padding: 20px !important;
    font-size: 16px !important;
    letter-spacing: 0.04em;
    box-shadow: 0 14px 32px rgba(45,106,79,0.30);
    transition: transform .2s, box-shadow .2s, background .2s !important;
  }
  .lp-atc:hover { transform: translateY(-2px); box-shadow: 0 18px 40px rgba(45,106,79,0.42); }
  .lp-atc:disabled { opacity: 0.7; cursor: wait; }
  .lp-atc-note {
    text-align: center; font-size: 12.5px;
    color: var(--gray, #5A6B5E); margin: 10px 0 18px;
  }
  .lp-atc-note strong { color: var(--green-dark, #2D6A4F); }
  .lp-faq { background: linear-gradient(180deg, var(--cream, #FFE6CB) 0%, #FDF3E0 100%); }
  @media (max-width: 768px) {
    .lp-promo { padding: 12px 14px; }
    .lp-promo-text strong { font-size: 13px; }
    .lp-promo-text span { font-size: 11px; }
    .lp-price-save { width: 100%; margin-left: 0; margin-top: 8px; text-align: center; }
  }
</style>

<script>
(function() {
  var btn = document.getElementById('lp-atc-btn');
  if (!btn) return;
  var qtyInput = document.getElementById('lp-qty-input');
  var qtyMinus = document.getElementById('lp-qty-minus');
  var qtyPlus  = document.getElementById('lp-qty-plus');
  var txtEl    = document.getElementById('lp-atc-text');

  if (qtyMinus) qtyMinus.addEventListener('click', function() {
    var v = parseInt(qtyInput.value) || 1; if (v > 1) qtyInput.value = v - 1;
  });
  if (qtyPlus)  qtyPlus.addEventListener('click', function() {
    var v = parseInt(qtyInput.value) || 1; if (v < 20) qtyInput.value = v + 1;
  });

  btn.addEventListener('click', function() {
    var variantId = btn.dataset.variantId;
    var discount  = btn.dataset.discount;
    var qty = Math.max(1, Math.min(20, parseInt(qtyInput.value) || 1));
    if (!variantId) return;

    btn.disabled = true;
    if (txtEl) txtEl.textContent = 'Adding…';

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: qty })
    }).then(function(r) {
      if (!r.ok) throw new Error('Sorry — we couldn\'t add that to your cart.');
      return r.json();
    }).then(function() {
      if (txtEl) txtEl.textContent = '✓ Added — applying USA10…';
      window.location.href = '/discount/' + encodeURIComponent(discount) + '?redirect=/checkout';
    }).catch(function() {
      btn.disabled = false;
      if (txtEl) txtEl.textContent = 'ADD TO CART';
      alert('Couldn\'t add to cart. Please refresh and try again.');
    });
  });
})();
</script>