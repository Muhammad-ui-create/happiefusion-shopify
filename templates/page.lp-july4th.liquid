  .lp-rating-count { color: var(--gray, #5A6B5E); font-weight: 600; }

  /* ── Amazon reviews section ── */
  .lp-reviews {
    padding: 80px 24px;
    background: linear-gradient(180deg, transparent 0%, #FAF4E7 60%, #FFF8EE 100%);
    position: relative;
  }
  .lp-reviews-inner { max-width: 1100px; margin: 0 auto; }
  .lp-reviews-head { text-align: center; margin-bottom: 48px; }
  .lp-reviews-stars {
    font-size: 32px; letter-spacing: 6px;
    color: #F5A623;
    text-shadow: 0 2px 6px rgba(245,166,35,0.20);
    margin-bottom: 16px;
  }
  .lp-reviews-score {
    display: inline-flex; align-items: baseline; gap: 6px;
