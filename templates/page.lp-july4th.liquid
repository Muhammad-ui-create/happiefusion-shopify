  }
  .lp-rev-body {
    font-size: 14.5px; color: #333; line-height: 1.65;
    margin: 0 0 22px;
    font-style: normal; font-weight: 500;
    position: relative; z-index: 1;
  }
  .lp-rev-foot {
    display: flex; align-items: center; gap: 12px;
    margin-top: auto; padding-top: 16px;
    border-top: 1px dashed rgba(0,0,0,0.10);
    position: relative; z-index: 1;
  }
  .lp-rev-avatar {
    width: 38px; height: 38px; border-radius: 50%;
    color: #fff; font-weight: 800; font-size: 13px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 3px 8px rgba(0,0,0,0.15);
  }
  .lp-rev-author { display: flex; flex-direction: column; line-height: 1.35; min-width: 0; }
  .lp-rev-author strong { font-size: 13.5px; color: var(--ink, #1A1A1A); font-weight: 700; }
  .lp-rev-verified {
    font-size: 11px; color: #B8730A; font-weight: 700;
    display: inline-flex; align-items: center; gap: 4px;
  }
  .lp-reviews-foot { text-align: center; }
  .lp-reviews-foot a {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--green-dark, #2D6A4F); color: #fff;
    padding: 14px 28px; border-radius: 50px;
    font-weight: 800; font-size: 14px; letter-spacing: 0.02em;
    text-decoration: none;
    box-shadow: 0 8px 22px rgba(45,106,79,0.25);
    transition: transform .2s, box-shadow .2s, background .2s;
  }
  .lp-reviews-foot a:hover {
    transform: translateY(-2px);
    background: #1B4332;
    box-shadow: 0 14px 32px rgba(45,106,79,0.40);
  }
  @media (max-width: 768px) {
    .lp-reviews { padding: 56px 16px; }
    .lp-reviews-grid { grid-template-columns: 1fr; gap: 16px; }
    .lp-video-row { grid-template-columns: repeat(3, 1fr); gap: 8px; }
    .lp-video { border-radius: 12px; }
    .lp-rev { padding: 24px 22px 20px; }
    .lp-rev::after { font-size: 80px; top: 4px; right: 16px; }
  }

  .lp-faq { background: linear-gradient(180deg, var(--cream, #FFE6CB) 0%, #FDF3E0 100%); }
  @media (max-width: 768px) {
    .lp-promo { padding: 12px 14px; }
    .lp-promo-text strong { font-size: 13px; }
    .lp-promo-text span { font-size: 11px; }
    .lp-price-save { width: 100%; margin-left: 0; margin-top: 8px; text-align: center; }
  }
</style>

<script>
(function() {
  /* ════════════════════════════════════════════════
     DISCOUNT INTERCEPTOR — hoisted ABOVE any bailouts.
     Hard-coded constant so it can NEVER pull the wrong code.
     ════════════════════════════════════════════════ */
  var LP_DISCOUNT = 'USA10';

  /* Persist in sessionStorage so the right code applies even if user
     navigates away (e.g. clicks the upsell card) and comes back to checkout */
  try { sessionStorage.setItem('happieLpDiscount', LP_DISCOUNT); } catch(e) {}

  /* (Removed broken pre-warm iframe — Shopify CSP frame-ancestors 'none' blocks it.
     The capture-phase checkout interceptor below still applies the discount via top-level nav.) */

  /* Capture-phase click on the cart drawer Checkout button — runs first, beats
     happie.js handlers and default link nav. Re-routes through /discount/CODE
     so the correct LP code is ALWAYS applied, overwriting any stale cookie. */
  document.addEventListener('click', function(e) {
    var target = e.target.closest('.btn-cart-checkout, a[href="/checkout"], a[href^="/checkout?"]');
    if (!target) return;
    var code = sessionStorage.getItem('happieLpDiscount') || LP_DISCOUNT;
    e.preventDefault();
    e.stopPropagation();
    e.stopImmediatePropagation();
    var fireAndGo = function() {
      window.location.href = '/discount/' + encodeURIComponent(code) + '?redirect=' + encodeURIComponent('/checkout');
    };
    try {
      if (window.fbq) {
        fetch('/cart.js', { headers: { 'Accept': 'application/json' } })
          .then(function(r) { return r.json(); })
          .then(function(cart) {
            fbq('track', 'InitiateCheckout', {
              content_ids: (cart.items || []).map(function(i) { return String(i.variant_id); }),
              content_type: 'product',
              num_items: cart.item_count,
              value: (cart.total_price || 0) / 100,
              currency: (cart.currency || 'USD')
            });
            fireAndGo();
          })
          .catch(fireAndGo);
        return;
      }
    } catch(e2) {}
    fireAndGo();
  }, true);

  /* ── Gallery thumbnail click handler (LPs don't run initProductPage() in happie.js) ── */
  var mainImg = document.getElementById('gallery-main-img');
  var thumbs  = document.querySelectorAll('.gallery-thumb');
  var srcs = [];
  thumbs.forEach(function(t) {
    srcs.push(t.dataset.src);
    t.addEventListener('click', function() {
      if (!mainImg) return;
      mainImg.style.transition = 'opacity 0.18s ease';
      mainImg.style.opacity = '0';
      setTimeout(function() {
        mainImg.src = t.dataset.src;
        mainImg.style.opacity = '1';
      }, 80);
      thumbs.forEach(function(x) { x.classList.remove('active'); });
      t.classList.add('active');
    });
  });
  /* Preload all full-size gallery images after page is idle so swaps are instant */
  function preloadGallery() {
    srcs.forEach(function(s) { var i = new Image(); i.decoding = 'async'; i.src = s; });
  }
  if (document.readyState === 'complete') {
    ('requestIdleCallback' in window) ? requestIdleCallback(preloadGallery, {timeout: 1500}) : setTimeout(preloadGallery, 300);
  } else {
    window.addEventListener('load', function() {
      ('requestIdleCallback' in window) ? requestIdleCallback(preloadGallery, {timeout: 1500}) : setTimeout(preloadGallery, 300);
    }, {once: true});
  }

  var btn = document.getElementById('lp-atc-btn');
  if (!btn) return;
  var qtyInput = document.getElementById('lp-qty-input');
  var qtyMinus = document.getElementById('lp-qty-minus');
  var qtyPlus  = document.getElementById('lp-qty-plus');
  var txtEl    = document.getElementById('lp-atc-text');

  if (qtyMinus) qtyMinus.addEventListener('click', function() {
    var v = parseInt(qtyInput.value) || 1; if (v > 1) qtyInput.value = v - 1;
  });
  if (qtyPlus)  qtyPlus.addEventListener('click', function() {
    var v = parseInt(qtyInput.value) || 1; if (v < 20) qtyInput.value = v + 1;
  });

  /* Discount interceptor lives at the top of this IIFE so it survives any bailouts.
     This block kept as a no-op marker to preserve the script structure. */

  /* Original ATC text — restored after the success flash */
  var originalText = txtEl ? txtEl.innerHTML : 'ADD TO CART';

  btn.addEventListener('click', function() {
    var variantId = btn.dataset.variantId;
    var qty = Math.max(1, Math.min(20, parseInt(qtyInput.value) || 1));
    if (!variantId) return;

    btn.disabled = true;
    if (txtEl) txtEl.textContent = 'Adding…';

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: qty })
    }).then(function(r) {
      if (!r.ok) throw new Error('Sorry — we couldn\'t add that to your cart.');
      return r.json();
    }).then(function() {
      if (txtEl) txtEl.textContent = '✓ Added to Cart!';
      /* Fire Meta Pixel AddToCart so Meta's optimizer gets the mid-funnel signal */
      try {
        if (window.fbq) {
          fbq('track', 'AddToCart', {
            content_ids: [String(variantId)],
            content_type: 'product',
            content_name: {{ product.title | json }},
            value: {{ product.price | divided_by: 100.0 }},
            currency: 'USD',
            num_items: qty
          });
        }
      } catch(e) {}
      /* Open the existing cart drawer — happie.js binds openCart() to this click */
      var cartTrigger = document.getElementById('cart-trigger');
      if (cartTrigger) cartTrigger.click();
      setTimeout(function() {
        btn.disabled = false;
        if (txtEl) txtEl.innerHTML = originalText;
      }, 1800);
    }).catch(function() {
      btn.disabled = false;
      if (txtEl) txtEl.innerHTML = originalText;
      alert('Couldn\'t add to cart. Please refresh and try again.');
    });
  });

  /* ── Lazy-load review videos: only fetch + autoplay when scrolled into viewport ── */
  var videos = document.querySelectorAll('.lp-video[data-src]');
  if (videos.length && 'IntersectionObserver' in window) {
    var vIO = new IntersectionObserver(function(entries) {
      entries.forEach(function(en) {
        if (!en.isIntersecting) return;
        var v = en.target;
        if (!v.src) {
          v.src = v.dataset.src;
          v.load();
          var p = v.play(); if (p && p.catch) p.catch(function(){});
        }
        vIO.unobserve(v);
      });
    }, { rootMargin: '200px 0px' });
    videos.forEach(function(v) { vIO.observe(v); });
  } else {
    videos.forEach(function(v) { v.src = v.dataset.src; v.load(); v.play && v.play(); });
  }
})();
</script>