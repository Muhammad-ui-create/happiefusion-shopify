    margin-bottom: 24px;
  }
  .lp-reviews-score strong { color: var(--ink, #1A1A1A); font-weight: 900; font-size: 18px; }
  .lp-reviews-title {
    font-size: clamp(28px, 3.6vw, 40px); font-weight: 900;
    line-height: 1.12; letter-spacing: -0.025em;
    color: var(--ink, #1A1A1A); margin: 0;
    max-width: 720px; margin-left: auto; margin-right: auto;
  }
  .lp-video-row {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 16px; margin-bottom: 36px;
  }
  .lp-video {
    width: 100%; aspect-ratio: 9 / 16;
    object-fit: cover; border-radius: 16px;
    background: #000; display: block;
    box-shadow: 0 8px 24px rgba(0,0,0,0.12);
  }
  .lp-reviews-grid {
    display: grid; grid-template-columns: repeat(2, 1fr);
    gap: 22px; margin-bottom: 40px;
  }
  .lp-rev {
    background: #fff;
    border: 0;
    border-radius: 22px;
    padding: 28px 28px 22px;
    display: flex; flex-direction: column;
    box-shadow: 0 10px 36px rgba(27,42,31,0.08), 0 2px 6px rgba(27,42,31,0.04);
    position: relative;
    overflow: hidden;
    transition: transform .3s cubic-bezier(0.34,1.56,0.64,1), box-shadow .3s ease;
  }
  .lp-rev::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--green-mid, #52B788), var(--green-dark, #2D6A4F));
  }
  .lp-rev::after {
    content: '"';
    position: absolute;
    top: 8px; right: 22px;
    font-family: 'Times New Roman', Georgia, serif;
    font-size: 110px; line-height: 1;
    color: rgba(45,106,79,0.10);
    pointer-events: none; font-weight: 700;
  }
  .lp-rev:hover {
    transform: translateY(-8px);
    box-shadow: 0 28px 56px rgba(27,42,31,0.15), 0 4px 12px rgba(27,42,31,0.06);
  }
  .lp-rev-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px; position: relative; z-index: 1; }
  .lp-rev-stars { color: #F5A623; font-size: 16px; letter-spacing: 3px; }
  .lp-rev-flavor {
    font-size: 10px; font-weight: 900; letter-spacing: 0.10em; text-transform: uppercase;
    padding: 5px 11px; border-radius: 50px;
  }
  .lp-rev-flavor-blue       { background: rgba(59,111,240,0.12);  color: #2855D4; }
  .lp-rev-flavor-watermelon { background: rgba(232,76,107,0.12); color: #C03060; }
  .lp-rev-flavor-mango      { background: rgba(245,166,35,0.14); color: #B8730A; }
  .lp-rev-title {
    font-size: 16px; font-weight: 800; color: var(--ink, #1A1A1A);
    line-height: 1.3; margin-bottom: 12px;
