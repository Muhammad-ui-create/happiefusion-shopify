<!-- ── Custom ATC: add to cart, then redirect to /discount/FUNGI15?redirect=/checkout for auto-apply ── -->
<script>
(function() {
  /* ════════════════════════════════════════════════
     DISCOUNT INTERCEPTOR — hoisted ABOVE any bailouts.
     Hard-coded constant so it can NEVER pull the wrong code, even if
     the button or any other element fails to render on the page.
     ════════════════════════════════════════════════ */
  var LP_DISCOUNT = 'FUNGI15';

  /* Persist in sessionStorage so the right code applies even if user
     navigates away (e.g. clicks the upsell card) and comes back to checkout */
  try { sessionStorage.setItem('happieLpDiscount', LP_DISCOUNT); } catch(e) {}

  /* Silent iframe — pre-warms the cookie for express checkout (Shop Pay / Apple Pay / Google Pay) */
  (function() {
    var iframe = document.createElement('iframe');
    iframe.style.cssText = 'position:absolute;width:1px;height:1px;border:0;opacity:0;pointer-events:none;left:-9999px;';
    iframe.setAttribute('aria-hidden', 'true');
    iframe.setAttribute('tabindex', '-1');
    iframe.src = '/discount/' + encodeURIComponent(LP_DISCOUNT) + '?redirect=%2Fcart.js';
    (document.body || document.documentElement).appendChild(iframe);
    setTimeout(function() { try { iframe.remove(); } catch(e) {} }, 4000);
  })();

  /* Capture-phase click on the cart drawer Checkout button — runs first, beats
     happie.js handlers and default link nav. Re-routes through /discount/CODE
     so the correct LP code is ALWAYS applied, overwriting any stale cookie. */
  document.addEventListener('click', function(e) {
    var target = e.target.closest('.btn-cart-checkout, a[href="/checkout"], a[href^="/checkout?"]');
    if (!target) return;
    var code = sessionStorage.getItem('happieLpDiscount') || LP_DISCOUNT;
    e.preventDefault();
    e.stopPropagation();
    e.stopImmediatePropagation();
    window.location.href = '/discount/' + encodeURIComponent(code) + '?redirect=' + encodeURIComponent('/checkout');
  }, true);

  /* ── Gallery thumbnail click handler (LPs don't run initProductPage() in happie.js) ── */
  var mainImg = document.getElementById('gallery-main-img');
  var thumbs  = document.querySelectorAll('.gallery-thumb');
  var srcs = [];
  thumbs.forEach(function(t) {
    srcs.push(t.dataset.src);
    t.addEventListener('click', function() {
      if (!mainImg) return;
      mainImg.style.transition = 'opacity 0.18s ease';
      mainImg.style.opacity = '0';
      setTimeout(function() {
        mainImg.src = t.dataset.src;
        mainImg.style.opacity = '1';
      }, 80);
      thumbs.forEach(function(x) { x.classList.remove('active'); });
      t.classList.add('active');
    });
  });
  /* Preload all full-size gallery images after page is idle so swaps are instant */
  function preloadGallery() {
    srcs.forEach(function(s) { var i = new Image(); i.decoding = 'async'; i.src = s; });
  }
  if (document.readyState === 'complete') {
    ('requestIdleCallback' in window) ? requestIdleCallback(preloadGallery, {timeout: 1500}) : setTimeout(preloadGallery, 300);
  } else {
    window.addEventListener('load', function() {
      ('requestIdleCallback' in window) ? requestIdleCallback(preloadGallery, {timeout: 1500}) : setTimeout(preloadGallery, 300);
    }, {once: true});
  }

  var btn = document.getElementById('lp-atc-btn');
  if (!btn) return;
  var qtyInput = document.getElementById('lp-qty-input');
  var qtyMinus = document.getElementById('lp-qty-minus');
  var qtyPlus  = document.getElementById('lp-qty-plus');
  var txtEl    = document.getElementById('lp-atc-text');

  if (qtyMinus) qtyMinus.addEventListener('click', function() {
    var v = parseInt(qtyInput.value) || 1; if (v > 1) qtyInput.value = v - 1;
  });
  if (qtyPlus)  qtyPlus.addEventListener('click', function() {
    var v = parseInt(qtyInput.value) || 1; if (v < 20) qtyInput.value = v + 1;
  });

  /* Discount interceptor lives at the top of this IIFE so it survives any bailouts.
     This block kept as a no-op marker to preserve the script structure. */

  /* Original ATC text — restored after the success flash */
  var originalText = txtEl ? txtEl.innerHTML : 'ADD TO CART';

  btn.addEventListener('click', function() {
    var variantId = btn.dataset.variantId;
    var qty = Math.max(1, Math.min(20, parseInt(qtyInput.value) || 1));
    if (!variantId) return;

    btn.disabled = true;
    if (txtEl) txtEl.textContent = 'Adding…';

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: qty })
    }).then(function(r) {
      if (!r.ok) throw new Error('Sorry — we couldn\'t add that to your cart.');
      return r.json();
    }).then(function() {
      if (txtEl) txtEl.textContent = '✓ Added to Cart!';
      /* Open the existing cart drawer — happie.js binds openCart() to this click */
      var cartTrigger = document.getElementById('cart-trigger');
      if (cartTrigger) cartTrigger.click();
      setTimeout(function() {
        btn.disabled = false;
        if (txtEl) txtEl.innerHTML = originalText;
      }, 1800);
    }).catch(function() {
      btn.disabled = false;
      if (txtEl) txtEl.innerHTML = originalText;
      alert('Couldn\'t add to cart. Please refresh and try again.');
    });
  });
})();
</script>

