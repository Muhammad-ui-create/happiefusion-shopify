{% layout none %}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>400mg of the Queen of Mushrooms — Happie Fusion</title>
  <meta name="robots" content="noindex,nofollow">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Playfair+Display:ital,wght@0,700;1,400;1,700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --black:   #0C0B09;
      --slate:   #1A1814;
      --cream:   #F5F0E8;
      --gold:    #C9A84C;
      --gold-lt: #E8D5A3;
      --sage:    #8B9E7A;
      --white:   #FFFFFF;
      --gray:    #888;
    }
    html { scroll-behavior: smooth; }
    body { font-family: 'Inter', sans-serif; background: var(--black); color: var(--cream); }
    img  { max-width: 100%; display: block; }
    a    { text-decoration: none; color: inherit; }

    /* ── NAV ── */
    .lp-nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      padding: 18px 32px;
      display: flex; justify-content: space-between; align-items: center;
      background: rgba(12,11,9,0.85); backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(201,168,76,0.15);
    }
    .lp-nav-logo img { height: 56px; width: auto; display: block; filter: brightness(0) invert(1); }
    .lp-nav-cta {
      background: var(--gold); color: var(--black);
      border-radius: 50px; padding: 10px 24px;
      font-size: 13px; font-weight: 800; letter-spacing: 0.06em;
    }

    /* ── HERO ── */
    .hero {
      min-height: 100vh;
      background: radial-gradient(ellipse at 30% 40%, #2A2318 0%, var(--slate) 45%, var(--black) 100%);
      display: flex; align-items: center;
      padding: 120px 48px 80px;
      position: relative; overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute; top: 0; left: 0; right: 0; bottom: 0;
      background: radial-gradient(circle at 25% 50%, rgba(201,168,76,0.08) 0%, transparent 60%);
      pointer-events: none;
    }
    .hero-inner {
      max-width: 1200px; margin: 0 auto; width: 100%;
      display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center;
    }
    .hero-eyebrow {
      font-size: 11px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--gold); margin-bottom: 20px;
      display: flex; align-items: center; gap: 10px;
    }
    .hero-eyebrow::before { content: ''; width: 32px; height: 1px; background: var(--gold); }
    .hero-headline {
      font-family: 'Playfair Display', serif;
      font-size: clamp(38px, 5vw, 62px);
      font-style: italic; font-weight: 400;
      line-height: 1.1; color: var(--cream);
      margin-bottom: 24px;
    }
    .hero-headline em { color: var(--gold); font-style: italic; }
    .hero-sub {
      font-size: 18px; color: rgba(245,240,232,0.7); line-height: 1.7;
      margin-bottom: 40px; max-width: 480px;
    }
    .hero-cta-group { display: flex; flex-direction: column; gap: 14px; }
    .btn-primary {
      display: inline-block;
      background: var(--gold); color: var(--black);
      border-radius: 50px; padding: 18px 40px;
      font-size: 15px; font-weight: 800; letter-spacing: 0.04em;
      transition: all 0.2s; text-align: center;
    }
    .btn-primary:hover { background: var(--gold-lt); transform: translateY(-2px); }
    .hero-discount {
      font-size: 13px; color: var(--gold-lt);
      letter-spacing: 0.08em; text-align: center;
    }
    .hero-discount strong { font-weight: 800; }
    .hero-visual { position: relative; display: flex; justify-content: center; align-items: center; }
    .hero-can-wrap {
      position: relative;
      filter: drop-shadow(0 40px 80px rgba(201,168,76,0.25));
    }
    .hero-can { width: 320px; max-width: 100%; border-radius: 24px; }
    .hero-badge {
      position: absolute; top: -20px; right: -20px;
      width: 100px; height: 100px; border-radius: 50%;
      background: var(--gold); display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      box-shadow: 0 8px 32px rgba(201,168,76,0.4);
    }
    .hero-badge-num { font-size: 22px; font-weight: 900; color: var(--black); line-height: 1; }
    .hero-badge-unit { font-size: 10px; font-weight: 700; color: var(--black); letter-spacing: 0.08em; }

    /* ── STATS BAR ── */
    .stats-bar {
      background: var(--slate);
      border-top: 1px solid rgba(201,168,76,0.2);
      border-bottom: 1px solid rgba(201,168,76,0.2);
      padding: 28px 48px;
    }
    .stats-bar-inner {
      max-width: 900px; margin: 0 auto;
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 0; text-align: center;
    }
    .stat-item { padding: 0 24px; }
    .stat-item + .stat-item { border-left: 1px solid rgba(201,168,76,0.2); }
    .stat-num { font-size: 28px; font-weight: 900; color: var(--gold); margin-bottom: 4px; }
    .stat-label { font-size: 12px; color: rgba(245,240,232,0.6); letter-spacing: 0.08em; text-transform: uppercase; }

    /* ── REISHI SECTION ── */
    .reishi-section {
      padding: 100px 48px;
      background: linear-gradient(180deg, var(--black) 0%, var(--slate) 50%, var(--black) 100%);
    }
    .reishi-inner {
      max-width: 1100px; margin: 0 auto;
      display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center;
    }
    .reishi-text .section-eyebrow {
      font-size: 11px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--gold); margin-bottom: 16px;
    }
    .reishi-text h2 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(30px, 4vw, 48px);
      font-weight: 700; line-height: 1.15;
      color: var(--cream); margin-bottom: 24px;
    }
    .reishi-text p {
      font-size: 16px; color: rgba(245,240,232,0.7);
      line-height: 1.8; margin-bottom: 16px;
    }
    .reishi-facts { display: flex; flex-direction: column; gap: 16px; margin-top: 32px; }
    .reishi-fact {
      display: flex; align-items: flex-start; gap: 14px;
      padding: 18px 20px;
      background: rgba(201,168,76,0.06);
      border: 1px solid rgba(201,168,76,0.15);
      border-radius: 14px;
    }
    .reishi-fact-icon { font-size: 20px; flex-shrink: 0; margin-top: 2px; }
    .reishi-fact-title { font-size: 13px; font-weight: 800; color: var(--gold); margin-bottom: 4px; letter-spacing: 0.04em; }
    .reishi-fact-desc { font-size: 13px; color: rgba(245,240,232,0.65); line-height: 1.6; }
    .reishi-visual {
      background: radial-gradient(ellipse at center, rgba(201,168,76,0.1) 0%, transparent 70%);
      border-radius: 32px;
      padding: 48px;
      border: 1px solid rgba(201,168,76,0.15);
      text-align: center;
    }
    .reishi-dose-display {
      font-family: 'Playfair Display', serif;
      font-size: 80px; font-weight: 700; color: var(--gold);
      line-height: 1; margin-bottom: 8px;
    }
    .reishi-dose-label {
      font-size: 14px; letter-spacing: 0.16em; text-transform: uppercase;
      color: rgba(245,240,232,0.6); margin-bottom: 24px;
    }
    .reishi-dose-bar {
      height: 4px; background: rgba(201,168,76,0.2);
      border-radius: 2px; margin-bottom: 10px; overflow: hidden;
    }
    .reishi-dose-fill { height: 100%; background: var(--gold); width: 100%; border-radius: 2px; }
    .reishi-compare {
      display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 24px; text-align: left;
    }
    .compare-item {
      padding: 14px 16px;
      background: rgba(12,11,9,0.6); border-radius: 12px;
      border: 1px solid rgba(201,168,76,0.12);
    }
    .compare-label { font-size: 11px; color: var(--gray); margin-bottom: 4px; letter-spacing: 0.06em; text-transform: uppercase; }
    .compare-val { font-size: 16px; font-weight: 800; color: var(--cream); }
    .compare-val.gold { color: var(--gold); }

    /* ── PRODUCTS ── */
    .products-section { padding: 100px 48px; background: var(--black); }
    .products-inner { max-width: 1100px; margin: 0 auto; }
    .section-header { text-align: center; margin-bottom: 56px; }
    .section-header .section-eyebrow {
      font-size: 11px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--gold); margin-bottom: 12px;
    }
    .section-header h2 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(28px, 4vw, 44px);
      color: var(--cream); font-weight: 700;
    }
    .products-grid {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;
      margin-bottom: 48px;
    }
    .product-card {
      background: var(--slate);
      border: 1px solid rgba(201,168,76,0.15);
      border-radius: 24px; overflow: hidden;
      transition: all 0.3s;
    }
    .product-card:hover { transform: translateY(-6px); border-color: rgba(201,168,76,0.4); }
    .product-card-img {
      background: radial-gradient(ellipse at center, rgba(201,168,76,0.08) 0%, transparent 70%);
      padding: 32px; text-align: center;
    }
    .product-card-img img { height: 200px; width: auto; margin: 0 auto; object-fit: contain; }
    .product-card-body { padding: 20px 24px 24px; }
    .product-card-tag {
      font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--gold); margin-bottom: 8px;
    }
    .product-card-name { font-size: 16px; font-weight: 800; color: var(--cream); margin-bottom: 8px; }
    .product-card-desc { font-size: 13px; color: var(--gray); line-height: 1.6; margin-bottom: 16px; }
    .product-card-price { font-size: 18px; font-weight: 900; color: var(--gold); margin-bottom: 16px; }
    .product-card-btn {
      display: block; text-align: center;
      background: rgba(201,168,76,0.12); color: var(--gold-lt);
      border: 1px solid rgba(201,168,76,0.3);
      border-radius: 50px; padding: 11px 20px;
      font-size: 13px; font-weight: 700;
      transition: all 0.2s;
    }
    .product-card-btn:hover { background: var(--gold); color: var(--black); }
    .products-cta { text-align: center; }

    /* ── RITUAL STEPS ── */
    .ritual-section { padding: 100px 48px; background: var(--slate); }
    .ritual-inner { max-width: 800px; margin: 0 auto; }
    .ritual-steps { display: flex; flex-direction: column; gap: 0; margin-top: 48px; }
    .ritual-step {
      display: flex; gap: 28px; align-items: flex-start;
      padding: 32px 0;
      border-bottom: 1px solid rgba(201,168,76,0.1);
    }
    .ritual-step:last-child { border-bottom: none; }
    .ritual-step-num {
      min-width: 52px; height: 52px; border-radius: 50%;
      border: 2px solid var(--gold); color: var(--gold);
      font-size: 18px; font-weight: 900;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .ritual-step-title { font-size: 18px; font-weight: 800; color: var(--cream); margin-bottom: 8px; }
    .ritual-step-desc { font-size: 15px; color: rgba(245,240,232,0.65); line-height: 1.7; }

    /* ── REVIEWS ── */
    .reviews-section { padding: 100px 48px; background: var(--black); }
    .reviews-inner { max-width: 1100px; margin: 0 auto; }
    .reviews-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 48px; }
    .review-card {
      background: var(--slate);
      border: 1px solid rgba(201,168,76,0.12);
      border-radius: 20px; padding: 28px;
    }
    .review-stars { font-size: 16px; margin-bottom: 14px; letter-spacing: 2px; }
    .review-text { font-size: 15px; color: rgba(245,240,232,0.8); line-height: 1.7; margin-bottom: 20px; font-style: italic; }
    .review-author { font-size: 13px; font-weight: 700; color: var(--gold); }

    /* ── TRUST BAR ── */
    .trust-section {
      padding: 60px 48px;
      background: linear-gradient(135deg, #1A1814, #0C0B09);
      border-top: 1px solid rgba(201,168,76,0.15);
      border-bottom: 1px solid rgba(201,168,76,0.15);
    }
    .trust-inner {
      max-width: 900px; margin: 0 auto;
      display: grid; grid-template-columns: repeat(4, 1fr);
      gap: 0; text-align: center;
    }
    .trust-item { padding: 0 20px; }
    .trust-item + .trust-item { border-left: 1px solid rgba(201,168,76,0.15); }
    .trust-icon { font-size: 28px; margin-bottom: 10px; }
    .trust-title { font-size: 13px; font-weight: 800; color: var(--cream); margin-bottom: 4px; }
    .trust-desc { font-size: 12px; color: var(--gray); line-height: 1.5; }

    /* ── FINAL CTA ── */
    .final-cta {
      padding: 120px 48px;
      background: radial-gradient(ellipse at center, #2A2318 0%, var(--black) 70%);
      text-align: center;
    }
    .final-cta h2 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(32px, 5vw, 58px);
      font-style: italic; color: var(--cream);
      margin-bottom: 20px; max-width: 700px; margin-left: auto; margin-right: auto;
    }
    .final-cta h2 em { color: var(--gold); }
    .final-cta p {
      font-size: 17px; color: rgba(245,240,232,0.65);
      margin-bottom: 48px; max-width: 500px;
      margin-left: auto; margin-right: auto;
    }
    .final-cta-btns { display: flex; justify-content: center; gap: 16px; flex-wrap: wrap; }
    .btn-secondary {
      display: inline-block;
      background: transparent; color: var(--gold-lt);
      border: 1px solid rgba(201,168,76,0.4);
      border-radius: 50px; padding: 16px 32px;
      font-size: 14px; font-weight: 700;
      transition: all 0.2s;
    }
    .btn-secondary:hover { border-color: var(--gold); color: var(--gold); }
    .disclaimer {
      font-size: 11px; color: rgba(245,240,232,0.35);
      max-width: 600px; margin: 40px auto 0; line-height: 1.6;
    }

    /* ── FOOTER ── */
    .lp-footer {
      padding: 32px 48px;
      background: var(--black);
      border-top: 1px solid rgba(201,168,76,0.1);
      display: flex; justify-content: space-between; align-items: center;
    }
    .lp-footer-logo { font-size: 13px; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; color: var(--gold); }
    .lp-footer-links { display: flex; gap: 24px; }
    .lp-footer-links a { font-size: 12px; color: var(--gray); transition: color 0.2s; }
    .lp-footer-links a:hover { color: var(--cream); }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
      .hero-inner, .reishi-inner { grid-template-columns: 1fr; gap: 48px; }
      .hero { padding: 100px 24px 60px; }
      .hero-visual { order: -1; }
      .hero-can { width: 240px; }
      .products-grid { grid-template-columns: 1fr; max-width: 400px; margin-left: auto; margin-right: auto; }
      .reviews-grid { grid-template-columns: 1fr; }
      .trust-inner { grid-template-columns: repeat(2, 1fr); gap: 24px; }
      .trust-item + .trust-item { border-left: none; }
      .trust-item:nth-child(odd) { border-right: 1px solid rgba(201,168,76,0.15); }
      .stats-bar-inner { grid-template-columns: 1fr; gap: 16px; }
      .stat-item + .stat-item { border-left: none; border-top: 1px solid rgba(201,168,76,0.2); padding-top: 16px; }
      .reishi-compare { grid-template-columns: 1fr; }
      .lp-footer { flex-direction: column; gap: 16px; text-align: center; }
      section { padding-left: 24px !important; padding-right: 24px !important; }
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav class="lp-nav">
    <a href="/" class="lp-nav-logo"><img src="{{ 'happie-logo.png' | asset_url }}" alt="Happie Fusion"></a>
    <a href="/collections/all?discount=WINDOWN15" class="lp-nav-cta">Shop — 15% Off</a>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-text">
        <div class="hero-eyebrow">The Evening Ritual</div>
        <h1 class="hero-headline">
          400mg of the<br><em>queen of mushrooms.</em>
        </h1>
        <p class="hero-sub">Reishi. For the wind-down. Dual-extracted for 3–7× the absorption of capsules. No alcohol. No caffeine. Just 2,000 years of wisdom in every can.</p>
        <div class="hero-cta-group">
          <a href="/collections/all?discount=WINDOWN15" class="btn-primary">Shop Fungi Fusion →</a>
          <div class="hero-discount">Use code <strong>WINDOWN15</strong> for 15% off your first order</div>
        </div>
      </div>
      <div class="hero-visual">
        <div class="hero-can-wrap">
          <img src="{{ 'can-watermelon.png' | asset_url }}" alt="Happie Fungi Fusion Can" class="hero-can">
          <div class="hero-badge">
            <div class="hero-badge-num">400</div>
            <div class="hero-badge-unit">MG REISHI</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS BAR -->
  <div class="stats-bar">
    <div class="stats-bar-inner">
      <div class="stat-item">
        <div class="stat-num">400mg</div>
        <div class="stat-label">Reishi Per Can</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">3–7×</div>
        <div class="stat-label">Better Absorption than Capsules</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">0</div>
        <div class="stat-label">Alcohol · Caffeine · Junk</div>
      </div>
    </div>
  </div>

  <!-- REISHI EDUCATION -->
  <section class="reishi-section">
    <div class="reishi-inner">
      <div class="reishi-text">
        <div class="section-eyebrow">The Ingredient</div>
        <h2>Called the queen of mushrooms for 2,000 years.</h2>
        <p>Reishi (<em>Ganoderma lucidum</em>) has been the crown jewel of Eastern wellness traditions for millennia. We don't sprinkle it — we dose it at 400mg per can, dual-extracted so your body actually absorbs it.</p>
        <p>The result? A calm, clear wind-down that works with your body's natural rhythm — not against it.</p>
        <div class="reishi-facts">
          <div class="reishi-fact">
            <div class="reishi-fact-icon">🌙</div>
            <div>
              <div class="reishi-fact-title">Evening Calm</div>
              <div class="reishi-fact-desc">Reishi supports your body's natural stress response so you actually unwind — not just zone out.</div>
            </div>
          </div>
          <div class="reishi-fact">
            <div class="reishi-fact-icon">🧪</div>
            <div>
              <div class="reishi-fact-title">Dual-Extracted</div>
