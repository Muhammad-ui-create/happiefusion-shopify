            <div class="reishi-fact-icon">✅</div>
            <div>
              <div class="reishi-fact-title">Third-Party Tested</div>
              <div class="reishi-fact-desc">Every batch COA verified. You get exactly what's on the label — nothing more, nothing less.</div>
            </div>
          </div>
        </div>
      </div>
      <div class="reishi-visual">
        <div class="reishi-dose-display">400</div>
        <div class="reishi-dose-label">MG REISHI PER CAN</div>
        <div class="reishi-dose-bar"><div class="reishi-dose-fill"></div></div>
        <div style="font-size:11px;color:var(--gray);margin-bottom:24px;">Full therapeutic dose. Every single can.</div>
        <div class="reishi-compare">
          <div class="compare-item">
            <div class="compare-label">Happie Fusion</div>
            <div class="compare-val gold">400mg ✓</div>
          </div>
          <div class="compare-item">
            <div class="compare-label">Typical Capsule</div>
            <div class="compare-val">~50mg absorbed</div>
          </div>
          <div class="compare-item">
            <div class="compare-label">Alcohol Content</div>
            <div class="compare-val gold">Zero</div>
          </div>
          <div class="compare-item">
            <div class="compare-label">Caffeine</div>
            <div class="compare-val gold">None</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PRODUCTS -->
  <section class="products-section">
    <div class="products-inner">
      <div class="section-header">
        <div class="section-eyebrow">Choose Your Wind-Down</div>
        <h2>Three flavors. One ritual.</h2>
      </div>
      <div class="products-grid">
        <div class="product-card">
          <div class="product-card-img">
            <img src="{{ 'can-watermelon.png' | asset_url }}" alt="Watermelon Fungi-Powered Seltzer">
          </div>
          <div class="product-card-body">
            <div class="product-card-tag">Fan Favourite</div>
            <div class="product-card-name">Watermelon</div>
            <div class="product-card-desc">Crisp, cool, and crafted for clarity. Juicy refreshment meets focused calm.</div>
            <div class="product-card-price">$23.99 / 6-Pack</div>
            <a href="/products/watermelon-fungi-powered-seltzer?discount=WINDOWN15" class="product-card-btn">Shop Watermelon →</a>
          </div>
        </div>
        <div class="product-card">
          <div class="product-card-img">
            <img src="{{ 'can-mango-mimosa.png' | asset_url }}" alt="Mango Mimosa Fungi-Powered Seltzer">
          </div>
          <div class="product-card-body">
            <div class="product-card-tag">Tropical Calm</div>
            <div class="product-card-name">Mango Mimosa</div>
            <div class="product-card-desc">Lush mango flavor with natural sweetness. The evening ritual with a tropical twist.</div>
            <div class="product-card-price">$23.99 / 6-Pack</div>
            <a href="/products/mango-mimosa-fungi-powered-seltzer?discount=WINDOWN15" class="product-card-btn">Shop Mango →</a>
          </div>
        </div>
        <div class="product-card">
          <div class="product-card-img">
