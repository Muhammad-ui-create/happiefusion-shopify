{% layout none %}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>The 2pm Energy-Drink Swap — Happie Fungi Fusion Mango Mimosa</title>
  <meta name="description" content="The afternoon energy drink is a deal with the devil. Three real mushrooms. 40 cal. No caffeine. No three-hours-later crash. 15% off — code FUNGI15.">
  <meta name="robots" content="noindex,nofollow">
  <link rel="icon" type="image/png" href="{{ 'happie-favicon.png' | asset_url }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --cream:      #FBF6E9;
      --cream-2:    #F2E8C9;
      --cream-3:    #E8DAA7;
      --mango:      #E89B3C;
      --mango-dk:   #C97F1F;
      --mango-soft: #F5C97A;
      --tropical:   #4A7C59;
      --tropical-dk:#2D6A4F;
      --tropical-lt:#D8F3DC;
      --warn:       #C73E47;
      --warn-soft:  #F2D3D6;
      --ink:        #2A1F0D;
      --ink-2:      #6B5743;
      --ink-3:      #9A8966;
      --white:      #FFFFFF;
    }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Poppins', system-ui, -apple-system, sans-serif;
      background: var(--cream);
      color: var(--ink);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }
    img { max-width: 100%; display: block; }
    a { text-decoration: none; color: inherit; }

    /* ── NAV ── BIG LOGO ── */
    .lp-nav {
      position: sticky; top: 0; z-index: 100;
      padding: 14px 32px;
      display: flex; justify-content: space-between; align-items: center;
      background: rgba(251,246,233,0.94);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(42,31,13,0.08);
    }
    .lp-nav-logo img {
      height: 80px;
      width: auto;
      display: block;
    }
    .lp-nav-cta {
      background: var(--ink); color: var(--cream);
      border-radius: 50px; padding: 11px 24px;
      font-size: 13px; font-weight: 700; letter-spacing: 0.04em;
      transition: background 0.2s;
    }
    .lp-nav-cta:hover { background: var(--mango-dk); }

    /* ── HERO ── */
    .hero {
      padding: 80px 32px 90px;
      background:
        radial-gradient(ellipse at 75% 25%, rgba(232,155,60,0.18) 0%, transparent 60%),
        radial-gradient(ellipse at 15% 80%, rgba(74,124,89,0.12) 0%, transparent 55%),
        linear-gradient(180deg, var(--cream) 0%, var(--cream-2) 100%);
      position: relative; overflow: hidden;
    }
    .hero-inner {
      max-width: 1180px; margin: 0 auto;
      display: grid; grid-template-columns: 1.1fr 1fr;
      gap: 64px; align-items: center;
    }
    .hero-eyebrow {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--white);
      border: 1.5px solid rgba(42,31,13,0.08);
      color: var(--ink-2);
      font-size: 11px; font-weight: 700; letter-spacing: 0.16em;
      text-transform: uppercase;
      padding: 8px 18px; border-radius: 50px;
      margin-bottom: 24px;
    }
    .hero-eyebrow-dot {
      width: 7px; height: 7px; border-radius: 50%;
      background: var(--mango); animation: pulse 2s infinite;
    }
    @keyframes pulse { 0%,100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.5; transform: scale(1.2); } }

    .hero-headline {
      font-size: clamp(42px, 7vw, 86px);
      font-weight: 900; line-height: 0.98;
      color: var(--ink); margin-bottom: 22px;
      letter-spacing: -0.03em;
    }
    .hero-headline .swap {
      color: var(--mango-dk);
      position: relative; display: inline-block;
    }
    .hero-headline .swap::after {
      content: ''; position: absolute;
      left: 0; right: 0; bottom: 8px;
      height: 14px; background: var(--mango-soft);
      z-index: -1; opacity: 0.55;
    }
    .hero-sub {
      font-size: 19px; color: var(--ink-2);
      line-height: 1.6; margin-bottom: 32px;
      max-width: 480px;
    }
    .hero-sub strong { color: var(--ink); font-weight: 700; }

    .hero-doses {
      display: flex; gap: 0;
      margin-bottom: 32px;
      padding: 22px 0;
      border-top: 1.5px solid rgba(42,31,13,0.1);
      border-bottom: 1.5px solid rgba(42,31,13,0.1);
    }
    .hero-dose {
      flex: 1; padding: 0 14px;
      text-align: center;
    }
    .hero-dose + .hero-dose { border-left: 1px solid rgba(42,31,13,0.1); }
    .hero-dose-num {
      font-size: 22px; font-weight: 900;
      color: var(--ink); display: block;
      line-height: 1;
    }
    .hero-dose-name {
      font-size: 10px; letter-spacing: 0.12em;
      color: var(--ink-2); text-transform: uppercase;
      font-weight: 700; margin-top: 6px;
    }
    .hero-cta-stack {
      display: flex; flex-direction: column;
      gap: 14px; align-items: flex-start;
    }
    .btn-primary {
      display: inline-flex; align-items: center; gap: 10px;
      background: var(--ink); color: var(--cream);
      border-radius: 50px; padding: 17px 32px;
      font-family: 'Poppins', sans-serif;
      font-size: 15px; font-weight: 800;
      letter-spacing: 0.02em;
      transition: all 0.2s;
      box-shadow: 0 12px 28px rgba(42,31,13,0.2);
    }
    .btn-primary:hover { background: var(--mango-dk); transform: translateY(-2px); }
    .btn-primary svg { transition: transform 0.2s; }
    .btn-primary:hover svg { transform: translateX(3px); }
    .hero-code-row {
      display: flex; align-items: center; gap: 10px;
      font-size: 13px; color: var(--ink-2);
    }
    .hero-code-row strong {
      background: var(--mango); color: var(--ink);
      padding: 4px 10px; border-radius: 8px;
      font-weight: 800; letter-spacing: 0.06em;
      font-family: 'Poppins', monospace;
    }

    /* Hero visual */
    .hero-visual {
      position: relative;
      display: flex; justify-content: center; align-items: center;
      min-height: 500px;
    }
    .hero-can-wrap {
      position: relative;
      filter: drop-shadow(0 32px 50px rgba(201,127,31,0.3));
    }
    .hero-can-glow {
      position: absolute; inset: 0;
      background: radial-gradient(circle at center, rgba(232,155,60,0.35) 0%, transparent 65%);
      transform: scale(1.6);
    }
    .hero-can {
      width: 300px; max-width: 80vw; position: relative; z-index: 2;
    }
    /* Floating "2pm" clock card */
    .hero-clock-card {
      position: absolute; top: 30px; right: -20px;
      background: var(--ink); color: var(--cream);
      border-radius: 18px;
      padding: 18px 22px;
      box-shadow: 0 16px 36px rgba(42,31,13,0.25);
      transform: rotate(3deg);
      z-index: 3;
      text-align: center;
    }
    .hero-clock-num {
      font-size: 32px; font-weight: 900; line-height: 1;
    }
    .hero-clock-num span { color: var(--mango); }
    .hero-clock-label {
      font-size: 9px; letter-spacing: 0.18em;
      text-transform: uppercase; margin-top: 4px;
      color: rgba(251,246,233,0.6);
    }
    .hero-flavor-tag {
      position: absolute; bottom: 30px; left: -20px;
      background: var(--mango); color: var(--ink);
      padding: 9px 20px; border-radius: 50px;
      font-size: 12px; font-weight: 800; letter-spacing: 0.08em;
      text-transform: uppercase;
      transform: rotate(-4deg);
      box-shadow: 0 12px 28px rgba(232,155,60,0.4);
      z-index: 3;
    }

    /* ── DEAL WITH THE DEVIL SECTION ── */
    .devil-section {
      padding: 100px 32px;
      background: var(--ink);
      color: var(--cream);
      position: relative; overflow: hidden;
    }
    .devil-section::before {
      content: ''; position: absolute; inset: 0;
      background: radial-gradient(ellipse at 30% 30%, rgba(199,62,71,0.18) 0%, transparent 60%);
      pointer-events: none;
    }
    .devil-inner {
      max-width: 920px; margin: 0 auto;
      text-align: center; position: relative;
    }
    .devil-eyebrow {
      display: inline-block;
      font-size: 11px; font-weight: 800;
      letter-spacing: 0.16em; text-transform: uppercase;
      background: var(--warn); color: var(--cream);
      padding: 6px 16px; border-radius: 50px;
      margin-bottom: 22px;
    }
    .devil-headline {
      font-size: clamp(34px, 5vw, 56px);
      font-weight: 900; line-height: 1.05;
      color: var(--cream); margin-bottom: 28px;
      letter-spacing: -0.02em;
    }
    .devil-headline .strike {
      color: var(--mango-soft);
      text-decoration: line-through;
      text-decoration-color: var(--warn);
      text-decoration-thickness: 3px;
    }
    .devil-body {
      font-size: 18px; color: rgba(251,246,233,0.8);
      line-height: 1.7; max-width: 720px;
      margin: 0 auto;
    }
    .devil-body strong { color: var(--cream); }

    /* ── COMPARISON ── */
    .compare-section {
      padding: 100px 32px;
      background: var(--cream);
    }
    .compare-inner { max-width: 1080px; margin: 0 auto; }
    .compare-header { text-align: center; margin-bottom: 56px; }
    .compare-eyebrow {
      font-size: 11px; font-weight: 800;
      letter-spacing: 0.16em; text-transform: uppercase;
      color: var(--mango-dk); margin-bottom: 14px;
    }
    .compare-title {
      font-size: clamp(28px, 4vw, 44px);
      font-weight: 900; color: var(--ink);
      line-height: 1.15; letter-spacing: -0.02em;
    }
    .compare-title em { font-style: normal; color: var(--mango-dk); }
    .compare-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 22px;
    }
    .compare-col {
      background: var(--white);
      border-radius: 24px;
      padding: 40px 32px;
      border: 1.5px solid rgba(42,31,13,0.06);
      position: relative;
    }
    .compare-col.bad {
      background: linear-gradient(165deg, var(--warn-soft), #F8E0E3);
      border-color: rgba(199,62,71,0.2);
    }
    .compare-col.good {
      background: linear-gradient(165deg, var(--cream), var(--cream-2));
      border: 2.5px solid var(--mango);
      box-shadow: 0 20px 50px rgba(232,155,60,0.18);
    }
    .compare-col.good::after {
      content: 'YOUR NEW 2PM';
      position: absolute; top: -12px; right: 20px;
      background: var(--ink); color: var(--mango);
      padding: 5px 14px; border-radius: 50px;
      font-size: 10px; font-weight: 900; letter-spacing: 0.14em;
    }
    .compare-col-tag {
      display: inline-block;
      font-size: 10px; font-weight: 800; letter-spacing: 0.18em;
      text-transform: uppercase; padding: 6px 14px; border-radius: 50px;
      margin-bottom: 18px;
    }
    .compare-col.bad .compare-col-tag { background: rgba(199,62,71,0.15); color: var(--warn); }
    .compare-col.good .compare-col-tag { background: var(--mango); color: var(--ink); }
    .compare-col h3 {
      font-size: 24px; font-weight: 900;
      color: var(--ink); margin-bottom: 22px;
      line-height: 1.2;
    }
    .compare-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0; }
    .compare-list li {
      display: flex; align-items: flex-start; gap: 12px;
      font-size: 15px; color: var(--ink-2);
      line-height: 1.55;
      padding: 12px 0;
      border-bottom: 1px solid rgba(42,31,13,0.07);
    }
    .compare-list li:last-child { border-bottom: none; }
    .compare-list li svg { flex-shrink: 0; margin-top: 2px; }
    .compare-col.bad .compare-list svg { stroke: var(--warn); }
    .compare-col.good .compare-list svg { stroke: var(--tropical-dk); }

    /* ── HOW IT FEELS (TIMELINE) ── */
    .feels-section {
      padding: 100px 32px;
      background: linear-gradient(180deg, var(--cream-2) 0%, var(--cream) 100%);
    }
    .feels-inner { max-width: 980px; margin: 0 auto; }
    .feels-header { text-align: center; margin-bottom: 56px; }
    .feels-headline {
      font-size: clamp(28px, 4vw, 44px);
      font-weight: 900; color: var(--ink);
      line-height: 1.15; letter-spacing: -0.02em;
    }
    .feels-headline em { font-style: normal; color: var(--mango-dk); }
    .feels-timeline {
      display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px;
      position: relative;
    }
    .feels-step {
      background: var(--white);
      border: 1.5px solid rgba(42,31,13,0.06);
      border-radius: 20px;
      padding: 26px 22px;
      text-align: center;
    }
    .feels-time {
      font-size: 28px; font-weight: 900;
      color: var(--mango-dk); line-height: 1;
      margin-bottom: 12px;
    }
    .feels-step-title {
      font-size: 13px; font-weight: 800;
      color: var(--ink); margin-bottom: 8px;
      letter-spacing: 0.04em;
    }
    .feels-step-body {
      font-size: 13px; color: var(--ink-2);
      line-height: 1.6;
    }

    /* ── REVIEWS ── */
    .reviews-section {
      padding: 100px 32px;
      background: var(--cream);
      border-top: 1px solid rgba(42,31,13,0.07);
    }
    .reviews-inner { max-width: 1080px; margin: 0 auto; }
    .reviews-header { text-align: center; margin-bottom: 48px; }
    .reviews-eyebrow {
      font-size: 11px; font-weight: 800;
      letter-spacing: 0.16em; text-transform: uppercase;
      color: var(--mango-dk); margin-bottom: 12px;
    }
    .reviews-title {
      font-size: clamp(28px, 4vw, 42px);
      font-weight: 900; color: var(--ink);
      line-height: 1.15; letter-spacing: -0.02em;
    }
    .reviews-grid {
      display: grid; grid-template-columns: repeat(3,1fr); gap: 20px;
    }
    .review-card {
      background: var(--white);
      border: 1.5px solid rgba(42,31,13,0.06);
      border-radius: 20px;
      padding: 28px 26px;
    }
    .review-stars {
      color: var(--mango); font-size: 14px; letter-spacing: 1px;
      margin-bottom: 14px;
    }
    .review-title {
      font-size: 16px; font-weight: 800;
      color: var(--ink); margin-bottom: 10px;
    }
    .review-body {
      font-size: 14px; color: var(--ink-2);
      line-height: 1.7; margin-bottom: 18px;
    }
    .review-by {
      display: flex; align-items: center; gap: 7px;
      font-size: 11px; color: var(--ink-3);
      font-weight: 700; letter-spacing: 0.06em;
      text-transform: uppercase;
      padding-top: 14px;
      border-top: 1px solid rgba(42,31,13,0.07);
    }
    .review-by svg { fill: var(--mango); }

    /* ── TRUST BAR ── */
    .trust-section {
      padding: 50px 32px;
      background: var(--tropical-dk);
      color: var(--cream);
    }
    .trust-inner {
      max-width: 1000px; margin: 0 auto;
      display: grid; grid-template-columns: repeat(4,1fr); gap: 0;
      text-align: center;
    }
    .trust-item { padding: 0 16px; }
    .trust-item + .trust-item { border-left: 1px solid rgba(251,246,233,0.15); }
    .trust-item svg { stroke: var(--mango); margin-bottom: 10px; }
    .trust-item strong { display: block; font-size: 13px; margin-bottom: 4px; font-weight: 800; }
    .trust-item span { font-size: 11px; color: rgba(251,246,233,0.65); }

    /* ── FINAL CTA ── */
    .final-cta {
      padding: 120px 32px;
      background:
        radial-gradient(ellipse at center, rgba(232,155,60,0.18) 0%, transparent 60%),
        linear-gradient(180deg, var(--cream) 0%, var(--cream-2) 100%);
      text-align: center;
    }
    .final-cta-inner { max-width: 680px; margin: 0 auto; }
    .final-cta h2 {
      font-size: clamp(34px, 5vw, 58px);
      font-weight: 900; color: var(--ink);
      line-height: 1.05; letter-spacing: -0.025em;
      margin-bottom: 22px;
    }
    .final-cta h2 em {
      font-style: normal; color: var(--mango-dk);
      position: relative; display: inline-block;
    }
    .final-cta h2 em::after {
      content: ''; position: absolute;
      left: 0; right: 0; bottom: 6px;
      height: 12px; background: var(--mango-soft);
      z-index: -1; opacity: 0.6;
    }
    .final-cta p {
      font-size: 17px; color: var(--ink-2);
      line-height: 1.7; margin-bottom: 36px;
      max-width: 480px; margin-left: auto; margin-right: auto;
    }
    .final-cta-row {
      display: flex; justify-content: center; gap: 16px;
      flex-wrap: wrap; align-items: center;
    }
    .disclaimer {
      font-size: 11px; color: var(--ink-3);
      max-width: 560px; margin: 40px auto 0;
      line-height: 1.6;
    }

    /* ── FOOTER ── */
    .lp-footer {
      padding: 28px 32px;
      background: var(--ink);
      color: rgba(251,246,233,0.6);
      display: flex; justify-content: space-between; align-items: center;
      font-size: 12px;
    }
    .lp-footer-links { display: flex; gap: 22px; }
    .lp-footer-links a:hover { color: var(--cream); }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
      .lp-nav-logo img { height: 60px; }
      .hero-inner, .compare-grid, .reviews-grid { grid-template-columns: 1fr; }
      .hero { padding: 60px 22px 70px; }
      .hero-visual { order: -1; min-height: 400px; }
      .hero-can { width: 230px; }
      .feels-timeline { grid-template-columns: 1fr 1fr; }
      .reviews-grid { max-width: 460px; margin-left: auto; margin-right: auto; }
      .trust-inner { grid-template-columns: repeat(2,1fr); gap: 24px; }
      .trust-item + .trust-item { border-left: none; }
      .trust-item:nth-child(odd) { border-right: 1px solid rgba(251,246,233,0.15); }
      .lp-footer { flex-direction: column; gap: 14px; text-align: center; }
      section { padding-left: 20px !important; padding-right: 20px !important; }
    }
  </style>
</head>
<body>

  {%- comment -%} Auto-apply discount + redirect to Mango Mimosa product page {%- endcomment -%}
  {%- assign cta_url = '/discount/FUNGI15?redirect=/products/mango-mimosa-fungi-powered-seltzer' -%}

  <!-- NAV — Big logo -->
  <nav class="lp-nav">
    <a href="/" class="lp-nav-logo"><img src="{{ 'happie-logo.png' | asset_url }}" alt="Happie Fusion"></a>
    <a href="{{ cta_url }}" class="lp-nav-cta">Try Mango — 15% Off →</a>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-text">
        <div class="hero-eyebrow">
          <span class="hero-eyebrow-dot"></span>
          The 2pm Swap · Mango Mimosa
        </div>
        <h1 class="hero-headline">The 2pm energy-drink <span class="swap">swap.</span></h1>
        <p class="hero-sub">The afternoon energy drink is a <strong>deal with the devil</strong>. Mango Mimosa skips both ends — three real mushrooms, sustained focus, <strong>40 calories</strong>, zero caffeine, <strong>zero three-hours-later crash</strong>.</p>
        <div class="hero-doses">
          <div class="hero-dose">
            <span class="hero-dose-num">900mg</span>
            <div class="hero-dose-name">Lion's Mane</div>
          </div>
          <div class="hero-dose">
            <span class="hero-dose-num">700mg</span>
            <div class="hero-dose-name">Cordyceps</div>
          </div>
          <div class="hero-dose">
            <span class="hero-dose-num">400mg</span>
            <div class="hero-dose-name">Reishi</div>
          </div>
        </div>
        <div class="hero-cta-stack">
          <a href="{{ cta_url }}" class="btn-primary">
            Try Mango Mimosa — 15% Off
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <div class="hero-code-row">
            Code <strong>FUNGI15</strong> auto-applies at checkout
          </div>
        </div>
      </div>
      <div class="hero-visual">
        <div class="hero-can-wrap">
          <div class="hero-can-glow"></div>
          <img src="{{ 'can-mango-mimosa.png' | asset_url }}" alt="Happie Fungi Fusion Mango Mimosa" class="hero-can">
          <div class="hero-clock-card">
            <div class="hero-clock-num">2<span>:00</span></div>
            <div class="hero-clock-label">No Wall</div>
          </div>
          <div class="hero-flavor-tag">Tropical Brunch Drink</div>
        </div>
      </div>
    </div>
  </section>

  <!-- DEAL WITH THE DEVIL -->
  <section class="devil-section">
    <div class="devil-inner">
      <div class="devil-eyebrow">The 2pm Bargain</div>
      <h2 class="devil-headline">Energy drinks borrow energy <span class="strike">from tomorrow</span>.</h2>
      <p class="devil-body">Caffeine doesn't <em>give</em> you energy. It blocks adenosine receptors and triggers cortisol — your body's stress hormone. You feel "alert" for 90 minutes, then the bill comes due. <strong>Crash at 5pm. Can't sleep at 11. Wake up tired. Repeat at 2pm tomorrow.</strong></p>
    </div>
  </section>

  <!-- COMPARE -->
  <section class="compare-section">
    <div class="compare-inner">
      <div class="compare-header">
        <div class="compare-eyebrow">Skip both ends of the deal</div>
        <h2 class="compare-title">The 2pm energy drink<br>vs. <em>The 2pm Mango Mimosa.</em></h2>
      </div>
      <div class="compare-grid">
        <div class="compare-col bad">
          <div class="compare-col-tag">Your old 2pm</div>
