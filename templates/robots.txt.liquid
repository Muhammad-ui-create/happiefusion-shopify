# Happie Fusion robots.txt
# Allow all major web crawlers + AI search bots (ChatGPT, Claude, Perplexity, Gemini, etc.)
# Crawl budget set generously since site is small.

{% for group in robots.default_groups %}
{{- group.user_agent }}
{% for rule in group.rules -%}
{{ rule }}
{% endfor -%}
{%- if group.sitemap != blank %}
{{ group.sitemap }}
{% endif %}
{% endfor %}

