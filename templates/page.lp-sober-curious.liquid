<style>
.lp-sc {
  --lp-dark: #0F0E1A;
  --lp-dusk: #1C1830;
  --lp-purple: #6260AE;
  --lp-cream: #FFFDF5;
  --lp-green: #2D6A4F;
  --lp-teal: #1ABC9C;
  --lp-yellow: #F9C234;
  font-family: 'Inter', 'Helvetica Neue', Arial, sans-serif;
}

/* HERO */
.lp-hero {
  position: relative;
  min-height: 100svh;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: var(--lp-dusk);
  text-align: center;
  padding: 120px 24px 80px;
}
.lp-hero-bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 80% 60% at 50% 30%, rgba(98,96,174,0.35) 0%, transparent 70%),
    radial-gradient(ellipse 60% 40% at 80% 80%, rgba(26,188,156,0.12) 0%, transparent 60%),
    linear-gradient(175deg, #0F0E1A 0%, #1C1830 50%, #130F2A 100%);
  z-index: 0;
}
.lp-hero-bg::before, .lp-hero-bg::after {
  content: '';
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  animation: lp-float 8s ease-in-out infinite alternate;
}
.lp-hero-bg::before { width:320px; height:320px; background:rgba(98,96,174,0.25); top:10%; left:10%; }
.lp-hero-bg::after  { width:240px; height:240px; background:rgba(26,188,156,0.15); bottom:15%; right:15%; animation-delay:3s; }
@keyframes lp-float { from { transform:translateY(0) scale(1); } to { transform:translateY(-30px) scale(1.08); } }

.lp-hero-inner { position:relative; z-index:1; max-width:800px; margin:0 auto; }

.lp-eyebrow {
  display:inline-flex; align-items:center; gap:8px;
  background:rgba(98,96,174,0.25); border:1px solid rgba(98,96,174,0.5);
  border-radius:50px; padding:6px 16px;
  font-size:11px; font-weight:700; letter-spacing:0.12em; text-transform:uppercase;
  color:#C8C6FF; margin-bottom:28px;
}
.lp-hero-headline {
  font-size:clamp(36px,6vw,76px); font-weight:900; line-height:1.05;
  letter-spacing:-0.03em; color:var(--lp-cream); margin:0 0 20px;
}
.lp-hero-headline em {
  font-style:normal;
  background:linear-gradient(135deg, var(--lp-purple) 0%, #9B8FE8 50%, var(--lp-teal) 100%);
  -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
}
.lp-hero-sub { font-size:clamp(16px,2.2vw,20px); line-height:1.6; color:rgba(255,255,255,0.65); max-width:580px; margin:0 auto 40px; }
.lp-hero-sub strong { color:rgba(255,255,255,0.9); font-weight:600; }
.lp-cta-group { display:flex; align-items:center; justify-content:center; gap:16px; flex-wrap:wrap; }

.lp-btn-primary {
  display:inline-flex; align-items:center; gap:8px;
  background:var(--lp-teal); color:#fff; font-weight:800; font-size:15px;
  letter-spacing:0.04em; padding:16px 36px; border-radius:50px; text-decoration:none;
  transition:transform 0.3s cubic-bezier(0.16,1,0.3,1), box-shadow 0.3s cubic-bezier(0.16,1,0.3,1);
  box-shadow:0 8px 32px rgba(26,188,156,0.4);
}
.lp-btn-primary:hover { transform:translateY(-3px) scale(1.03); box-shadow:0 16px 48px rgba(26,188,156,0.5); }

.lp-hero-discount { margin-top:20px; font-size:13px; color:var(--lp-yellow); font-weight:600; letter-spacing:0.04em; }
.lp-hero-can { margin-top:56px; display:inline-block; }
.lp-hero-can img {
  width:min(320px,70vw); height:auto;
  filter:drop-shadow(0 40px 80px rgba(98,96,174,0.5));
  animation:lp-can-float 5s ease-in-out infinite;
}
@keyframes lp-can-float {
  0%,100% { transform:translateY(0px) rotate(-2deg); }
  50%      { transform:translateY(-18px) rotate(2deg); }
}

/* PROBLEM */
.lp-problem { background:var(--lp-cream); padding:80px 24px; text-align:center; }
.lp-problem-label { font-size:11px; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; color:var(--lp-purple); margin-bottom:16px; }
.lp-problem-headline { font-size:clamp(26px,4vw,48px); font-weight:900; letter-spacing:-0.025em; color:#0F0E1A; max-width:700px; margin:0 auto 20px; line-height:1.1; }
.lp-problem-body { font-size:17px; line-height:1.7; color:#555; max-width:580px; margin:0 auto 48px; }
.lp-problem-cards { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; max-width:900px; margin:0 auto; }
.lp-prob-card { background:#fff; border-radius:20px; padding:32px 24px; border:1px solid rgba(0,0,0,0.07); box-shadow:0 2px 20px rgba(0,0,0,0.04); position:relative; overflow:hidden; }
.lp-prob-card::before { content:''; position:absolute; top:0; left:0; right:0; height:4px; background:#E57373; }
.lp-prob-icon { font-size:32px; margin-bottom:12px; }
.lp-prob-card h3 { font-size:16px; font-weight:800; color:#1A1A2E; margin:0 0 8px; }
.lp-prob-card p { font-size:13px; color:#777; line-height:1.55; margin:0; }

/* SOLUTION */
.lp-solution { background:var(--lp-dusk); padding:100px 24px; text-align:center; }
.lp-solution-eyebrow { font-size:11px; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; color:var(--lp-teal); margin-bottom:16px; }
.lp-solution-headline { font-size:clamp(28px,4.5vw,56px); font-weight:900; letter-spacing:-0.03em; color:var(--lp-cream); max-width:720px; margin:0 auto 20px; line-height:1.05; }
.lp-solution-sub { font-size:17px; color:rgba(255,255,255,0.6); max-width:560px; margin:0 auto 60px; line-height:1.65; }
.lp-cans-showcase { display:flex; align-items:flex-end; justify-content:center; gap:24px; margin-bottom:48px; flex-wrap:wrap; }
.lp-can-item { display:flex; flex-direction:column; align-items:center; gap:12px; }
.lp-can-item img { width:min(140px,28vw); height:auto; filter:drop-shadow(0 20px 40px rgba(0,0,0,0.4)); transition:transform 0.4s cubic-bezier(0.16,1,0.3,1); }
.lp-can-item:hover img { transform:translateY(-8px) scale(1.05); }
.lp-can-label { font-size:12px; font-weight:700; letter-spacing:0.05em; text-transform:uppercase; color:rgba(255,255,255,0.55); }
.lp-offer-badge { display:inline-flex; flex-direction:column; align-items:center; background:rgba(249,194,52,0.12); border:1px solid rgba(249,194,52,0.4); border-radius:16px; padding:20px 40px; margin-bottom:32px; gap:4px; }
.lp-offer-badge .offer-main { font-size:22px; font-weight:900; color:var(--lp-yellow); letter-spacing:-0.02em; }
.lp-offer-badge .offer-sub { font-size:13px; color:rgba(255,255,255,0.55); }
.lp-offer-badge .offer-code { font-size:12px; font-weight:700; color:var(--lp-yellow); letter-spacing:0.12em; background:rgba(249,194,52,0.15); border-radius:6px; padding:3px 10px; margin-top:6px; text-transform:uppercase; }

/* REISHI */
.lp-reishi { background:var(--lp-cream); padding:100px 24px; }
.lp-reishi-inner { max-width:1100px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; gap:80px; align-items:center; }
.lp-reishi-visual { display:flex; align-items:center; justify-content:center; }
.lp-reishi-circle {
  width:min(360px,90%); aspect-ratio:1; border-radius:50%;
  background:radial-gradient(ellipse at 40% 40%, #3B2F6E, #1C1830);
  display:flex; align-items:center; justify-content:center; position:relative;
  box-shadow:0 40px 100px rgba(98,96,174,0.3);
}
.lp-reishi-circle img { width:70%; height:auto; filter:drop-shadow(0 20px 40px rgba(0,0,0,0.5)); }
.lp-section-eyebrow { font-size:11px; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; color:var(--lp-purple); margin-bottom:14px; }
.lp-section-headline { font-size:clamp(26px,3.5vw,44px); font-weight:900; letter-spacing:-0.025em; color:#0F0E1A; margin:0 0 20px; line-height:1.1; }
.lp-section-body { font-size:16px; line-height:1.75; color:#555; margin-bottom:36px; }
.lp-benefit-list { list-style:none; padding:0; margin:0 0 40px; display:flex; flex-direction:column; gap:14px; }
.lp-benefit-list li { display:flex; align-items:flex-start; gap:12px; font-size:15px; color:#333; line-height:1.5; }
.lp-benefit-check { flex-shrink:0; width:22px; height:22px; border-radius:50%; background:var(--lp-purple); display:flex; align-items:center; justify-content:center; margin-top:1px; }
.lp-reishi-dosage { display:flex; align-items:center; gap:12px; background:rgba(98,96,174,0.08); border:1px solid rgba(98,96,174,0.2); border-radius:14px; padding:16px 20px; width:fit-content; }
.lp-dosage-number { font-size:32px; font-weight:900; color:var(--lp-purple); line-height:1; }
.lp-dosage-label { font-size:12px; font-weight:700; color:#888; text-transform:uppercase; letter-spacing:0.08em; line-height:1.4; }

/* COMPARE */
.lp-compare { background:#0F0E1A; padding:100px 24px; text-align:center; }
.lp-compare-headline { font-size:clamp(28px,4vw,52px); font-weight:900; letter-spacing:-0.03em; color:var(--lp-cream); max-width:700px; margin:0 auto 16px; line-height:1.05; }
.lp-compare-sub { font-size:17px; color:rgba(255,255,255,0.55); max-width:500px; margin:0 auto 56px; }
.lp-compare-grid { display:grid; grid-template-columns:1fr auto 1fr; gap:24px; max-width:900px; margin:0 auto 48px; align-items:center; }
.lp-compare-col { background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); border-radius:24px; padding:32px 24px; }
.lp-compare-col.is-happie { background:rgba(98,96,174,0.15); border-color:rgba(98,96,174,0.4); box-shadow:0 0 60px rgba(98,96,174,0.2); }
.lp-compare-col-label { font-size:12px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; margin-bottom:20px; color:rgba(255,255,255,0.5); }
.lp-compare-col.is-happie .lp-compare-col-label { color:#C8C6FF; }
.lp-compare-name { font-size:22px; font-weight:900; color:#fff; margin-bottom:24px; }
.lp-compare-items { list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:12px; }
.lp-compare-items li { display:flex; align-items:center; gap:10px; font-size:14px; color:rgba(255,255,255,0.7); text-align:left; }
.lp-compare-vs { font-size:20px; font-weight:900; color:rgba(255,255,255,0.2); letter-spacing:0.1em; }

/* PROOF */
.lp-proof { background:var(--lp-cream); padding:100px 24px; text-align:center; }
.lp-proof-eyebrow { font-size:11px; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; color:var(--lp-green); margin-bottom:14px; }
.lp-proof-headline { font-size:clamp(26px,3.5vw,44px); font-weight:900; letter-spacing:-0.025em; color:#0F0E1A; margin:0 auto 48px; max-width:600px; line-height:1.1; }
.lp-reviews-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; max-width:1000px; margin:0 auto 48px; }
.lp-review-card { background:#fff; border-radius:20px; padding:28px; text-align:left; border:1px solid rgba(0,0,0,0.06); box-shadow:0 4px 24px rgba(0,0,0,0.05); position:relative; }
.lp-review-stars { display:flex; gap:3px; margin-bottom:14px; color:#F9C234; }
.lp-review-text { font-size:14px; line-height:1.65; color:#444; margin-bottom:18px; font-style:italic; }
.lp-review-author { display:flex; align-items:center; gap:10px; }
.lp-review-avatar { width:38px; height:38px; border-radius:50%; background:linear-gradient(135deg,var(--lp-purple),var(--lp-teal)); display:flex; align-items:center; justify-content:center; font-weight:800; font-size:13px; color:#fff; flex-shrink:0; }
.lp-review-name { font-size:13px; font-weight:700; color:#1A1A2E; }
.lp-review-handle { font-size:11px; color:#aaa; }
.lp-verified-badge { position:absolute; top:20px; right:20px; background:rgba(45,106,79,0.1); border-radius:6px; padding:3px 8px; font-size:10px; font-weight:700; color:var(--lp-green); letter-spacing:0.05em; text-transform:uppercase; }

/* HOW IT WORKS */
.lp-how { background:var(--lp-dusk); padding:100px 24px; text-align:center; }
.lp-how-headline { font-size:clamp(26px,3.5vw,44px); font-weight:900; letter-spacing:-0.025em; color:var(--lp-cream); margin:0 auto 16px; max-width:600px; line-height:1.1; }
.lp-how-sub { font-size:16px; color:rgba(255,255,255,0.55); max-width:500px; margin:0 auto 60px; }
.lp-steps { display:grid; grid-template-columns:repeat(3,1fr); gap:24px; max-width:900px; margin:0 auto; }
.lp-step-num { width:48px; height:48px; border-radius:50%; background:rgba(98,96,174,0.2); border:1px solid rgba(98,96,174,0.4); display:flex; align-items:center; justify-content:center; font-size:18px; font-weight:900; color:#C8C6FF; margin:0 auto 20px; }
.lp-step h3 { font-size:17px; font-weight:800; color:var(--lp-cream); margin:0 0 10px; }
.lp-step p { font-size:14px; color:rgba(255,255,255,0.5); line-height:1.6; margin:0; }

/* TRUST */
.lp-trust { background:var(--lp-cream); padding:40px 24px; border-top:1px solid rgba(0,0,0,0.07); border-bottom:1px solid rgba(0,0,0,0.07); }
.lp-trust-inner { display:flex; align-items:center; justify-content:center; gap:48px; flex-wrap:wrap; max-width:900px; margin:0 auto; }
.lp-trust-item { display:flex; align-items:center; gap:10px; font-size:13px; font-weight:700; color:#444; }
.lp-trust-item svg { color:var(--lp-green); flex-shrink:0; }

/* FINAL CTA */
.lp-final-cta { background:#0F0E1A; padding:120px 24px; text-align:center; position:relative; overflow:hidden; }
.lp-final-cta::before { content:''; position:absolute; width:600px; height:600px; border-radius:50%; background:radial-gradient(circle,rgba(98,96,174,0.3) 0%,transparent 70%); top:50%; left:50%; transform:translate(-50%,-50%); }
.lp-final-cta-inner { position:relative; z-index:1; max-width:700px; margin:0 auto; }
.lp-final-eyebrow { font-size:11px; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; color:var(--lp-teal); margin-bottom:20px; }
.lp-final-headline { font-size:clamp(32px,5vw,64px); font-weight:900; letter-spacing:-0.03em; color:var(--lp-cream); line-height:1.05; margin:0 0 20px; }
.lp-final-sub { font-size:17px; color:rgba(255,255,255,0.55); line-height:1.65; margin-bottom:40px; }
.lp-final-offer { display:inline-flex; align-items:center; gap:8px; background:rgba(249,194,52,0.1); border:1px solid rgba(249,194,52,0.3); border-radius:50px; padding:8px 20px; font-size:13px; font-weight:700; color:var(--lp-yellow); margin-bottom:32px; letter-spacing:0.04em; }

/* MOBILE */
@media (max-width: 768px) {
  .lp-problem-cards, .lp-reviews-grid, .lp-steps { grid-template-columns:1fr; max-width:420px; margin-left:auto; margin-right:auto; }
  .lp-reishi-inner { grid-template-columns:1fr; gap:48px; text-align:center; }
  .lp-reishi-visual { order:-1; }
  .lp-benefit-list li { text-align:left; }
  .lp-reishi-dosage { margin:0 auto; }
  .lp-compare-grid { grid-template-columns:1fr; max-width:420px; margin-left:auto; margin-right:auto; }
  .lp-compare-vs { display:none; }
  .lp-trust-inner { gap:24px; }
  .lp-reishi-circle { width:min(260px,80vw); }
}
@media (max-width: 480px) {
  .lp-hero { padding:100px 20px 60px; }
  .lp-btn-primary { font-size:14px; padding:14px 28px; }
  .lp-final-cta { padding:80px 20px; }
}
</style>

{% assign variety_url = '/collections/all' %}
{% assign discount_code = 'WINDOWN15' %}
{% assign p_blue  = all_products['blue-razzberry-fungi-powered-seltzer'] %}
{% assign p_mango = all_products['mango-mimosa-fungi-powered-seltzer'] %}
{% assign p_water = all_products['watermelon-fungi-powered-seltzer'] %}

<div class="lp-sc">

  {%- comment -%} HERO {%- endcomment -%}
  <section class="lp-hero">
    <div class="lp-hero-bg"></div>
    <div class="lp-hero-inner">
      <div class="lp-eyebrow">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L4 6v6c0 5.55 3.84 10.74 8 12 4.16-1.26 8-6.45 8-12V6l-8-4z"/><path d="M8.5 12l2.5 2.5 4.5-4.5"/></svg>
        Functional Mushroom Drinks · No Alcohol
      </div>
      <h1 class="lp-hero-headline">Your 5 o'clock ritual,<br><em>upgraded.</em></h1>
      <p class="lp-hero-sub">Wind down without the wine. Happie packs <strong>400mg of Reishi</strong> — the "Queen of Mushrooms" — into a sparkling seltzer that looks like a cocktail, holds like one, and leaves you feeling calm without the headache.</p>
      <div class="lp-cta-group">
        <a href="/discount/{{ discount_code }}?redirect={{ variety_url }}" class="lp-btn-primary">
          Reclaim Your Evenings
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
      <div class="lp-hero-discount">🎉 Use code <strong>{{ discount_code }}</strong> — 15% off your first order</div>
      <div class="lp-hero-can">
        <img src="{{ 'can-blue-razzberry.png' | asset_url }}" alt="Happie functional mushroom seltzer" width="320" height="480" loading="eager" />
      </div>
    </div>
  </section>

  {%- comment -%} PROBLEM {%- endcomment -%}
  <section class="lp-problem">
    <div class="lp-problem-label">Sound Familiar?</div>
    <h2 class="lp-problem-headline">You want to unwind.<br>You just don't want the wine.</h2>
    <p class="lp-problem-body">The standard options — alcohol, energy drinks, or just scrolling — all come with a tax. There's a better way to end your day.</p>
    <div class="lp-problem-cards">
      <div class="lp-prob-card">
        <div class="lp-prob-icon">🍷</div>
        <h3>Alcohol</h3>
        <p>Disrupts sleep, dehydrates you, and leaves a foggy head in the morning.</p>
      </div>
      <div class="lp-prob-card">
        <div class="lp-prob-icon">⚡</div>
        <h3>Energy Drinks</h3>
        <p>Too much caffeine at 5pm — you're wired until midnight and crash hard.</p>
      </div>
      <div class="lp-prob-card">
        <div class="lp-prob-icon">📱</div>
        <h3>Just Scrolling</h3>
        <p>Feels relaxing in the moment, but your brain is still firing. No real wind-down.</p>
      </div>
    </div>
  </section>

  {%- comment -%} SOLUTION {%- endcomment -%}
  <section class="lp-solution">
    <div class="lp-solution-eyebrow">Introducing Happie</div>
    <h2 class="lp-solution-headline">Looks like a cocktail.<br>Holds like one.</h2>
    <p class="lp-solution-sub">Three flavors, one mission: give you a ritual you actually look forward to — without the alcohol, without the crash.</p>
    <div class="lp-cans-showcase">
      <div class="lp-can-item">
        <img src="{{ 'can-blue-razzberry.png' | asset_url }}" alt="Blue Razzberry" width="140" height="210" loading="lazy" />
        <span class="lp-can-label">Blue Razzberry</span>
      </div>
      <div class="lp-can-item">
        <img src="{{ 'can-mango-mimosa.png' | asset_url }}" alt="Mango Mimosa" width="140" height="210" loading="lazy" />
        <span class="lp-can-label">Mango Mimosa</span>
      </div>
      <div class="lp-can-item">
        <img src="{{ 'can-watermelon.png' | asset_url }}" alt="Watermelon" width="140" height="210" loading="lazy" />
        <span class="lp-can-label">Watermelon</span>
      </div>
    </div>
    <div class="lp-offer-badge">
      <span class="offer-main">Variety Pack — Try All 3</span>
      <span class="offer-sub">Free shipping over $41.99</span>
      <span class="offer-code">15% off — code: {{ discount_code }}</span>
    </div>
    <a href="/discount/{{ discount_code }}?redirect={{ variety_url }}" class="lp-btn-primary">
      Shop the Variety Pack
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </section>

  {%- comment -%} REISHI {%- endcomment -%}
  <section class="lp-reishi">
    <div class="lp-reishi-inner">
      <div class="lp-reishi-visual">
        <div class="lp-reishi-circle">
          <img src="{{ 'can-blue-razzberry.png' | asset_url }}" alt="Reishi mushroom" width="252" height="252" loading="lazy" />
        </div>
      </div>
      <div class="lp-reishi-content">
        <div class="lp-section-eyebrow">The Queen of Mushrooms</div>
        <h2 class="lp-section-headline">400mg of Reishi.<br>No wine. No headache.</h2>
        <p class="lp-section-body">Reishi has been used for over 2,000 years. Modern research backs what ancient healers knew: Reishi supports stress response, promotes calm, and supports better sleep quality — without sedation.</p>
        <ul class="lp-benefit-list">
          <li>
            <div class="lp-benefit-check"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg></div>
            <span><strong>Calms the nervous system</strong> — adaptogens help your body shift out of fight-or-flight mode.</span>
