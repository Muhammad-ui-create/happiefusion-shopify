            <svg viewBox="0 0 120 140" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:120px;height:140px;">
              <path d="M20 50 L100 50 L92 122 C90 130 84 134 76 134 L44 134 C36 134 30 130 28 122 Z" fill="#6b4423" stroke="#3a2615" stroke-width="2"/>
