        <div class="hero-side hero-side-yes">
          <div class="hero-side-label">Fungi Fusion</div>
          <div class="hero-icon-wrap">
            <img src="{{ 'can-mango-mimosa.png' | asset_url }}" alt="Happie Fungi Fusion Mango Mimosa can — zero caffeine" onerror="this.style.display='none';">
          </div>
          <div class="hero-side-caption">0 mg caffeine</div>
          <div class="hero-side-sub">Energy from mushrooms only</div>
        </div>
      </div>
    </div>
  </section>

  <!-- HIDDEN CAFFEINE -->
  <section class="hidden">
    <div class="hidden-inner">
