<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">

  {%- comment -%} ── SEO: TITLE TAGS ── {%- endcomment -%}
  {%- if template.name == 'index' -%}
    <title>Functional Mushroom Drinks | Lion's Mane, Cordyceps & Reishi Seltzer – Happie Fusion</title>
  {%- elsif template.name == 'product' -%}
    <title>{{ product.title }} | Functional Mushroom Seltzer – Happie Fusion</title>
  {%- elsif template.name == 'collection' -%}
    <title>{{ collection.title }} | Mushroom Seltzers – Happie Fusion</title>
  {%- else -%}
    <title>{{ page_title }}{% unless page_title contains shop.name %} – {{ shop.name }}{% endunless %}</title>
  {%- endif -%}

  {%- comment -%} ── SEO: META DESCRIPTIONS ── {%- endcomment -%}
  {%- if template.name == 'index' -%}
    <meta name="description" content="Happie Fungi Fusion — functional mushroom seltzers with 900mg Lion's Mane, 700mg Cordyceps & 400mg Reishi per can. No alcohol. No caffeine. Real adaptogenic results. Free shipping, no minimum.">
  {%- elsif template.name == 'product' -%}
    {%- comment -%} Prefer the Shopify-managed SEO description; fall back to body if not set. {%- endcomment -%}
    {%- assign seo_meta = product.metafields.global.description_tag -%}
    {%- if seo_meta == blank -%}
      {%- assign seo_meta = product.description | strip_html | strip | truncate: 155 -%}
    {%- endif -%}
    <meta name="description" content="{{ seo_meta | escape }}">
  {%- elsif template.name == 'collection' -%}
    {%- assign seo_meta = collection.metafields.global.description_tag -%}
    {%- if seo_meta == blank -%}
      {%- assign seo_meta = 'Shop ' | append: collection.title | append: ' — functional mushroom seltzers with dual-extracted Lion''s Mane (900mg), Cordyceps (700mg) & Reishi (400mg). Zero caffeine, zero alcohol. From $23.99. Free shipping, no minimum.' -%}
    {%- endif -%}
    <meta name="description" content="{{ seo_meta | escape }}">
  {%- else -%}
    <meta name="description" content="{{ page_description | default: "Happie Fusion — functional mushroom seltzers with Lion's Mane, Cordyceps & Reishi. No alcohol, no caffeine. Real adaptogenic results." | escape }}">
  {%- endif -%}

  {%- comment -%} ── FAVICON ── {%- endcomment -%}
  <link rel="icon" type="image/png" sizes="32x32" href="{{ 'happie-favicon.png' | asset_url }}">
  <link rel="icon" type="image/png" sizes="192x192" href="{{ 'happie-favicon.png' | asset_url }}">
  <link rel="apple-touch-icon" href="{{ 'happie-favicon.png' | asset_url }}">

  {%- comment -%} ── PINTEREST VERIFICATION ── {%- endcomment -%}
  <meta name="p:domain_verify" content="f0abad25c419105077cd60ebf30f11db"/>

  {%- comment -%} ── SEO + GEO META TAGS ── {%- endcomment -%}
  {%- comment -%}
    Paid-traffic landing pages (any template starting with "page.lp-") should be noindex —
    they auto-apply a discount + compete with real product pages for the same keywords.
  {%- endcomment -%}
  {%- assign _ts = template.suffix | default: '' -%}
  {%- if _ts contains 'lp-' or _ts == 'three-mushrooms' or _ts == 'caffeine-free' -%}
    <meta name="robots" content="noindex, nofollow">
  {%- else -%}
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
    <meta name="googlebot" content="index, follow, max-image-preview:large, max-snippet:-1">
  {%- endif -%}
  <meta name="bingbot" content="index, follow">
  <meta name="theme-color" content="#2D6A4F">
  <meta name="author" content="Happie Fusion">
  <meta name="publisher" content="Happie Fusion">
  <meta name="geo.region" content="US-CA">
  <meta name="geo.placename" content="Northern California">
  <meta name="format-detection" content="telephone=yes">

  {%- comment -%} ── GEO / AI SEARCH KEYWORDS — helps AI assistants understand the page ── {%- endcomment -%}
  {%- if template.name == 'index' -%}
    <meta name="keywords" content="functional mushroom drinks, mushroom seltzer, Lion's Mane drink, Cordyceps drink, Reishi drink, adaptogen beverage, caffeine-free energy drink, alcohol alternative, sober curious drink, sparkling mushroom water, Happie Fungi Fusion">
  {%- elsif template.name == 'product' -%}
    <meta name="keywords" content="{{ product.title }}, mushroom seltzer, functional beverage, Lion's Mane, Cordyceps, Reishi, adaptogen drink, Happie Fungi Fusion">
  {%- endif -%}

  {%- comment -%} ── Performance hints for faster LCP ── {%- endcomment -%}
  <link rel="dns-prefetch" href="https://cdn.shopify.com">
  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

  {%- comment -%} ── LP hero preload: the LP product image is the LCP element, preload it responsively ── {%- endcomment -%}
  {%- if _ts contains 'lp-' -%}
    {%- comment -%} Map each LP template suffix to the product it features so preload matches the rendered hero. {%- endcomment -%}
    {%- if _ts contains 'mango' -%}
      {%- assign lp_handle = 'mango-mimosa-fungi-powered-seltzer' -%}
    {%- elsif _ts contains 'watermelon' -%}
      {%- assign lp_handle = 'watermelon-fungi-powered-seltzer' -%}
    {%- else -%}
      {%- assign lp_handle = 'blue-razzberry-fungi-powered-seltzer' -%}
    {%- endif -%}
    {%- assign lp_product = all_products[lp_handle] -%}
    {%- assign lp_hero = lp_product.images | first -%}
    {%- if lp_hero != blank -%}
      <link rel="preload" as="image"
        imagesrcset="{{ lp_hero | image_url: width: 360 }} 360w, {{ lp_hero | image_url: width: 540 }} 540w, {{ lp_hero | image_url: width: 720 }} 720w"
        imagesizes="(max-width: 480px) 92vw, (max-width: 768px) 60vw, 480px"
        fetchpriority="high">
    {%- endif -%}
  {%- elsif template.name == 'product' -%}
    {%- comment -%} PDP: the gallery hero is the LCP element — imagesizes must match the img's sizes attr in main-product.liquid {%- endcomment -%}
    {%- assign pdp_hero = product.images | first -%}
    {%- if pdp_hero != blank -%}
      <link rel="preload" as="image"
        imagesrcset="{{ pdp_hero | image_url: width: 360 }} 360w, {{ pdp_hero | image_url: width: 540 }} 540w, {{ pdp_hero | image_url: width: 720 }} 720w, {{ pdp_hero | image_url: width: 900 }} 900w"
        imagesizes="(max-width: 768px) 92vw, 600px"
        fetchpriority="high">
    {%- endif -%}
  {%- endif -%}

  <link rel="canonical" href="{{ canonical_url }}">

  {%- comment -%} ── OPEN GRAPH ── {%- endcomment -%}
  <meta property="og:site_name" content="Happie Fusion">
  <meta property="og:url" content="{{ canonical_url }}">
  <meta property="og:locale" content="en_US">
  {%- if template.name == 'product' -%}
    <meta property="og:type" content="product">
    <meta property="og:title" content="{{ product.title }} | Functional Mushroom Seltzer – Happie Fusion">
    <meta property="og:description" content="{{ product.metafields.global.description_tag | default: product.description | strip_html | truncate: 200 | escape }}">
    {%- if product.featured_image -%}
      <meta property="og:image" content="https:{{ product.featured_image | image_url: width: 1200 }}">
      <meta property="og:image:width" content="1200">
      <meta property="og:image:height" content="1200">
      <meta property="og:image:alt" content="{{ product.title | escape }}">
    {%- endif -%}
    <meta property="product:price:amount" content="{{ product.price | money_without_currency }}">
    <meta property="product:price:currency" content="{{ cart.currency.iso_code }}">
  {%- elsif template.name == 'index' -%}
    <meta property="og:type" content="website">
    <meta property="og:title" content="Functional Mushroom Drinks | Lion's Mane, Cordyceps & Reishi Seltzer – Happie Fusion">
    <meta property="og:description" content="Functional mushroom seltzers with 900mg Lion's Mane, 700mg Cordyceps & 400mg Reishi per can. No alcohol. No caffeine. Real results.">
    <meta property="og:image" content="{{ 'happie-logo.png' | asset_url }}">
  {%- else -%}
    <meta property="og:type" content="website">
    <meta property="og:title" content="{{ page_title }}{% unless page_title contains shop.name %} – {{ shop.name }}{% endunless %}">
    <meta property="og:description" content="{{ page_description | default: "Happie Fusion — functional mushroom seltzers with Lion's Mane, Cordyceps & Reishi." | escape }}">
    <meta property="og:image" content="{{ 'happie-logo.png' | asset_url }}">
  {%- endif -%}

  {%- comment -%} ── TWITTER CARD ── {%- endcomment -%}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content="@happiefusion">
  {%- if template.name == 'product' -%}
    <meta name="twitter:title" content="{{ product.title }} | Functional Mushroom Seltzer – Happie Fusion">
    <meta name="twitter:description" content="{{ product.metafields.global.description_tag | default: product.description | strip_html | truncate: 200 | escape }}">
    {%- if product.featured_image -%}
      <meta name="twitter:image" content="https:{{ product.featured_image | image_url: width: 1200 }}">
    {%- endif -%}
  {%- else -%}
    <meta name="twitter:title" content="{{ page_title }}{% unless page_title contains shop.name %} – {{ shop.name }}{% endunless %}">
    <meta name="twitter:description" content="{{ page_description | default: 'Functional mushroom seltzers — no alcohol, no caffeine, real adaptogenic results.' | escape }}">
    <meta name="twitter:image" content="{{ 'happie-logo.png' | asset_url }}">
  {%- endif -%}

  {%- comment -%} ── STRUCTURED DATA: ORGANIZATION + WEBSITE (Homepage only) ── {%- endcomment -%}
  {%- if template.name == 'index' -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "https://happiefusion.com/#organization",
        "name": "Happie Fusion",
        "url": "https://happiefusion.com",
        "logo": {
          "@type": "ImageObject",
          "url": "{{ 'happie-logo.png' | asset_url }}",
          "width": 400,
          "height": 100
        },
        "description": "Happie Fusion makes Fungi Fusion — functional mushroom seltzers with dual-extracted Lion's Mane (900mg), Cordyceps (700mg), and Reishi (400mg) per can. No alcohol, no caffeine, no jitters. Just real adaptogenic results.",
        "foundingDate": "2024",
        "foundingLocation": { "@type": "Place", "address": { "@type": "PostalAddress", "addressRegion": "California", "addressCountry": "US" } },
        "areaServed": { "@type": "Country", "name": "United States" },
        "knowsAbout": [
          "Functional mushrooms",
          "Adaptogens",
          "Lion's Mane mushroom",
          "Cordyceps mushroom",
          "Reishi mushroom",
          "Mushroom seltzer",
          "Sober curious beverages",
          "Caffeine-free energy drinks",
          "Dual-extracted mushroom supplements"
        ],
        "sameAs": [
          "https://www.instagram.com/happiefusion/",
          "https://www.tiktok.com/@drinkhappie1",
          "https://www.amazon.com/stores/Happie-Fusion"
        ],
        "contactPoint": {
          "@type": "ContactPoint",
          "email": "orders@livehappie.com",
          "telephone": "+1-833-374-6567",
          "contactType": "customer service",
          "availableLanguage": "English"
        },
        "founder": { "@id": "https://happiefusion.com/#founder" },
        "brand": { "@id": "https://happiefusion.com/#brand" }
      },
      {
        "@type": "Person",
        "@id": "https://happiefusion.com/#founder",
        "name": "Pete Olander",
        "jobTitle": "Founder & CEO",
        "worksFor": { "@id": "https://happiefusion.com/#organization" },
        "knowsAbout": [
          "Functional mushroom beverages",
          "Adaptogens",
          "Lion's Mane mushroom",
          "Cordyceps mushroom",
          "Reishi mushroom",
          "Beverage product development",
          "Direct-to-consumer brands",
          "Sober-curious movement"
        ],
        "sameAs": [
          "https://www.linkedin.com/in/pete-olander-580a657/"
        ]
      },
      {
        "@type": "Brand",
        "@id": "https://happiefusion.com/#brand",
        "name": "Happie Fungi Fusion",
        "logo": "{{ 'happie-logo.png' | asset_url }}",
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "4.9",
          "reviewCount": "1200",
          "bestRating": "5",
          "worstRating": "1"
        }
      },
      {
        "@type": "WebSite",
        "@id": "https://happiefusion.com/#website",
        "url": "https://happiefusion.com",
        "name": "Happie Fusion",
        "publisher": { "@id": "https://happiefusion.com/#organization" },
        "inLanguage": "en-US",
        "potentialAction": {
          "@type": "SearchAction",
          "target": {
            "@type": "EntryPoint",
            "urlTemplate": "https://happiefusion.com/search?q={search_term_string}"
          },
          "query-input": "required name=search_term_string"
        }
      },
      {
        "@type": "FAQPage",
        "@id": "https://happiefusion.com/#faq",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "What is Happie Fungi Fusion?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Happie Fungi Fusion is a functional mushroom sparkling seltzer containing 2,000mg of dual-extracted fruiting body mushrooms per 12oz can: 900mg Lion's Mane for focus, 700mg Cordyceps for natural energy, and 400mg Reishi for calm. It contains zero alcohol, zero caffeine, and only 40 calories. Available in Blue Razzberry, Mango Mimosa, and Watermelon flavors."
            }
          },
          {
            "@type": "Question",
            "name": "Does Happie Fungi Fusion have caffeine?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "No. Happie Fungi Fusion is 100% caffeine-free. The energy benefits come from Cordyceps mushroom, which supports cellular ATP production naturally — no stimulants, no crash."
            }
          },
          {
            "@type": "Question",
            "name": "Is Happie Fungi Fusion safe to drink every day?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes. Happie Fungi Fusion is formulated for daily use. The adaptogenic benefits of Lion's Mane, Cordyceps, and Reishi build over time with consistent daily consumption. Most customers report noticeable improvements in focus, energy, and sleep quality within 2 to 4 weeks."
            }
          },
          {
            "@type": "Question",
            "name": "How much does Happie Fungi Fusion cost?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "A 6-pack costs $23.99. A 12-can Variety Pack costs $38.99. Subscribe and Save members get 20% off every order plus free shipping. New customers get 15% off their first order with code WELCOME15. Free shipping on every order — no minimum."
            }
          },
          {
            "@type": "Question",
            "name": "Is Happie Fungi Fusion psychedelic?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "No. Happie Fungi Fusion contains only functional (adaptogenic) mushrooms — Lion's Mane, Cordyceps, and Reishi. These are completely different from psilocybin mushrooms. They are legal in all 50 US states, non-psychoactive, and backed by decades of peer-reviewed research."
            }
          },
          {
            "@type": "Question",
            "name": "Where can I buy Happie Fungi Fusion?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Happie Fungi Fusion is available directly at happiefusion.com with free shipping on every order to all 50 US states, no minimum, and on Amazon. New customers get 15% off their first order with code WELCOME15."
            }
          }
        ]
      }
    ]
  }
  </script>

  {%- comment -%} ── SPEAKABLE schema for voice assistants ── {%- endcomment -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "speakable": {
      "@type": "SpeakableSpecification",
      "cssSelector": [".hero-headline", ".hero-sub", ".section-title"]
    }
  }
  </script>
  {%- endif -%}

  {%- comment -%} ── STRUCTURED DATA: PRODUCT + RATINGS + BREADCRUMBS ── {%- endcomment -%}
  {%- if template.name == 'product' -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": {{ product.title | json }},
    "description": {{ product.description | strip_html | strip | truncate: 500 | json }},
    "brand": {
      "@type": "Brand",
      "name": "Happie Fusion"
    },
    "url": {{ canonical_url | json }},
    "image": [
      {% for image in product.images limit: 4 %}
        "https:{{ image | image_url: width: 800 }}"{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ],
    "sku": {{ product.selected_or_first_available_variant.sku | default: product.id | json }},
    "category": "Functional Beverages",
    "offers": [
      {% for variant in product.variants %}
      {
        "@type": "Offer",
        "name": {{ variant.title | json }},
        "price": "{{ variant.price | money_without_currency }}",
        "priceCurrency": "USD",
        "availability": "{% if variant.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
        "url": "{{ canonical_url }}?variant={{ variant.id }}",
        "seller": { "@type": "Organization", "name": "Happie Fusion" },
        "shippingDetails": {
          "@type": "OfferShippingDetails",
          "shippingRate": { "@type": "MonetaryAmount", "value": "5.99", "currency": "USD" },
          "shippingDestination": { "@type": "DefinedRegion", "addressCountry": "US" },
          "deliveryTime": {
            "@type": "ShippingDeliveryTime",
            "handlingTime": { "@type": "QuantitativeValue", "minValue": 0, "maxValue": 1, "unitCode": "DAY" },
            "transitTime": { "@type": "QuantitativeValue", "minValue": 3, "maxValue": 5, "unitCode": "DAY" }
          }
        },
        "hasMerchantReturnPolicy": {
          "@type": "MerchantReturnPolicy",
          "applicableCountry": "US",
          "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
          "merchantReturnDays": 30,
          "returnMethod": "https://schema.org/ReturnByMail",
          "returnFees": "https://schema.org/FreeReturn"
        }
      }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ],
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "reviewCount": "1200",
      "bestRating": "5",
      "worstRating": "1"
    },
    "additionalProperty": [
      { "@type": "PropertyValue", "name": "Lion's Mane", "value": "900mg per can, dual-extracted fruiting body" },
      { "@type": "PropertyValue", "name": "Cordyceps", "value": "700mg per can, dual-extracted fruiting body" },
      { "@type": "PropertyValue", "name": "Reishi", "value": "400mg per can, dual-extracted fruiting body" },
      { "@type": "PropertyValue", "name": "Caffeine", "value": "0mg — caffeine free" },
      { "@type": "PropertyValue", "name": "Alcohol", "value": "0% — alcohol free" },
      { "@type": "PropertyValue", "name": "Calories", "value": "~40 per can" },
      { "@type": "PropertyValue", "name": "Vegan", "value": "Yes" },
      { "@type": "PropertyValue", "name": "Non-GMO", "value": "Yes" }
    ]
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://happiefusion.com" },
      { "@type": "ListItem", "position": 2, "name": "All Products", "item": "https://happiefusion.com/collections/all" },
      { "@type": "ListItem", "position": 3, "name": {{ product.title | json }}, "item": {{ canonical_url | json }} }
    ]
  }
  </script>
  {%- endif -%}

  {{ content_for_header }}
  {%- comment -%} Fonts: preconnect + async-loaded stylesheet to avoid render-blocking {%- endcomment -%}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet"></noscript>
  {{ 'happie.css' | asset_url | stylesheet_tag }}
  {%- comment -%} Lenis smooth-scroll: defer so it doesn't block first paint (it's a UX nicety, not critical) {%- endcomment -%}
  <script src="https://cdn.jsdelivr.net/npm/lenis@1.1.14/dist/lenis.min.js" defer></script>
</head>
<body class="template-{{ template.name }}">
  {% section 'announcement-bar' %}
  {% section 'header' %}
  <main id="main-content">
    {{ content_for_layout }}
  </main>
  {% section 'footer' %}
  {%- comment -%} Email popup (WELCOME15 / 15% off) hidden site-wide per merchant request.
       To re-enable: uncomment the line below. Section template itself is untouched. {%- endcomment -%}
  {%- comment -%} {% section 'email-popup' %} {%- endcomment -%}
  <div id="cart-drawer" class="cart-drawer">
    <div class="cart-drawer-overlay"></div>
    <div class="cart-drawer-panel">
      <div class="cart-drawer-header">
        <h3>Your Cart</h3>
        <button class="cart-drawer-close" aria-label="Close cart">✕</button>
      </div>
      <div class="cart-drawer-body" id="cart-drawer-body">
        <p class="cart-empty-msg">Your cart is empty.</p>
      </div>
      <div class="cart-drawer-footer">
        <div class="cart-subtotal">
          <span>Subtotal</span>
          <span id="cart-subtotal-price">$0.00</span>
        </div>
        <p class="cart-free-ship-note">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="margin-right:6px;vertical-align:-2px;">
            <rect x="1" y="6" width="15" height="11" rx="2"/><path d="M16 10h4l3 3v4h-7"/><circle cx="5.5" cy="19.5" r="1.5"/><circle cx="20.5" cy="19.5" r="1.5"/>
          </svg>
          Free shipping on every order, no minimum
        </p>
        <a href="/checkout" class="btn-cart-checkout">Secure Checkout →</a>
        <a href="/cart" class="btn-cart-view">View Cart</a>
        <div class="cart-trust-row" aria-label="Accepted payment methods">
          <svg viewBox="0 0 34 22" width="34" height="22" role="img" aria-label="Visa"><rect width="34" height="22" rx="3" fill="#1A1F71"/><text x="17" y="15.5" font-family="Arial,sans-serif" font-weight="900" font-size="9" fill="#fff" text-anchor="middle" letter-spacing="0.5">VISA</text></svg>
          <svg viewBox="0 0 34 22" width="34" height="22" role="img" aria-label="Mastercard"><rect width="34" height="22" rx="3" fill="#fff" stroke="#e5e5e5"/><circle cx="13" cy="11" r="6" fill="#EB001B"/><circle cx="21" cy="11" r="6" fill="#F79E1B"/><path d="M17 6.5a6 6 0 0 0 0 9 6 6 0 0 0 0-9z" fill="#FF5F00"/></svg>
